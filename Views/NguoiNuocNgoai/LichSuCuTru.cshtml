@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.LichSuCuTru>
@{
    Layout = "_ForeignerServiceLayout";
    ViewData["Title"] = "Lịch sử cư trú";
    var cuTruModel = ViewBag.CuTruModel as ManagementOfForeigners.Models.ViewModels.NguoiNuocNgoai.CuTruViewModel ?? new ManagementOfForeigners.Models.ViewModels.NguoiNuocNgoai.CuTruViewModel();
}

<link rel="stylesheet" href="~/css/khai-bao-tam-tru.css" asp-append-version="true" />

<div class="row g-4">
    <!-- Cột trái: Sidebar điều hướng & thông tin tài khoản -->
    <div class="col-lg-3">
        @await Html.PartialAsync("_ForeignerProfileSidebar")
    </div>
    
    <!-- Cột phải: Lịch sử cư trú và Cập nhật nơi cư trú mới -->
    <div class="col-lg-9">
        <!-- Collapsible Update Form Card -->
        <div class="collapse mb-4" id="collapseUpdateResidence">
            <div class="service-card">
                <div class="service-card-header">
                    <h5 class="fw-bold mb-0 text-success"><i class="bi bi-pencil-square me-2"></i>Cập nhật nơi cư trú mới</h5>
                    <p class="text-muted small mb-0 mt-1">Khai báo ngay khi bạn chuyển đến nơi ở mới</p>
                </div>

                <form asp-action="CapNhatNoiCuTru" method="post">
                    @Html.AntiForgeryToken()
                    <div class="service-card-body">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark fs-7">Cơ sở lưu trú đăng ký mới</label>
                                <div class="search-combobox">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                                        <input type="text"
                                               id="ResidenceCoSoSearchInput"
                                               class="form-control"
                                               placeholder="Nhập tối thiểu 2 ký tự tên, địa chỉ..."
                                               autocomplete="off"
                                               required />
                                    </div>
                                    <input type="hidden" name="MaCoSoLuuTru" id="ResidenceMaCoSoLuuTru" />
                                    <span id="ResidenceMaCoSoLuuTru-error-custom" class="text-danger fs-8" style="display:none;"></span>
                                    <div id="ResidenceCoSoSearchResults" class="search-results"></div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-semibold text-dark fs-7">Số phòng / Số căn hộ</label>
                                <input name="Phong" class="form-control" placeholder="Ví dụ: 402, Villa A..." style="border-radius: 8px;" required />
                                <span class="text-danger fs-8"></span>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-semibold text-dark fs-7">Ngày bắt đầu đến ở</label>
                                <input name="NgayBatDau" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" style="border-radius: 8px;" required />
                                <span class="text-danger fs-8"></span>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-semibold text-dark fs-7">Ghi chú / Yêu cầu thêm</label>
                                <textarea name="GhiChu" class="form-control" rows="2" placeholder="Ghi chú thêm về nơi ở..." style="border-radius: 8px;"></textarea>
                            </div>
                        </div>

                        <div class="alert alert-warning fs-8 text-muted border-0 p-2 mt-3 mb-0" style="border-radius: 8px; background-color: #fffbeb;">
                            <i class="bi bi-info-circle me-1"></i> <strong>Lưu ý:</strong> Hệ thống sẽ tự động cập nhật trạng thái nơi ở cũ thành "Đã rời".
                        </div>
                    </div>

                    <div class="service-card-body border-top bg-light p-3 text-end">
                        <button type="button" class="btn btn-outline-secondary me-2 fw-semibold" data-bs-toggle="collapse" data-bs-target="#collapseUpdateResidence" style="border-radius: 8px;">Hủy</button>
                        <button type="submit" class="btn btn-outline-success fw-semibold px-4" style="border-radius: 8px;">Xác nhận chuyển nơi ở</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- List of stay history (Full width) -->
        <div class="service-card">
            <div class="service-card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="fw-bold mb-0 text-success"><i class="bi bi-geo-alt-fill me-2"></i>Lịch sử cư trú cá nhân</h5>
                    <p class="text-muted small mb-0 mt-1">Theo dõi nơi tạm trú của bạn tại TP Đà Nẵng</p>
                </div>
                <button class="btn btn-link text-success text-decoration-none fw-semibold p-0" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUpdateResidence" aria-expanded="false" aria-controls="collapseUpdateResidence" style="font-size: 0.9rem;">
                    <i class="bi bi-pencil-square me-1"></i> Cập nhật nơi cư trú mới
                </button>
            </div>
            <div class="service-card-body">
                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-geo-alt text-muted fs-1 mb-3 d-block"></i>
                        <p class="text-muted small mb-0">Bạn chưa có dữ liệu lịch sử cư trú nào.</p>
                    </div>
                }
                else
                {
                    <div class="residence-history-list">
                        @foreach (var item in Model)
                        {
                            <div class="residence-item py-3 border-bottom" style="border-color: #f1f5f9 !important;">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <span class="fw-bold text-dark" style="font-size: 1rem;">@(item.CoSoLuuTru?.TenCoSo ?? "Cư trú tự do / Ngoài cơ sở")</span>
                                            <span class="badge @(item.TrangThai == "Đang ở" ? "bg-success" : "bg-secondary")" style="font-size: 0.72rem;">
                                                @item.TrangThai
                                            </span>
                                        </div>
                                        <div class="text-muted small mt-1" style="font-size: 0.8rem;">
                                            <i class="bi bi-calendar-range me-1"></i> Thời gian: @item.NgayBatDau.ToString("dd/MM/yyyy") - @(item.NgayKetThuc.HasValue ? item.NgayKetThuc.Value.ToString("dd/MM/yyyy") : "Hiện tại")
                                        </div>
                                    </div>
                                    <div class="text-secondary small" style="font-size: 0.85rem;">
                                        Phòng: <strong class="text-dark">@item.Phong</strong>
                                    </div>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-end flex-wrap gap-2 mt-2" style="font-size: 0.825rem;">
                                    <div class="text-secondary">
                                        <i class="bi bi-geo-alt-fill text-muted me-1"></i>Địa chỉ: <span class="text-dark">@(item.CoSoLuuTru?.DiaChi ?? "Địa chỉ tự khai")</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.GhiChu))
                                    {
                                        <div class="text-muted">
                                            <i class="bi bi-info-circle me-1"></i> Ghi chú: @item.GhiChu
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    <div class="d-flex justify-content-center mt-3">
                        @Html.PagedListPager(Model, page => Url.Action("LichSuCuTru", new { page }),
                            new X.PagedList.Mvc.Core.PagedListRenderOptions {
                                LiElementClasses = new string[] { "page-item" },
                                PageClasses = new string[] { "page-link" },
                                UlElementClasses = new string[] { "pagination", "pagination-sm" }
                            })
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/khai-bao-tam-tru.js" asp-append-version="true"></script>
}
