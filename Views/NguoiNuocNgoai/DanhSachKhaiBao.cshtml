@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.HoSoKhaiBaoTamTru>
@{
    Layout = "_ForeignerServiceLayout";
    ViewData["Title"] = "Lịch sử khai báo";
}

<div class="row g-4">
    <!-- Cột trái: Sidebar điều hướng & thông tin tài khoản -->
    <div class="col-lg-3">
        @await Html.PartialAsync("_ForeignerProfileSidebar")
    </div>
    
    <!-- Cột phải: Lịch sử khai báo tạm trú -->
    <div class="col-lg-9">
        <div class="service-card">
            <div class="service-card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-success"></i>Lịch sử khai báo tạm trú</h5>
                    <p class="text-muted small mb-0 mt-1">Danh sách tất cả tờ khai bạn đã gửi lên hệ thống</p>
                </div>
                <a asp-action="KhaiBaoTamTru" class="btn btn-link text-success text-decoration-none fw-semibold p-0" style="font-size: 0.9rem;">
                    <i class="bi bi-plus-lg me-1"></i> Khai báo mới
                </a>
            </div>

            <div class="service-card-body">
                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-file-earmark-excel text-muted fs-1 mb-3 d-block"></i>
                        <h6 class="fw-bold text-dark">Chưa có dữ liệu khai báo</h6>
                        <p class="text-muted small mb-3">Bạn chưa gửi bất kỳ tờ khai báo tạm trú nào trên hệ thống.</p>
                        <a asp-action="KhaiBaoTamTru" class="text-success text-decoration-none fw-semibold d-inline-flex align-items-center gap-1">
                            Khai báo tạm trú ngay <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                }
                else
                {
                    <div class="declaration-history-list">
                        @foreach (var dec in Model)
                        {
                            <div class="declaration-item py-3 border-bottom" style="border-color: #f1f5f9 !important;">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <span class="fw-bold text-success" style="font-size: 1rem;">#@dec.MaHSKhaiBao</span>
                                            <span class="badge bg-light text-secondary border fs-8">@dec.MucDichLuuTru</span>
                                            @await Html.PartialAsync("_StatusBadge", dec.TrangThai)
                                        </div>
                                        <div class="text-muted small mt-1" style="font-size: 0.8rem;">
                                            <i class="bi bi-calendar-check me-1"></i> Ngày khai: @dec.NgayKhaiBao.ToString("dd/MM/yyyy")
                                            <span class="mx-2 text-light">|</span>
                                            <i class="bi bi-clock me-1"></i> Thời hạn: @dec.NgayBatDau.ToString("dd/MM/yyyy") - @dec.NgayKetThuc.ToString("dd/MM/yyyy")
                                        </div>
                                    </div>
                                    <div>
                                        <a asp-action="ChiTietKhaiBao" asp-route-id="@dec.MaHSKhaiBao" class="btn btn-link text-success text-decoration-none fw-semibold p-0" style="font-size: 0.85rem;">
                                            Chi tiết <i class="bi bi-chevron-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                                
                                <div class="text-secondary small mt-2 d-flex flex-wrap gap-x-4 gap-y-1" style="font-size: 0.825rem;">
                                    <div>
                                        <i class="bi bi-geo-alt-fill text-muted me-1"></i>Địa chỉ: <span class="text-dark">@dec.DiaChiLuuTru</span>
                                    </div>
                                    <div class="d-none d-md-block text-muted">|</div>
                                    <div>
                                        <i class="bi bi-building text-muted me-1"></i>Cơ sở: <span class="fw-semibold text-dark">@(dec.CoSoLuuTru?.TenCoSo ?? "Tự khai báo ngoài cơ sở")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    <div class="d-flex justify-content-center mt-4">
                        @Html.PagedListPager(Model, page => Url.Action("DanhSachKhaiBao", new { page }),
                            new X.PagedList.Mvc.Core.PagedListRenderOptions {
                                LiElementClasses = new string[] { "page-item" },
                                PageClasses = new string[] { "page-link" },
                                UlElementClasses = new string[] { "pagination", "pagination-sm" }
                            })
                    </div>
                }
            </div>
        </div>
    </div>
</div>
