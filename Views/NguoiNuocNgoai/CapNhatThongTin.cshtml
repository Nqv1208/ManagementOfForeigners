@model ManagementOfForeigners.Models.ViewModels.NguoiNuocNgoai.CapNhatThongTinViewModel
@{
    Layout = "_ForeignerServiceLayout";
    ViewData["Title"] = "Cập nhật hồ sơ";
}

<div class="row g-4">
    <!-- Cột trái: Sidebar điều hướng & thông tin tài khoản -->
    <div class="col-lg-3">
        @await Html.PartialAsync("_ForeignerProfileSidebar")
    </div>
    
    <!-- Cột phải: Form cập nhật thông tin -->
    <div class="col-lg-9">
        <div class="service-card">
            <div class="service-card-header">
                <h5><i class="bi bi-pencil-square text-success me-2"></i>Cập nhật thông tin cá nhân</h5>
            </div>

            <form asp-action="CapNhatThongTin" method="post" class="needs-validation">
                @Html.AntiForgeryToken()
                <div class="service-card-body">
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <h6 class="fw-bold text-muted mb-3 uppercase-title fs-7">1. Thông tin cá nhân</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="HoTen" class="form-label fw-semibold text-dark fs-7"></label>
                            <input asp-for="HoTen" class="form-control" placeholder="Ví dụ: John Smith" style="border-radius: 8px;" />
                            <span asp-validation-for="HoTen" class="text-danger fs-8"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="QuocTich" class="form-label fw-semibold text-dark fs-7"></label>
                            <input asp-for="QuocTich" class="form-control" placeholder="Ví dụ: United States" style="border-radius: 8px;" />
                            <span asp-validation-for="QuocTich" class="text-danger fs-8"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NgaySinh" class="form-label fw-semibold text-dark fs-7"></label>
                            <input asp-for="NgaySinh" class="form-control" type="date" style="border-radius: 8px;" />
                            <span asp-validation-for="NgaySinh" class="text-danger fs-8"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GioiTinh" class="form-label fw-semibold text-dark fs-7"></label>
                            <select asp-for="GioiTinh" class="form-select" style="border-radius: 8px;">
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                            <span asp-validation-for="GioiTinh" class="text-danger fs-8"></span>
                        </div>
                    </div>

                    <h6 class="fw-bold text-muted mb-3 uppercase-title fs-7">2. Thông tin hộ chiếu</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label asp-for="SoHoChieu" class="form-label fw-semibold text-dark fs-7"></label>
                            <input asp-for="SoHoChieu" class="form-control" placeholder="Số hộ chiếu" style="border-radius: 8px;" />
                            <span asp-validation-for="SoHoChieu" class="text-danger fs-8"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NgayCapHoChieu" class="form-label fw-semibold text-dark fs-7"></label>
                            <input asp-for="NgayCapHoChieu" class="form-control" type="date" style="border-radius: 8px;" />
                            <span asp-validation-for="NgayCapHoChieu" class="text-danger fs-8"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NgayHetHanHoChieu" class="form-label fw-semibold text-dark fs-7"></label>
                            <input asp-for="NgayHetHanHoChieu" class="form-control" type="date" style="border-radius: 8px;" />
                            <span asp-validation-for="NgayHetHanHoChieu" class="text-danger fs-8"></span>
                        </div>
                    </div>

                    <h6 class="fw-bold text-muted mb-3 uppercase-title fs-7">3. Thông tin liên hệ</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold text-dark fs-7"></label>
                            <input asp-for="Email" class="form-control" placeholder="email@vi-du.com" style="border-radius: 8px;" />
                            <span asp-validation-for="Email" class="text-danger fs-8"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SoDienThoai" class="form-label fw-semibold text-dark fs-7"></label>
                            <input asp-for="SoDienThoai" class="form-control" placeholder="Số điện thoại" style="border-radius: 8px;" />
                            <span asp-validation-for="SoDienThoai" class="text-danger fs-8"></span>
                        </div>
                    </div>

                    <h6 class="fw-bold text-danger mb-3 uppercase-title fs-7">4. Lý do cập nhật (Bắt buộc)</h6>
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="LyDoCapNhat" class="form-label fw-semibold text-dark fs-7"></label>
                            <textarea asp-for="LyDoCapNhat" class="form-control" rows="3" placeholder="Vui lòng cung cấp lý do chi tiết cho sự thay đổi này..." style="border-radius: 8px;"></textarea>
                            <span asp-validation-for="LyDoCapNhat" class="text-danger fs-8"></span>
                        </div>
                    </div>

                </div>

                <div class="card-footer bg-transparent border-0 p-4 d-flex justify-content-between">
                    <a asp-action="ThongTinCaNhan" class="btn btn-outline-secondary px-4" style="border-radius: 8px;">Hủy</a>
                    <button type="submit" class="btn btn-success px-4" style="border-radius: 8px;">Cập nhật hồ sơ</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
