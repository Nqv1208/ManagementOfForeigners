@model ManagementOfForeigners.Models.Entities.NguoiNuocNgoai
@{
    Layout = "_ForeignerServiceLayout";
    ViewData["Title"] = "Thông tin cá nhân";
    var taiKhoan = Model.TaiKhoan;
}

<div class="row g-4">
    <!-- Cột trái: Sidebar điều hướng & thông tin tài khoản -->
    <div class="col-lg-3">
        @await Html.PartialAsync("_ForeignerProfileSidebar")
    </div>
    
    <!-- Cột phải: Chi tiết hồ sơ cá nhân -->
    <div class="col-lg-9">
        <div class="service-card">
            <div class="service-card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="fw-bold mb-0 text-success"><i class="bi bi-person-badge-fill me-2"></i>Thông tin cá nhân</h5>
                    <p class="text-muted small mb-0 mt-1">Xem chi tiết thông tin hồ sơ và tài khoản của bạn</p>
                </div>
                <a asp-action="CapNhatThongTin" class="btn btn-link text-success text-decoration-none fw-semibold p-0" style="font-size: 0.9rem;">
                    <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa thông tin
                </a>
            </div>

            <div class="service-card-body">
                <!-- Group 1: Thông tin cá nhân -->
                <div class="mb-4">
                    <h6 class="text-success mb-2" style="font-weight: 600; font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">Thông tin cá nhân</h6>
                    <div class="border-top" style="border-color: #f1f5f9 !important;">
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Họ và tên</div>
                            <div class="col-sm-8 px-0 text-dark">@Model.HoTen</div>
                        </div>
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Quốc tịch</div>
                            <div class="col-sm-8 px-0 text-dark">@Model.QuocTich</div>
                        </div>
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Ngày sinh</div>
                            <div class="col-sm-8 px-0 text-dark">@Model.NgaySinh.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Giới tính</div>
                            <div class="col-sm-8 px-0 text-dark">@Model.GioiTinh</div>
                        </div>
                    </div>
                </div>

                <!-- Group 2: Hộ chiếu & Thị thực (Visa) -->
                <div class="mb-4">
                    <h6 class="text-success mb-2" style="font-weight: 600; font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">Hộ chiếu & Thị thực (Visa)</h6>
                    <div class="border-top" style="border-color: #f1f5f9 !important;">
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Số hộ chiếu</div>
                            <div class="col-sm-8 px-0 text-dark">@Model.SoHoChieu</div>
                        </div>
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Ngày cấp hộ chiếu</div>
                            <div class="col-sm-8 px-0 text-dark">@Model.NgayCapHoChieu.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Ngày hết hạn hộ chiếu</div>
                            <div class="col-sm-8 px-0 text-danger">@Model.NgayHetHanHoChieu.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Loại Visa / Thị thực</div>
                            <div class="col-sm-8 px-0 text-dark">@Model.LoaiVisa</div>
                        </div>
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Ngày hết hạn Visa</div>
                            <div class="col-sm-8 px-0 text-danger">@Model.NgayHetHanVisa.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                </div>

                <!-- Group 3: Thông tin tài khoản liên lạc -->
                <div class="mb-2">
                    <h6 class="text-success mb-2" style="font-weight: 600; font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">Thông tin tài khoản liên lạc</h6>
                    <div class="border-top" style="border-color: #f1f5f9 !important;">
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Email liên hệ</div>
                            <div class="col-sm-8 px-0 text-dark">@(taiKhoan?.Email ?? "Chưa cập nhật")</div>
                        </div>
                        <div class="row py-2 border-bottom align-items-center" style="border-color: #f1f5f9 !important; margin-left: 0; margin-right: 0;">
                            <div class="col-sm-4 px-0 text-secondary small">Số điện thoại</div>
                            <div class="col-sm-8 px-0 text-dark">@(taiKhoan?.SoDienThoai ?? "Chưa cập nhật")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
