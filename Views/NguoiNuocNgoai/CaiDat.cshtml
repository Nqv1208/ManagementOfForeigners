@model ManagementOfForeigners.Models.Entities.TaiKhoan
@{
    Layout = "_ForeignerServiceLayout";
    ViewData["Title"] = "Cài đặt tài khoản";
}

<div class="row g-4">
    <!-- Cột trái: Sidebar điều hướng & thông tin tài khoản -->
    <div class="col-lg-3">
        @await Html.PartialAsync("_ForeignerProfileSidebar")
    </div>
    
    <!-- Cột phải: Cài đặt tài khoản -->
    <div class="col-lg-9">
        <div class="service-card">
            <div class="service-card-header">
                <h5><i class="bi bi-gear-fill me-2 text-success"></i>Cài đặt tài khoản & Bảo mật</h5>
            </div>
            <div class="service-card-body">
                
                <!-- Section 1: Thông tin đăng nhập -->
                <h6 class="fw-bold text-muted mb-3 text-uppercase small fs-7" style="letter-spacing: 0.5px;">1. Thông tin tài khoản</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-semibold">Tên đăng nhập (Username)</label>
                        <input class="form-control bg-light" value="@Model.TenDangNhap" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-semibold">Vai trò tài khoản</label>
                        <input class="form-control bg-light" value="Người nước ngoài" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-semibold">Địa chỉ Email</label>
                        <input class="form-control" value="@Model.Email" placeholder="Chưa cập nhật email" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-semibold">Số điện thoại liên lạc</label>
                        <input class="form-control" value="@Model.SoDienThoai" placeholder="Chưa cập nhật số điện thoại" />
                    </div>
                </div>

                <hr class="my-4" />

                <!-- Section 2: Đổi mật khẩu -->
                <h6 class="fw-bold text-muted mb-3 text-uppercase small fs-7" style="letter-spacing: 0.5px;">2. Thay đổi mật khẩu</h6>
                <form method="post" action="#">
                    <div class="row g-3 mb-4">
                        <div class="col-md-12">
                            <label class="form-label text-secondary small fw-semibold">Mật khẩu hiện tại</label>
                            <input type="password" class="form-control" placeholder="Nhập mật khẩu hiện tại của bạn" style="border-radius: 8px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-semibold">Mật khẩu mới</label>
                            <input type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" style="border-radius: 8px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small fw-semibold">Xác nhận mật khẩu mới</label>
                            <input type="password" class="form-control" placeholder="Nhập lại mật khẩu mới" style="border-radius: 8px;" />
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small"><i class="bi bi-shield-lock me-1"></i> Mật khẩu nên kết hợp chữ, số và ký tự đặc biệt.</span>
                        <button type="button" class="btn btn-success px-4" style="border-radius: 8px;">Lưu thay đổi</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
