@model IEnumerable<ManagementOfForeigners.Models.ViewModels.QuanTri.NhatKyHoatDongViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Nhật ký hệ thống";
    string? search = ViewBag.Search as string;
    string? category = ViewBag.Category as string;
    string? status = ViewBag.Status as string;
    string? fromDate = ViewBag.FromDate as string;
    string? toDate = ViewBag.ToDate as string;
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1">Nhật ký hoạt động hệ thống</h4>
            <p class="text-muted mb-0 small">Giám sát các thao tác nghiệp vụ, thay đổi hồ sơ, cảnh báo và xử lý báo cáo vi phạm.</p>
        </div>
    </div>

    <!-- Filter Card -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; background-color: #fff;">
        <div class="card-body p-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-bold text-secondary small text-uppercase">Tìm trong nhật ký</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input class="form-control border-start-0" name="search" value="@search" placeholder="Tài khoản, nội dung chi tiết..." />
                    </div>
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label fw-bold text-secondary small text-uppercase">Loại hoạt động</label>
                    <select class="form-select" name="category">
                        <option value="">Tất cả</option>
                        <option value="Cập nhật thông tin" selected="@(category == "Cập nhật thông tin")">Cập nhật thông tin</option>
                        <option value="Cảnh báo vi phạm" selected="@(category == "Cảnh báo vi phạm")">Cảnh báo vi phạm</option>
                        <option value="Báo cáo vi phạm" selected="@(category == "Báo cáo vi phạm")">Báo cáo vi phạm</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label fw-bold text-secondary small text-uppercase">Từ ngày</label>
                    <input type="date" class="form-control" name="fromDate" value="@fromDate" />
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label fw-bold text-secondary small text-uppercase">Đến ngày</label>
                    <input type="date" class="form-control" name="toDate" value="@toDate" />
                </div>
                <div class="col-lg-3 col-md-12 d-flex gap-2">
                    <button class="btn btn-success flex-grow-1" type="submit">Lọc</button>
                    <a class="btn btn-outline-secondary" asp-controller="QuanTri" asp-action="NhatKyHeThong">Đặt lại</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Data Panel -->
    <div class="card border-0 shadow-sm" style="border-radius: 12px; background-color: #fff;">
        <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-dark mb-0"><i class="bi bi-journal-text me-2 text-success"></i>Nhật ký ghi nhận</h5>
            <span class="badge bg-light text-dark border px-3 py-1.5 fw-semibold">@Model.Count() dòng nhật ký</span>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size: 0.88rem; cursor: pointer;">
                    <thead>
                        <tr class="table-light">
                            <th style="width: 18%;">Thời gian</th>
                            <th style="width: 15%;">Người thực hiện</th>
                            <th style="width: 18%;">Loại hoạt động</th>
                            <th style="width: 37%;">Nội dung chi tiết</th>
                            <th style="width: 12%;" class="text-center">Kết quả</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-folder-x fs-3 d-block mb-2 text-secondary"></i>
                                    Không tìm thấy dòng nhật ký hoạt động nào khớp với bộ lọc.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr class="log-row" 
                                    data-bs-toggle="modal" data-bs-target="#logDetailModal"
                                    data-time="@item.OccurredAt.ToString("dd/MM/yyyy HH:mm:ss")"
                                    data-actor="@item.ActorOrSource"
                                    data-category="@item.Category"
                                    data-detail="@item.Detail"
                                    data-status="@item.Status">
                                    <td class="text-secondary fw-semibold">@item.OccurredAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td class="fw-bold text-dark">@item.ActorOrSource</td>
                                    <td><span class="badge bg-light text-dark border px-2 py-1">@item.Category</span></td>
                                    <td class="text-secondary text-truncate" style="max-width: 300px;">@item.Detail</td>
                                    <td class="text-center">
                                        @await Html.PartialAsync("_StatusBadge", item.Status)
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Log Details -->
<div class="modal fade" id="logDetailModal" tabindex="-1" aria-labelledby="logDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow" style="border-radius: 12px;">
            <div class="modal-header bg-light border-0 py-3" style="border-radius: 12px 12px 0 0;">
                <h6 class="modal-title fw-bold text-dark" id="logDetailModalLabel">
                    <i class="bi bi-info-circle me-2 text-success"></i> Chi tiết sự kiện nhật ký hệ thống
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3">
                            <small class="text-muted d-block text-uppercase fw-semibold mb-1" style="font-size: 0.75rem;">Thời gian xảy ra</small>
                            <span class="fw-bold text-dark" id="modal-log-time"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3">
                            <small class="text-muted d-block text-uppercase fw-semibold mb-1" style="font-size: 0.75rem;">Người thực hiện / Tác nhân</small>
                            <span class="fw-bold text-dark" id="modal-log-actor"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3">
                            <small class="text-muted d-block text-uppercase fw-semibold mb-1" style="font-size: 0.75rem;">Phân loại hoạt động</small>
                            <span class="badge bg-secondary text-white" id="modal-log-category"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3">
                            <small class="text-muted d-block text-uppercase fw-semibold mb-1" style="font-size: 0.75rem;">Kết quả xử lý</small>
                            <div id="modal-log-status-wrapper"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="p-3 bg-light rounded-3">
                            <small class="text-muted d-block text-uppercase fw-semibold mb-1" style="font-size: 0.75rem;">Nội dung chi tiết sự kiện</small>
                            <div class="fw-semibold text-dark text-break mt-1" id="modal-log-detail" style="font-family: monospace; white-space: pre-wrap; font-size: 0.9rem;"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light border-0 py-2" style="border-radius: 0 0 12px 12px;">
                <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const logRows = document.querySelectorAll(".log-row");
            const modalTime = document.getElementById("modal-log-time");
            const modalActor = document.getElementById("modal-log-actor");
            const modalCategory = document.getElementById("modal-log-category");
            const modalDetail = document.getElementById("modal-log-detail");
            const modalStatusWrapper = document.getElementById("modal-log-status-wrapper");

            logRows.forEach(row => {
                row.addEventListener("click", function () {
                    modalTime.textContent = this.getAttribute("data-time");
                    modalActor.textContent = this.getAttribute("data-actor");
                    modalCategory.textContent = this.getAttribute("data-category");
                    modalDetail.textContent = this.getAttribute("data-detail");

                    const status = this.getAttribute("data-status");
                    modalStatusWrapper.innerHTML = "";
                    
                    let badgeClass = "badge-neutral";
                    if (status === "Đã cập nhật" || status === "Đã xử lý" || status === "Đã duyệt" || status === "Hoạt động") {
                        badgeClass = "bg-success text-white";
                    } else if (status === "Lỗi" || status === "Thất bại" || status === "Từ chối") {
                        badgeClass = "bg-danger text-white";
                    } else if (status === "Chờ duyệt" || status === "Chờ xử lý") {
                        badgeClass = "bg-warning text-dark";
                    }
                    
                    const span = document.createElement("span");
                    span.className = `badge ${badgeClass} px-2.5 py-1.5 fw-bold`;
                    span.textContent = status;
                    modalStatusWrapper.appendChild(span);
                });
            });
        });
    </script>
}
