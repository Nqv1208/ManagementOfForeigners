@model ManagementOfForeigners.Models.ViewModels.QuanTri.TongQuanViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Tổng quan quản trị";
}

<div class="container-fluid py-4">
    <!-- Header Page Title -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1">Tổng quan quản trị hệ thống</h4>
            <p class="text-muted mb-0 small">Bảng điều khiển dành riêng cho Quản trị viên - Giám sát hoạt động và cấu hình hệ thống.</p>
        </div>
        <div class="bg-success bg-opacity-10 text-success px-3 py-2 rounded-3 fw-semibold small">
            <i class="bi bi-clock-history me-1"></i> Hôm nay có <strong>@Model.LogsTodayCount</strong> hoạt động hệ thống
        </div>
    </div>

    <!-- 4 Stat Cards Row -->
    <div class="row g-4 mb-4">
        <!-- 1. Total Accounts -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 12px; border-left: 4px solid #0d6efd !important; background-color: #fff;">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted fw-semibold small text-uppercase">Tổng số tài khoản</span>
                        <h2 class="fw-bold text-dark mt-2 mb-0">@Model.TotalAccounts</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3 d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="bi bi-people-fill fs-4 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Active Accounts -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 12px; border-left: 4px solid #198754 !important; background-color: #fff;">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted fw-semibold small text-uppercase">Tài khoản hoạt động</span>
                        <h2 class="fw-bold text-dark mt-2 mb-0">@Model.ActiveAccounts</h2>
                    </div>
                    <div class="bg-success bg-opacity-10 text-success rounded-circle p-3 d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="bi bi-check-circle-fill fs-4 text-success"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. Roles Count -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 12px; border-left: 4px solid #6f42c1 !important; background-color: #fff;">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted fw-semibold small text-uppercase">Vai trò hệ thống</span>
                        <h2 class="fw-bold text-dark mt-2 mb-0">@Model.TotalRoles</h2>
                    </div>
                    <div class="bg-purple bg-opacity-10 text-purple rounded-circle p-3 d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px; color: #6f42c1; background-color: rgba(111, 66, 193, 0.1);">
                        <i class="bi bi-shield-lock-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. Wards Count -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 12px; border-left: 4px solid #fd7e14 !important; background-color: #fff;">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted fw-semibold small text-uppercase">Danh mục Phường/Xã</span>
                        <h2 class="fw-bold text-dark mt-2 mb-0">@Model.TotalWards</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-3 d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px; color: #fd7e14; background-color: rgba(253, 126, 20, 0.1);">
                        <i class="bi bi-map-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2-Column Details Layout -->
    <div class="row g-4">
        <!-- Left Column: Recent Accounts -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px; background-color: #fff;">
                <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-people me-2 text-primary"></i>Tài khoản đăng ký gần đây</h5>
                    <a asp-controller="QuanTri" asp-action="TaiKhoan" class="text-decoration-none small text-success fw-semibold">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0" style="font-size: 0.88rem;">
                            <thead>
                                <tr class="table-light">
                                    <th class="border-0">Tên đăng nhập / Email</th>
                                    <th class="border-0">Chủ thể</th>
                                    <th class="border-0">Vai trò</th>
                                    <th class="border-0 text-center">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.LatestAccounts)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold text-dark">@item.TenDangNhap</div>
                                            <small class="text-muted">@item.Email</small>
                                        </td>
                                        <td>@item.OwnerDisplayName</td>
                                        <td>
                                            <span class="badge bg-light text-dark border px-2..5 py-1">@item.VaiTro</span>
                                        </td>
                                        <td class="text-center">
                                            @await Html.PartialAsync("_StatusBadge", item.TrangThai)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Recent Activity Logs -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px; background-color: #fff;">
                <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-journal-text me-2 text-success"></i>Nhật ký hoạt động mới nhất</h5>
                    <a asp-controller="QuanTri" asp-action="NhatKyHeThong" class="text-decoration-none small text-success fw-semibold">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex flex-column gap-3">
                        @if (!Model.LatestLogs.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-shield-check text-muted" style="font-size: 2.5rem;"></i>
                                <p class="text-muted mt-2 mb-0">Chưa có nhật ký hoạt động hệ thống nào hôm nay.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var log in Model.LatestLogs)
                            {
                                <div class="p-3 bg-light rounded-3">
                                    <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                                        <span class="fw-bold text-dark fs-7">@log.ActorOrSource</span>
                                        <small class="text-muted" style="font-size: 0.75rem;">@log.OccurredAt.ToString("HH:mm dd/MM")</small>
                                    </div>
                                    <div class="text-muted fs-8 mb-2">
                                        Phân nhóm: <span class="badge bg-secondary text-white">@log.Category</span>
                                    </div>
                                    <p class="mb-0 text-secondary fs-8 style-multiline-ellipsis">@log.Detail</p>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
