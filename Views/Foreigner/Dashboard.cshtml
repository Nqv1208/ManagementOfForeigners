@model ManagementOfForeigners.Models.ViewModels.Foreigner.DashboardViewModel
@{
    ViewBag.Title = "Bảng điều khiển - Người nước ngoài";
}

<div class="container py-4">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card bg-dark text-white border-0 shadow-sm overflow-hidden" style="border-radius: 16px;">
                <div class="card-body p-4 position-relative">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h4 class="fw-bold mb-1">Xin chào, @Model.PersonalInfo.HoTen! 👋</h4>
                            <p class="text-white-50 mb-0">Hộ chiếu: <strong>@Model.PersonalInfo.SoHoChieu</strong> | Quốc tịch: <strong>@Model.PersonalInfo.QuocTich</strong></p>
                        </div>
                        <div class="col-md-4 text-md-end mt-3 mt-md-0">
                            <span class="badge bg-success px-3 py-2 fs-7" style="border-radius: 8px;">Tài khoản: Hoạt động</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Warnings (Alerts) if any -->
    @if (Model.ActiveWarnings.Any(w => w.TrangThai != "Đã xử lý"))
    {
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card border-danger shadow-sm" style="border-radius: 12px; border-left: 5px solid #dc3545;">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0 text-danger me-3">
                                <i class="bi bi-exclamation-triangle-fill fs-2"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="fw-bold text-danger mb-1">CẢNH BÁO VI PHẠM TỪ CƠ QUAN QUẢN LÝ</h6>
                                <p class="mb-0 text-muted fs-7">Bạn có @Model.ActiveWarnings.Count(w => w.TrangThai != "Đã xử lý") cảnh báo vi phạm chưa được giải quyết. Vui lòng xem chi tiết bên dưới.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Main Content Grid -->
    <div class="row g-4">
        <!-- Personal Summary Card -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold text-dark mb-0">Hồ sơ cá nhân</h5>
                </div>
                <div class="card-body px-4">
                    <div class="text-center mb-4">
                        <div class="bg-light d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px; border-radius: 50%;">
                            <i class="bi bi-person text-secondary fs-1"></i>
                        </div>
                        <h6 class="fw-bold mt-3 mb-0">@Model.PersonalInfo.HoTen</h6>
                        <span class="text-muted fs-7">@Model.PersonalInfo.QuocTich</span>
                    </div>

                    <ul class="list-group list-group-flush fs-7">
                        <li class="list-group-item d-flex justify-content-between px-0 py-2">
                            <span class="text-muted">Ngày sinh:</span>
                            <span class="fw-semibold">@Model.PersonalInfo.NgaySinh.ToString("dd/MM/yyyy")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between px-0 py-2">
                            <span class="text-muted">Giới tính:</span>
                            <span class="fw-semibold">@Model.PersonalInfo.GioiTinh</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between px-0 py-2">
                            <span class="text-muted">Loại Visa:</span>
                            <span class="badge bg-light text-dark fw-bold border">@Model.PersonalInfo.LoaiVisa</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between px-0 py-2">
                            <span class="text-muted">Hết hạn Visa:</span>
                            <span class="fw-semibold text-danger">@Model.PersonalInfo.NgayHetHanVisa.ToString("dd/MM/yyyy")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between px-0 py-2">
                            <span class="text-muted">Email:</span>
                            <span class="fw-semibold">@Model.AccountInfo.Email</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between px-0 py-2">
                            <span class="text-muted">SĐT:</span>
                            <span class="fw-semibold">@Model.AccountInfo.SoDienThoai</span>
                        </li>
                    </ul>

                    <div class="d-grid gap-2 mt-4">
                        <a asp-action="ThongTinCaNhan" class="btn btn-outline-dark btn-sm" style="border-radius: 8px;">Xem Chi Tiết</a>
                        <a asp-action="CapNhatThongTin" class="btn btn-dark btn-sm" style="border-radius: 8px;">Cập Nhật Hồ Sơ</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick actions and lists -->
        <div class="col-lg-8">
            <div class="row g-4">
                <!-- Action Cards -->
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm hover-elevate" style="border-radius: 16px; transition: transform 0.2s;">
                        <div class="card-body p-4 d-flex align-items-center">
                            <div class="bg-primary text-white p-3 rounded-3 me-3">
                                <i class="bi bi-file-earmark-text fs-3"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Khai báo tạm trú mới</h6>
                                <p class="text-muted fs-8 mb-2">Thực hiện khai báo thời gian tạm trú tại Đà Nẵng</p>
                                <a asp-action="KhaiBaoTamTru" class="btn btn-primary btn-sm px-3" style="border-radius: 6px;">Khai báo</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 shadow-sm hover-elevate" style="border-radius: 16px; transition: transform 0.2s;">
                        <div class="card-body p-4 d-flex align-items-center">
                            <div class="bg-info text-white p-3 rounded-3 me-3">
                                <i class="bi bi-geo-alt fs-3"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Cập nhật nơi cư trú</h6>
                                <p class="text-muted fs-8 mb-2">Khai báo khi thay đổi chỗ ở/phòng trọ/khách sạn</p>
                                <a asp-action="LichSuCuTru" class="btn btn-info text-white btn-sm px-3" style="border-radius: 6px;">Cập nhật</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Declarations -->
                <div class="col-md-12">
                    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                        <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold text-dark mb-0">Hồ sơ khai báo tạm trú gần đây</h5>
                            <a asp-action="DanhSachKhaiBao" class="text-decoration-none fs-7 text-primary fw-semibold">Xem tất cả</a>
                        </div>
                        <div class="card-body px-4">
                            @if (!Model.RecentDeclarations.Any())
                            {
                                <div class="text-center py-4">
                                    <p class="text-muted fs-7 mb-0">Chưa có hồ sơ khai báo nào.</p>
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle fs-7 mb-0">
                                        <thead>
                                            <tr class="text-muted">
                                                <th>Mã hồ sơ</th>
                                                <th>Ngày khai báo</th>
                                                <th>Thời gian</th>
                                                <th>Địa chỉ</th>
                                                <th>Trạng thái</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var dec in Model.RecentDeclarations)
                                            {
                                                <tr>
                                                    <td>
                                                        <a asp-action="ChiTietKhaiBao" asp-route-id="@dec.MaHSKhaiBao" class="text-decoration-none fw-bold text-dark">
                                                            @dec.MaHSKhaiBao
                                                        </a>
                                                    </td>
                                                    <td>@dec.NgayKhaiBao.ToString("dd/MM/yyyy")</td>
                                                    <td>@dec.NgayBatDau.ToString("dd/MM") - @dec.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                                                    <td class="text-truncate" style="max-width: 150px;">@dec.DiaChiLuuTru</td>
                                                    <td>
                                                        @await Html.PartialAsync("_StatusBadge", dec.TrangThai)
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Warnings if any -->
                @if (Model.ActiveWarnings.Any())
                {
                    <div class="col-md-12">
                        <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                            <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                                <h5 class="fw-bold text-dark mb-0">Thông báo cảnh báo vi phạm (@Model.ActiveWarnings.Count)</h5>
                            </div>
                            <div class="card-body px-4">
                                <div class="list-group list-group-flush">
                                    @foreach (var warn in Model.ActiveWarnings)
                                    {
                                        <div class="list-group-item px-0 py-3 border-bottom">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="badge bg-danger">Mức độ: @warn.MucDoViPham</span>
                                                <small class="text-muted">@warn.NgayCanhBao.ToString("dd/MM/yyyy HH:mm")</small>
                                            </div>
                                            <h6 class="fw-bold mb-1 text-dark">Lỗi: @warn.LoaiViPham</h6>
                                            <p class="mb-1 text-secondary fs-7">Nội dung: @warn.NoiDungCanhBao</p>
                                            @if (!string.IsNullOrEmpty(warn.GhiChu))
                                            {
                                                <small class="text-muted d-block mt-1 bg-light p-2 rounded"><strong>Yêu cầu xử lý:</strong> @warn.GhiChu</small>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
