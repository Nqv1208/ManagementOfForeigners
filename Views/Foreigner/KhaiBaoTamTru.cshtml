@model ManagementOfForeigners.Models.ViewModels.Foreigner.KhaiBaoTamTruCreateViewModel
@{
    ViewBag.Title = "Tờ khai báo tạm trú";
}

<!-- Link custom style sheet directly in the view -->
<link rel="stylesheet" href="~/css/khai-bao-tam-tru.css" asp-append-version="true" />

<div class="temporary-residence-page py-3">
    <div class="declaration-shell">
        
        <!-- Header -->
        <div class="mb-4">
            <h3 class="fw-bold mb-1 text-primary-dark">Tờ khai báo tạm trú</h3>
            <p class="text-muted small mb-0">Khai báo thông tin lưu trú của người nước ngoài tại thành phố Đà Nẵng.</p>
        </div>

        <!-- Step Indicator -->
        <div class="stepper">
            <div class="step completed">
                <div class="step-number">1</div>
                <div class="step-label">Thông tin cá nhân</div>
            </div>
            <div class="step active">
                <div class="step-number">2</div>
                <div class="step-label">Nơi lưu trú</div>
            </div>
            <div class="step">
                <div class="step-number">3</div>
                <div class="step-label">Thời gian lưu trú</div>
            </div>
            <div class="step">
                <div class="step-number">4</div>
                <div class="step-label">Xác nhận</div>
            </div>
        </div>

        <form asp-action="KhaiBaoTamTru" method="post" id="declarationForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4 p-3 bg-danger bg-opacity-10 border border-danger border-opacity-20 rounded-3 small"></div>

            <!-- SECTION 1: Thông tin người nước ngoài -->
            <div class="declaration-section">
                <div class="section-title">
                    <i class="bi bi-person-circle text-primary"></i>Thông tin người nước ngoài
                </div>
                <div class="readonly-grid mb-3">
                    <div class="readonly-field">
                        <span class="readonly-label">Họ và tên</span>
                        <span class="readonly-value text-dark">@Model.HoTen</span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Giới tính</span>
                        <span class="readonly-value">@Model.GioiTinh</span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Ngày sinh</span>
                        <span class="readonly-value">
                            @(Model.NgaySinh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")
                        </span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Quốc tịch</span>
                        <span class="readonly-value">@Model.QuocTich</span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Số điện thoại</span>
                        <span class="readonly-value">
                            @if (string.IsNullOrWhiteSpace(Model.SoDienThoai))
                            {
                                <span class="text-muted fs-8">Chưa cập nhật</span>
                            }
                            else
                            {
                                @Model.SoDienThoai
                            }
                        </span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Email</span>
                        <span class="readonly-value">
                            @if (string.IsNullOrWhiteSpace(Model.Email))
                            {
                                <span class="text-muted fs-8">Chưa cập nhật</span>
                            }
                            else
                            {
                                @Model.Email
                            }
                        </span>
                    </div>
                </div>
                <div class="text-end">
                    <a asp-action="CapNhatThongTin" class="btn btn-xs btn-outline-primary fw-semibold rounded-pill py-1 px-3" style="font-size: 0.75rem;">
                        <i class="bi bi-pencil-square me-1"></i>Cập nhật thông tin cá nhân
                    </a>
                </div>
            </div>

            <!-- SECTION 2: Thông tin hộ chiếu và thị thực -->
            <div class="declaration-section">
                <div class="section-title">
                    <i class="bi bi-passport text-primary"></i>Thông tin hộ chiếu và thị thực
                </div>
                <div class="readonly-grid">
                    <div class="readonly-field">
                        <span class="readonly-label">Số hộ chiếu</span>
                        <span class="readonly-value text-dark">@Model.SoHoChieu</span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Loại hộ chiếu</span>
                        <span class="readonly-value">
                            @if (string.IsNullOrWhiteSpace(Model.LoaiHoChieu))
                            {
                                <span class="text-muted">Phổ thông</span>
                            }
                            else
                            {
                                @Model.LoaiHoChieu
                            }
                        </span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Hạn hộ chiếu</span>
                        <span class="readonly-value text-danger">
                            @(Model.NgayHetHanHoChieu?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")
                        </span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Số thị thực / Visa</span>
                        <span class="readonly-value">
                            @if (string.IsNullOrWhiteSpace(Model.SoVisa))
                            {
                                <span class="text-muted fs-8">Chưa cập nhật</span>
                            }
                            else
                            {
                                @Model.SoVisa
                            }
                        </span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Loại thị thực</span>
                        <span class="readonly-value">
                            @if (string.IsNullOrWhiteSpace(Model.LoaiVisa))
                            {
                                <span class="text-muted fs-8">Chưa cập nhật</span>
                            }
                            else
                            {
                                @Model.LoaiVisa
                            }
                        </span>
                    </div>
                    <div class="readonly-field">
                        <span class="readonly-label">Cửa khẩu nhập cảnh</span>
                        <span class="readonly-value">
                            @if (string.IsNullOrWhiteSpace(Model.CuaKhauNhapCanh))
                            {
                                <span class="text-muted fs-8">Chưa cập nhật</span>
                            }
                            else
                            {
                                @Model.CuaKhauNhapCanh
                            }
                        </span>
                    </div>
                </div>
                <div class="form-hint text-secondary mt-2">
                    <i class="bi bi-info-circle me-1"></i>Thông tin hộ chiếu và thị thực được lấy từ hồ sơ cá nhân hiện có.
                </div>
            </div>

            <!-- SECTION 3: Chi tiết lưu trú -->
            <div class="declaration-section">
                <div class="section-title">
                    <i class="bi bi-building-fill-check text-primary"></i>Chi tiết lưu trú
                </div>
                
                <div class="row">
                    <!-- Hàng 1: Phường/Xã | Cơ sở lưu trú -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="PhuongXaId" class="form-label required">Phường/Xã lưu trú</label>
                        <select asp-for="PhuongXaId" asp-items="Model.PhuongXaOptions" class="form-select">
                            <option value="">-- Chọn Phường/Xã --</option>
                        </select>
                        <span asp-validation-for="PhuongXaId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3 search-combobox">
                        <label class="form-label required">Cơ sở lưu trú</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" id="CoSoSearchInput" class="form-control" placeholder="Nhập tên cơ sở lưu trú, địa chỉ hoặc mã..." autocomplete="off" />
                        </div>
                        <input type="hidden" asp-for="CoSoLuuTruId" />
                        <span id="CoSoLuuTruId-error-custom" class="text-danger small" style="display:none;"></span>
                        <span asp-validation-for="CoSoLuuTruId" class="text-danger small"></span>

                        <!-- Autocomplete Dropdown -->
                        <div id="CoSoSearchResults" class="search-results"></div>
                    </div>

                    <!-- Hàng 2: Địa chỉ lưu trú cụ thể (Full width) -->
                    <div class="col-md-12 mb-3">
                        <label asp-for="DiaChiLuuTruCuThe" class="form-label required">Địa chỉ lưu trú cụ thể</label>
                        <input asp-for="DiaChiLuuTruCuThe" id="DiaChiLuuTruCuThe" class="form-control" placeholder="Số nhà, tên đường, tổ, thôn..." />
                        <span asp-validation-for="DiaChiLuuTruCuThe" class="text-danger small"></span>
                    </div>

                    <!-- Hàng 3: Ngày bắt đầu | Ngày kết thúc -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="NgayBatDau" class="form-label required">Ngày bắt đầu tạm trú</label>
                        <input asp-for="NgayBatDau" class="form-control" />
                        <span asp-validation-for="NgayBatDau" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="NgayKetThuc" class="form-label required">Ngày kết thúc tạm trú</label>
                        <input asp-for="NgayKetThuc" class="form-control" />
                        <span asp-validation-for="NgayKetThuc" class="text-danger small"></span>
                    </div>

                    <!-- Hàng 4: Mục đích lưu trú | Mục đích khác -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="MucDichLuuTru" class="form-label required">Mục đích lưu trú</label>
                        <select asp-for="MucDichLuuTru" class="form-select">
                            <option value="">-- Chọn mục đích --</option>
                            <option value="Du lịch">Du lịch</option>
                            <option value="Làm việc">Làm việc</option>
                            <option value="Học tập">Học tập</option>
                            <option value="Thăm thân">Thăm thân</option>
                            <option value="Công tác">Công tác</option>
                            <option value="Đầu tư">Đầu tư</option>
                            <option value="Khác">Khác</option>
                        </select>
                        <span asp-validation-for="MucDichLuuTru" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3" id="MucDichKhacContainer" style="display:none;">
                        <label asp-for="MucDichKhac" class="form-label required">Mô tả mục đích khác</label>
                        <input asp-for="MucDichKhac" id="MucDichKhac" class="form-control" placeholder="Nhập mục đích cụ thể..." />
                        <span asp-validation-for="MucDichKhac" class="text-danger small"></span>
                    </div>

                    <!-- Hàng 5: Số phòng / căn hộ -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="SoPhong" class="form-label">Số phòng / căn hộ</label>
                        <input asp-for="SoPhong" id="SoPhong" class="form-control" placeholder="Ví dụ: P.202, A-10..." />
                        <span asp-validation-for="SoPhong" class="text-danger small"></span>
                    </div>

                    <!-- Hàng 6: Ghi chú -->
                    <div class="col-md-12 mb-3">
                        <label asp-for="GhiChu" class="form-label">Ghi chú</label>
                        <textarea asp-for="GhiChu" class="form-control" rows="2" placeholder="Ghi chú thêm (nếu có)..."></textarea>
                        <span asp-validation-for="GhiChu" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Xác nhận cam kết -->
                <div class="warning-note mt-4">
                    <div class="d-flex align-items-center mb-1 fw-bold">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Vui lòng kiểm tra thông tin trước khi gửi.
                    </div>
                    Khai báo không đúng sự thật hoặc cố tình trốn tránh nghĩa vụ khai báo tạm trú có thể bị xử lý vi phạm hành chính hoặc trục xuất theo quy định của pháp luật Việt Nam.
                </div>

                <div class="form-check mt-3 d-flex align-items-center gap-2">
                    <input asp-for="CamKetThongTin" class="form-check-input" type="checkbox" id="CommitCheckbox" style="cursor:pointer; width: 18px; height: 18px;" />
                    <label class="form-check-label text-dark" for="CommitCheckbox" style="cursor:pointer; font-weight: 600;">
                        Tôi cam kết thông tin khai báo là đúng sự thật.
                    </label>
                </div>
                <span asp-validation-for="CamKetThongTin" class="text-danger small d-block mt-1"></span>

                <!-- Nút gửi -->
                <div class="form-actions mt-4">
                    <a asp-action="Dashboard" class="btn btn-outline-secondary px-4" style="border-radius: 6px; font-size: 0.85rem; font-weight: 500;">
                        Hủy
                    </a>
                    <button type="submit" id="SubmitDeclarationBtn" class="btn btn-primary-blue px-4" disabled>
                        <i class="bi bi-send-fill me-1"></i>Nộp tờ khai
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/khai-bao-tam-tru.js" asp-append-version="true"></script>
}
