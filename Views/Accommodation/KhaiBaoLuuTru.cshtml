@model ManagementOfForeigners.Models.ViewModels.Accommodation.LuuTruViewModel
@{
    ViewBag.Title = "Khai báo lưu trú cho người nước ngoài";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                <div class="card-header bg-dark text-white p-4">
                    <h5 class="fw-bold mb-0">Tờ khai báo lưu trú cho người nước ngoài tại cơ sở</h5>
                    <p class="text-white-50 mb-0 fs-7">Chủ cơ sở điền đầy đủ thông tin lưu trú thực tế của khách hàng</p>
                </div>

                <form asp-action="KhaiBaoLuuTru" method="post">
                    @Html.AntiForgeryToken()
                    <div class="card-body p-4">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="MaNguoiNuocNgoai" class="form-label fw-semibold text-dark fs-7"></label>
                            <select asp-for="MaNguoiNuocNgoai" asp-items="ViewBag.NguoiNuocNgoais" class="form-select select2" style="border-radius: 8px;" required>
                                <option value="">-- Chọn khách hàng người nước ngoài --</option>
                            </select>
                            <span asp-validation-for="MaNguoiNuocNgoai" class="text-danger fs-8"></span>
                            <div class="form-text fs-8 text-muted"><i class="bi bi-info-circle"></i> Khách hàng phải có tài khoản đăng ký trên hệ thống để chọn.</div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="Phong" class="form-label fw-semibold text-dark fs-7"></label>
                                <input asp-for="Phong" class="form-control" placeholder="Ví dụ: 302, VIP-1..." style="border-radius: 8px;" />
                                <span asp-validation-for="Phong" class="text-danger fs-8"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NgayBatDau" class="form-label fw-semibold text-dark fs-7"></label>
                                <input asp-for="NgayBatDau" class="form-control" type="date" style="border-radius: 8px;" />
                                <span asp-validation-for="NgayBatDau" class="text-danger fs-8"></span>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-12">
                                <label asp-for="NgayKetThuc" class="form-label fw-semibold text-dark fs-7"></label>
                                <input asp-for="NgayKetThuc" class="form-control" type="date" style="border-radius: 8px;" />
                                <span asp-validation-for="NgayKetThuc" class="text-danger fs-8"></span>
                                <div class="form-text fs-8 text-muted">Có thể để trống nếu khách hàng chưa có lịch rời đi dự kiến xác định.</div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="GhiChu" class="form-label fw-semibold text-dark fs-7"></label>
                                <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Ghi chú thêm về điều kiện lưu trú..." style="border-radius: 8px;"></textarea>
                                <span asp-validation-for="GhiChu" class="text-danger fs-8"></span>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 p-4 d-flex justify-content-between">
                        <a asp-action="Dashboard" class="btn btn-outline-secondary px-4" style="border-radius: 8px;">Hủy</a>
                        <button type="submit" class="btn btn-dark px-4" style="border-radius: 8px;">Khai báo ngay</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
