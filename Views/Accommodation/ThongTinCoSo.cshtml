@model ManagementOfForeigners.Models.Entities.CoSoLuuTru
@{
    ViewBag.Title = "Thông tin cơ sở lưu trú";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
                <!-- Header with premium gradient background -->
                <div class="card-header bg-dark text-white p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0">Thông tin cơ sở lưu trú</h5>
                        <p class="text-white-50 mb-0 fs-7">Chi tiết hồ sơ đăng ký kinh doanh và liên hệ của cơ sở</p>
                    </div>
                    <a asp-action="CapNhatCoSo" class="btn btn-light btn-sm fw-bold px-3 py-2" style="border-radius: 8px;">
                        <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
                    </a>
                </div>

                <div class="card-body p-4">
                    <!-- Alerts -->
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px;">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="row g-4">
                        <div class="col-md-12 text-center pb-3 border-bottom">
                            <div class="d-inline-flex align-items-center justify-content-center bg-light text-dark rounded-circle mb-3" style="width: 80px; height: 80px; font-size: 2.5rem;">
                                <i class="bi bi-building"></i>
                            </div>
                            <h4 class="fw-bold text-dark mb-1">@Model.TenCoSo</h4>
                            <div class="d-flex justify-content-center align-items-center gap-2 mt-2">
                                <span class="badge bg-secondary px-3 py-2 fs-8" style="border-radius: 20px;">Mã số: @Model.MaCoSoLuuTru</span>
                                <span class="badge bg-success px-3 py-2 fs-8" style="border-radius: 20px;">@Model.TrangThai</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <div class="text-muted fs-8 mb-1"><i class="bi bi-person-badge me-1"></i> Tên đăng nhập liên kết</div>
                                <div class="fw-bold text-dark fs-6">@Model.TaiKhoan.TenDangNhap</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <div class="text-muted fs-8 mb-1"><i class="bi bi-envelope me-1"></i> Email liên hệ</div>
                                <div class="fw-bold text-dark fs-6">@Model.Email</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <div class="text-muted fs-8 mb-1"><i class="bi bi-telephone me-1"></i> Số điện thoại</div>
                                <div class="fw-bold text-dark fs-6">@Model.SoDienThoai</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <div class="text-muted fs-8 mb-1"><i class="bi bi-geo-alt me-1"></i> Địa bàn quản lý</div>
                                <div class="fw-bold text-dark fs-6">TP. Đà Nẵng</div>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="p-3 bg-light rounded-3">
                                <div class="text-muted fs-8 mb-1"><i class="bi bi-map me-1"></i> Địa chỉ cơ sở</div>
                                <div class="fw-bold text-dark fs-6">@Model.DiaChi</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
