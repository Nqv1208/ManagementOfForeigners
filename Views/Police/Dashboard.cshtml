@model ManagementOfForeigners.Models.ViewModels.Police.DashboardViewModel
@{
    Layout = "~/Views/Shared/_PoliceLayout.cshtml";
    ViewBag.Title = "Bảng điều khiển - Công an Phường/Xã";
}

<div class="container-fluid">
    <!-- Header banner -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white border-0 shadow-sm overflow-hidden" style="border-radius: 20px;">
                <div class="p-5 d-flex align-items-center justify-content-between flex-wrap gap-4">
                    <div>
                        <span class="badge bg-success px-3 py-2 mb-2" style="border-radius: 30px;">Công an Phường/Xã phụ trách</span>
                        <h2 class="fw-bold mb-1">Địa bàn: @Model.TenDiaBan, Đà Nẵng</h2>
                        <p class="text-white-50 mb-0">Quản lý tạm trú, phê duyệt khai báo, gửi cảnh báo & báo cáo vi phạm người nước ngoài trên địa bàn</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="DanhSachKhaiBao" class="btn btn-success fw-semibold px-4 py-2" style="border-radius: 10px;">
                            <i class="bi bi-patch-check me-1"></i> Duyệt khai báo
                        </a>
                        <a asp-action="TraCuu" class="btn btn-outline-light fw-semibold px-4 py-2" style="border-radius: 10px;">
                            <i class="bi bi-search me-1"></i> Tra cứu địa bàn
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Analytics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm text-white bg-warning h-100" style="border-radius: 16px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-dark-50 fw-semibold mb-1 fs-7 text-dark">Chờ duyệt tạm trú</h6>
                        <h2 class="fw-bold mb-0 text-dark">@Model.TotalPending</h2>
                    </div>
                    <div class="bg-white bg-opacity-20 text-dark rounded-circle p-3 fs-3 d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-clock-history"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm text-white bg-success h-100" style="border-radius: 16px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 fw-semibold mb-1 fs-7">Đã duyệt tạm trú</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalApproved</h2>
                    </div>
                    <div class="bg-white bg-opacity-10 text-white rounded-circle p-3 fs-3 d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm text-white bg-primary h-100" style="border-radius: 16px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 fw-semibold mb-1 fs-7">NNN trong địa bàn</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalForeigners</h2>
                    </div>
                    <div class="bg-white bg-opacity-10 text-white rounded-circle p-3 fs-3 d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm text-white bg-dark h-100" style="border-radius: 16px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 fw-semibold mb-1 fs-7">Cảnh báo đã gửi</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalWarnings</h2>
                    </div>
                    <div class="bg-white bg-opacity-10 text-white rounded-circle p-3 fs-3 d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Pending Declarations -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark">Hồ sơ khai báo tạm trú chờ duyệt</h5>
                    <a asp-action="DanhSachKhaiBao" class="text-decoration-none fs-8 fw-semibold text-success">Xem tất cả <i class="bi bi-chevron-right fs-9"></i></a>
                </div>
                <div class="card-body p-4">
                    @if (!Model.RecentPending.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-shield-check text-success animate-pulse" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3 mb-0">Tuyệt vời! Không có hồ sơ nào đang chờ duyệt.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 fs-8">
                                <thead>
                                    <tr class="table-light">
                                        <th>Họ tên khách</th>
                                        <th>Hộ chiếu</th>
                                        <th>Địa chỉ lưu trú</th>
                                        <th>Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dec in Model.RecentPending)
                                    {
                                        <tr>
                                            <td class="fw-bold text-dark">@dec.TaiKhoan.NguoiNuocNgoai?.HoTen</td>
                                            <td>@dec.TaiKhoan.NguoiNuocNgoai?.SoHoChieu</td>
                                            <td><small class="text-muted style-multiline-ellipsis">@dec.DiaChiLuuTru</small></td>
                                            <td>
                                                <div class="d-inline-flex gap-2">
                                                    <a asp-action="ChiTietKhaiBao" asp-route-id="@dec.MaHSKhaiBao" class="btn btn-dark btn-xs" style="border-radius: 5px;">
                                                        <i class="bi bi-eye"></i> Xem / Duyệt
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Warnings -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark">Cảnh báo vi phạm đã gửi</h5>
                </div>
                <div class="card-body p-4">
                    @if (!Model.RecentWarnings.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-envelope text-muted" style="font-size: 2.5rem;"></i>
                            <p class="text-muted mt-2 mb-0">Bạn chưa gửi cảnh báo vi phạm nào.</p>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var warn in Model.RecentWarnings)
                            {
                                <div class="p-3 bg-light rounded-3">
                                    <div class="d-flex justify-content-between flex-wrap gap-2 mb-1">
                                        <span class="fw-bold text-dark fs-7">@warn.NguoiNuocNgoai.HoTen</span>
                                        <small class="text-muted fs-8">@warn.NgayCanhBao.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <div class="text-muted fs-8 mb-2">Loại: <span class="text-dark fw-semibold">@warn.LoaiViPham</span> | Mức độ: <span class="badge bg-danger">@warn.MucDoViPham</span></div>
                                    <p class="mb-0 text-secondary fs-8 style-multiline-ellipsis">@warn.NoiDungCanhBao</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
