@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.NguoiNuocNgoai>
@{
    Layout = "~/Views/Shared/_PoliceLayout.cshtml";
    ViewBag.Title = "Tra cứu địa bàn - Công an";
}

<div class="container-fluid">
    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-header bg-success text-white p-4" style="background-color: var(--police-primary) !important;">
            <h5 class="fw-bold mb-0">Tra cứu người nước ngoài tại @ViewBag.TenDiaBan</h5>
            <p class="text-white-50 mb-0 fs-7">Danh sách người nước ngoài đang sinh sống và cư trú thực tế trong địa bàn phụ trách của Công an phường</p>
        </div>

        <div class="card-body p-4">
            <!-- Search Form -->
            <form asp-action="TraCuu" method="get" class="row g-3 mb-4">
                <div class="col-md-9">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" value="@ViewBag.Search" placeholder="Tìm theo họ tên, số hộ chiếu, địa chỉ tạm trú..." style="border-radius: 0 8px 8px 0;" />
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-dark w-100 fw-semibold" style="border-radius: 8px;">Tìm kiếm</button>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">Không tìm thấy người nước ngoài nào đang cư trú tại địa bàn @ViewBag.TenDiaBan.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 fs-7">
                        <thead>
                            <tr class="table-dark">
                                <th>Mã NNN</th>
                                <th>Họ và tên</th>
                                <th>Số hộ chiếu</th>
                                <th>Quốc tịch</th>
                                <th>Loại Visa</th>
                                <th>Nơi cư trú địa bàn</th>
                                <th class="text-center">Thao tác nhanh</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var foreigner in Model)
                            {
                                <tr>
                                    <td><code class="text-secondary fw-semibold">@foreigner.MaNguoiNuocNgoai</code></td>
                                    <td class="fw-bold text-dark">@foreigner.HoTen</td>
                                    <td>@foreigner.SoHoChieu</td>
                                    <td>@foreigner.QuocTich</td>
                                    <td><span class="badge bg-primary">@foreigner.LoaiVisa</span></td>
                                    <td><small class="text-muted">@foreigner.NoiCuTruHienTai</small></td>
                                    <td class="text-center">
                                        <div class="d-inline-flex gap-2">
                                            <a asp-action="CanhBaoViPham" asp-route-maNguoiNuocNgoai="@foreigner.MaNguoiNuocNgoai" class="btn btn-warning btn-xs text-dark" style="border-radius: 6px;">
                                                <i class="bi bi-exclamation-triangle"></i> Cảnh báo
                                            </a>
                                            <a asp-action="BaoCaoViPham" asp-route-maNguoiNuocNgoai="@foreigner.MaNguoiNuocNgoai" class="btn btn-danger btn-xs" style="border-radius: 6px;">
                                                <i class="bi bi-flag"></i> Báo cáo XNC
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-4">
                    @Html.PagedListPager(Model, page => Url.Action("TraCuu", new { page, search = ViewBag.Search }),
                        new X.PagedList.Mvc.Core.PagedListRenderOptions {
                            LiElementClasses = new string[] { "page-item" },
                            PageClasses = new string[] { "page-link" },
                            UlElementClasses = new string[] { "pagination", "pagination-sm" }
                        })
                </div>
            }
        </div>
    </div>
</div>
