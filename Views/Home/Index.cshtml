@{
    Layout = "~/Views/Shared/_LandingLayout.cshtml";
    ViewData["Title"] = "Cổng khai báo tạm trú & lưu trú Người nước ngoài Đà Nẵng";
}

<!-- 1. HERO SECTION CHÍNH THỨC -->
<section class="portal-hero">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7 text-start">
                <div class="d-inline-flex align-items-center gap-2 bg-warning bg-opacity-20 text-warning border border-warning border-opacity-30 rounded-pill px-3 py-1 mb-3">
                    <span class="badge bg-warning rounded-circle p-1" style="width: 8px; height: 8px; display: inline-block;"></span>
                    <span class="fs-8 fw-bold text-uppercase text-white font-monospace">Hệ thống Dịch vụ công trực tuyến</span>
                </div>
                <h1 class="portal-hero-title mb-3">
                    Khai báo <span>Tạm trú & Lưu trú</span><br>Người nước ngoài trực tuyến
                </h1>
                <p class="lead text-white-50 mb-4 fs-6" style="max-width: 600px; text-shadow: 1px 1px 2px rgba(0,0,0,0.6);">
                    Chào mừng Quý khách và đại diện cơ sở lưu trú đến với Cổng thông tin khai báo cư trú điện tử của Công an Thành phố Đà Nẵng. Thực hiện thủ tục hành chính trực tuyến nhanh chóng, bảo mật và đúng pháp luật.
                </p>
                
                @if (User.Identity == null || !User.Identity.IsAuthenticated)
                {
                    <div class="d-flex flex-wrap gap-3">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-gov-accent btn-lg shadow" id="btn-hero-login">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập hệ thống
                        </a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg px-4" id="btn-hero-register" style="border-width: 2px;">
                            <i class="bi bi-person-plus me-2"></i>Đăng ký tài khoản mới
                        </a>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-3">
                        @{
                            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                            var dashboardUrl = "/";
                            if (role == "NguoiNuocNgoai") dashboardUrl = "/Foreigner/Dashboard";
                            else if (role == "ChuLuuTru") dashboardUrl = "/Accommodation/Dashboard";
                            else if (role == "CanBoXNC") dashboardUrl = "/Officer/Dashboard";
                            else if (role == "CongAn") dashboardUrl = "/Police/Dashboard";
                            else if (role == "Admin") dashboardUrl = "/Admin/Dashboard";
                        }
                        <a href="@dashboardUrl" class="btn btn-warning btn-lg px-4 fw-bold shadow">
                            <i class="bi bi-speedometer2 me-2"></i>Truy cập Trang điều hành quản trị
                        </a>
                    </div>
                }
            </div>
            
            <div class="col-lg-5 d-none d-lg-block">
                <!-- Administrative Status Overlay -->
                <div class="card bg-dark bg-opacity-70 border-0 shadow-lg p-4" style="border-radius: 12px; backdrop-filter: blur(8px); border-left: 5px solid var(--portal-gold);">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="bg-warning text-dark rounded-circle p-2 fs-5 d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0 text-white text-uppercase">Bảo mật & Pháp lý cao</h6>
                            <small class="text-white-50">Hệ thống vận hành theo quy định của Bộ Công an</small>
                        </div>
                    </div>
                    
                    <div class="d-flex flex-column gap-3 text-white-50 small">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-check-square-fill text-warning mt-1"></i>
                            <span>Khai báo tạm trú trực tiếp từ máy tính/điện thoại di động chỉ mất 3 phút.</span>
                        </div>
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-check-square-fill text-warning mt-1"></i>
                            <span>Chủ động cập nhật tình hình lưu trú của người nước ngoài tại khách sạn, nhà nghỉ.</span>
                        </div>
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-check-square-fill text-warning mt-1"></i>
                            <span>Công an Phường/Xã trực tiếp rà soát và phê duyệt hồ sơ điện tử nhanh chóng.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 2. DỊCH VỤ CÔNG TRỰC TUYẾN CHÍNH (BENTO LAYOUT) -->
<section class="py-5" id="dich-vu">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title-admin center" id="heading-dich-vu">Dịch Vụ Công Trực Tuyến Nổi Bật</h2>
            <p class="text-muted" style="max-width: 650px; margin: 0 auto;">Các dịch vụ công phục vụ cư dân nước ngoài cư trú và các doanh nghiệp, cơ sở lưu trú hoạt động kinh doanh trên địa bàn Thành phố Đà Nẵng.</p>
        </div>

        <div class="row g-4">
            <!-- Dịch vụ 1 -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card-admin" id="service-foreigner">
                    <div class="service-icon-admin">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-3">Người nước ngoài tự khai báo</h5>
                    <p class="text-muted small mb-4" style="min-height: 72px;">
                        Người nước ngoài trực tiếp thực hiện khai báo tạm trú trực tuyến khi đến cư trú ngoài các cơ sở lưu trú kinh doanh (thuê nhà riêng, ở nhờ người thân).
                    </p>
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold small text-primary">Đăng ký tài khoản <i class="bi bi-arrow-right"></i></a>
                        <span class="badge bg-light text-primary border px-2 py-1 fs-8">Mức độ 4</span>
                    </div>
                </div>
            </div>

            <!-- Dịch vụ 2 -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card-admin" id="service-accommodation">
                    <div class="service-icon-admin">
                        <i class="bi bi-building-fill-add"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-3">Chủ cơ sở khai báo lưu trú</h5>
                    <p class="text-muted small mb-4" style="min-height: 72px;">
                        Dành cho Khách sạn, Nhà nghỉ, Homestay, Ký túc xá đăng ký thông tin cơ sở và trực tiếp khai báo danh sách người nước ngoài đang lưu trú theo ngày.
                    </p>
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold small text-primary">Khai báo ngay <i class="bi bi-arrow-right"></i></a>
                        <span class="badge bg-light text-success border px-2 py-1 fs-8">Mức độ 4</span>
                    </div>
                </div>
            </div>

            <!-- Dịch vụ 3 -->
            <div class="col-md-6 col-lg-4">
                <div class="service-card-admin" id="service-guide">
                    <div class="service-icon-admin">
                        <i class="bi bi-journal-text"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-3">Hướng dẫn thủ tục hành chính</h5>
                    <p class="text-muted small mb-4" style="min-height: 72px;">
                        Tra cứu các bước chi tiết, chuẩn bị hồ sơ cần thiết và cách thức thực hiện thủ tục đăng ký tạm trú, cập nhật hộ chiếu, visa theo đúng quy định.
                    </p>
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="#quy-trinh" class="text-decoration-none fw-bold small text-primary">Xem hướng dẫn <i class="bi bi-arrow-right"></i></a>
                        <span class="badge bg-light text-secondary border px-2 py-1 fs-8">Miễn phí</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 3. QUY TRÌNH HÀNH CHÍNH 3 BƯỚC -->
<section class="py-5 bg-white border-top border-bottom" id="quy-trinh">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title-admin center" id="heading-quy-trinh">Quy Trình Khai Báo Cư Trú Trực Tuyến</h2>
            <p class="text-muted" style="max-width: 650px; margin: 0 auto;">Cơ quan Công an hướng dẫn các bước chi tiết giúp người dân và người nước ngoài hoàn thành nghĩa vụ cư trú đúng luật định.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="text-center p-3">
                    <div class="bg-light text-primary rounded-circle shadow-sm mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; border: 2px solid var(--portal-primary-light);">
                        <span class="fs-3 fw-bold">01</span>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Đăng ký & Kích hoạt</h5>
                    <p class="text-muted small">
                        Khai báo thông tin định danh ban đầu (Người nước ngoài nhập số hộ chiếu/visa; Chủ cơ sở nhập thông tin giấy phép kinh doanh) và tạo tài khoản trực tuyến.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="text-center p-3">
                    <div class="bg-light text-success rounded-circle shadow-sm mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; border: 2px solid #198754;">
                        <span class="fs-3 fw-bold">02</span>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Khai báo hồ sơ cư trú</h5>
                    <p class="text-muted small">
                        Đăng nhập hệ thống, điền thông tin địa chỉ cư trú cụ thể tại Đà Nẵng, thời hạn tạm trú dự kiến, mục đích lưu trú và gửi hồ sơ trực tuyến đi.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="text-center p-3">
                    <div class="bg-light text-warning rounded-circle shadow-sm mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; border: 2px solid #ffc107;">
                        <span class="fs-3 fw-bold">03</span>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Công an Phê duyệt</h5>
                    <p class="text-muted small">
                        Công an phường phụ trách địa bàn kiểm tra thông tin đối khớp. Hồ sơ hợp lệ sẽ được phê duyệt tức thì và cập nhật vào kho dữ liệu cư trú quốc gia.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 4. QUY ĐỊNH PHÁP LUẬT & TIN TỨC CHÍNH THỨC -->
<section class="py-5" id="phap-luat">
    <div class="container">
        <div class="row g-5">
            <!-- Quy định & Pháp luật -->
            <div class="col-lg-7">
                <h3 class="section-title-admin" id="heading-phap-luat"><i class="bi bi-book-half text-danger me-2"></i>Quy Định & Pháp Luật Liên Quan</h3>
                <p class="text-muted small mb-4">Các điều khoản chính thuộc Luật Nhập cảnh, xuất cảnh, quá cảnh, cư trú của người nước ngoài tại Việt Nam mà người cư trú và cơ sở cần nắm rõ:</p>

                <div class="accordion accordion-flush shadow-sm rounded-3 border overflow-hidden bg-white" id="accordionRegulations">
                    <!-- Điều 1 -->
                    <div class="accordion-item border-bottom">
                        <h2 class="accordion-header" id="headingOne">
                            <button class="accordion-button collapsed fw-bold text-dark fs-7" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="false" aria-controls="collapseOne">
                                1. Thời hạn bắt buộc khai báo tạm trú cho Người nước ngoài?
                            </button>
                        </h2>
                        <div id="collapseOne" class="accordion-collapse collapse" aria-labelledby="headingOne" data-bs-parent="#accordionRegulations">
                            <div class="accordion-body text-muted small">
                                Trong thời hạn 12 giờ (đối với địa bàn vùng sâu, vùng xa là 24 giờ) kể từ khi người nước ngoài đến tạm trú, người trực tiếp quản lý, điều hành hoạt động của cơ sở lưu trú phải hoàn thành việc khai báo tạm trú với Công an xã, phường, thị trấn nơi có cơ sở lưu trú.
                            </div>
                        </div>
                    </div>

                    <!-- Điều 2 -->
                    <div class="accordion-item border-bottom">
                        <h2 class="accordion-header" id="headingTwo">
                            <button class="accordion-button collapsed fw-bold text-dark fs-7" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                                2. Mức phạt hành vi không khai báo tạm trú cho khách nước ngoài?
                            </button>
                        </h2>
                        <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#accordionRegulations">
                            <div class="accordion-body text-muted small">
                                Theo Nghị định xử phạt hành chính trong lĩnh vực an ninh trật tự, chủ cơ sở cho người nước ngoài tạm trú qua đêm mà không khai báo tạm trú bị xử phạt từ 2,000,000đ đến 4,000,000đ đối với cá nhân, từ 4,000,000đ đến 8,000,000đ đối với tổ chức vi phạm.
                            </div>
                        </div>
                    </div>

                    <!-- Điều 3 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingThree">
                            <button class="accordion-button collapsed fw-bold text-dark fs-7" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                                3. Người nước ngoài có được tự ý thay đổi nơi cư trú?
                            </button>
                        </h2>
                        <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#accordionRegulations">
                            <div class="accordion-body text-muted small">
                                Người nước ngoài có quyền tự do đi lại và cư trú theo quy định, tuy nhiên khi thay đổi nơi cư trú (sang phường khác, thành phố khác) bắt buộc phải thực hiện thủ tục khai báo tạm trú mới tại địa chỉ cư trú mới trong thời hạn quy định để đảm bảo việc quản lý an ninh, trật tự xã hội.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tin tức - Thông báo khẩn -->
            <div class="col-lg-5">
                <h3 class="section-title-admin" id="heading-tin-tuc"><i class="bi bi-megaphone-fill text-warning me-2"></i>Tin Tức & Thông Báo Mới</h3>
                <div class="card border-0 shadow-sm bg-white p-4 h-100" style="border-radius: 8px;">
                    <div class="news-item-mini">
                        <span class="news-date">20/05/2026 - Cục QLXNC</span>
                        <a href="#" class="news-title">Triển khai Đề án 06 về đơn giản hoá thủ tục khai báo tạm trú trực tuyến cho người nước ngoài tại Đà Nẵng</a>
                    </div>

                    <div class="news-item-mini">
                        <span class="news-date">15/05/2026 - Công an Thành phố</span>
                        <a href="#" class="news-title">Tăng cường kiểm tra, rà soát và xử lý các cơ sở lưu trú homestay không đăng ký kinh doanh và khai báo cho khách ngoại quốc</a>
                    </div>

                    <div class="news-item-mini">
                        <span class="news-date">10/05/2026 - Phòng QLXNC</span>
                        <a href="#" class="news-title">Quy định mới về cấp thị thực (visa) điện tử kéo dài thời hạn cư trú lên tới 90 ngày tại các cửa khẩu quốc tế Việt Nam</a>
                    </div>

                    <div class="mt-4 pt-3 border-top text-end">
                        <a href="#" class="text-decoration-none fw-bold small text-danger"><i class="bi bi-list me-1"></i> Xem toàn bộ thông báo</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 5. SỐ LIỆU THỐNG KÊ CÔNG KHAI -->
<section class="py-5 bg-white border-top border-bottom" id="thong-ke">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title-admin center" id="heading-thong-ke">Số Liệu Thống Kê Công Khai</h2>
            <p class="text-muted" style="max-width: 650px; margin: 0 auto;">Thống kê tổng lượng khách nước ngoài cư trú và mức độ hoàn thành hồ sơ dịch vụ công hành chính trực tuyến tại TP. Đà Nẵng.</p>
        </div>

        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="stat-box" id="stat-total-guests">
                    <div class="stat-number">45,280+</div>
                    <div class="stat-label">Lượt khách nước ngoài</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-box" id="stat-active-residences">
                    <div class="stat-number">1,250+</div>
                    <div class="stat-label">Cơ sở lưu trú đã đăng ký</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-box" id="stat-approved-profiles">
                    <div class="stat-number">98.5%</div>
                    <div class="stat-label">Hồ sơ duyệt đúng hạn</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-box" id="stat-online-declarations">
                    <div class="stat-number">120,400+</div>
                    <div class="stat-label">Lượt khai báo trực tuyến</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 6. HOTLINE & LIÊN HỆ PHÒNG NGỪA RỦI RO -->
<section class="py-5" id="lien-he">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-8">
                <div class="portal-hotline-card" id="hotline-block">
                    <h4 class="fw-bold text-danger mb-3"><i class="bi bi-telephone-outbound-fill me-2"></i>Đường Dây Nóng Phản Ánh & Hỗ Trợ 24/7</h4>
                    <p class="text-dark small mb-4">
                        Nếu quý khách gặp khó khăn về mặt kỹ thuật khi sử dụng hệ thống dịch vụ công hoặc cần phản ánh, khai báo các trường hợp vi phạm quy định cư trú của người nước ngoài trên địa bàn, xin vui lòng gọi ngay đường dây nóng:
                    </p>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-danger text-white rounded-circle p-2 fs-5 d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                                    <i class="bi bi-telephone-fill"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block text-uppercase fw-semibold" style="font-size: 0.7rem;">Phòng QLXNC Đà Nẵng</small>
                                    <span class="fw-bold fs-5 text-danger">0236.3822.464</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-danger text-white rounded-circle p-2 fs-5 d-inline-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                                    <i class="bi bi-headset"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block text-uppercase fw-semibold" style="font-size: 0.7rem;">Tổng đài hỗ trợ kỹ thuật</small>
                                    <span class="fw-bold fs-5 text-dark">0236.1022</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
