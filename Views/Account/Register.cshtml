@model RegisterViewModel

@{
    ViewBag.Title = "Đăng ký tài khoản";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="card auth-card" style="max-width: 720px;">
            <div class="card-header">
                <h4>📝 Đăng ký tài khoản</h4>
                <p class="mb-0 small opacity-75">Hệ thống Quản lý Người nước ngoài TP Đà Nẵng</p>
            </div>
            <div class="card-body">
                <form asp-action="Register" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <!-- ===== Thông tin tài khoản ===== -->
                    <div class="register-section">
                        <h5>Thông tin tài khoản</h5>

                        <div class="mb-3">
                            <label asp-for="TenDangNhap" class="form-label"></label>
                            <input asp-for="TenDangNhap" class="form-control" placeholder="Từ 3 đến 50 ký tự" />
                            <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MatKhau" class="form-label"></label>
                                <input asp-for="MatKhau" class="form-control" placeholder="Ít nhất 6 ký tự" />
                                <span asp-validation-for="MatKhau" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="XacNhanMatKhau" class="form-label"></label>
                                <input asp-for="XacNhanMatKhau" class="form-control" placeholder="Nhập lại mật khẩu" />
                                <span asp-validation-for="XacNhanMatKhau" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="example@email.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoDienThoai" class="form-label"></label>
                                <input asp-for="SoDienThoai" class="form-control" placeholder="Không bắt buộc" />
                                <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="VaiTro" class="form-label"></label>
                            <select asp-for="VaiTro" class="form-select" id="vaiTroSelect">
                                <option value="">-- Chọn loại tài khoản --</option>
                                <option value="NguoiNuocNgoai">Người nước ngoài</option>
                                <option value="ChuLuuTru">Chủ cơ sở lưu trú</option>
                            </select>
                            <span asp-validation-for="VaiTro" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- ===== Thông tin người nước ngoài ===== -->
                    <div class="register-section d-none" id="sectionNguoiNuocNgoai">
                        <h5>Thông tin người nước ngoài</h5>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="HoTen" class="form-label"></label>
                                <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên đầy đủ" />
                                <span asp-validation-for="HoTen" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="GioiTinh" class="form-label"></label>
                                <select asp-for="GioiTinh" class="form-select">
                                    <option value="">-- Chọn --</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span asp-validation-for="GioiTinh" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NgaySinh" class="form-label"></label>
                                <input asp-for="NgaySinh" class="form-control" type="date" />
                                <span asp-validation-for="NgaySinh" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="QuocTich" class="form-label"></label>
                                <input asp-for="QuocTich" class="form-control" placeholder="Ví dụ: Hàn Quốc, Nhật Bản..." />
                                <span asp-validation-for="QuocTich" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="SoHoChieu" class="form-label"></label>
                                <input asp-for="SoHoChieu" class="form-control" placeholder="Nhập số hộ chiếu" />
                                <span asp-validation-for="SoHoChieu" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="NgayCapHoChieu" class="form-label"></label>
                                <input asp-for="NgayCapHoChieu" class="form-control" type="date" />
                                <span asp-validation-for="NgayCapHoChieu" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="NgayHetHanHoChieu" class="form-label"></label>
                                <input asp-for="NgayHetHanHoChieu" class="form-control" type="date" />
                                <span asp-validation-for="NgayHetHanHoChieu" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="LoaiVisa" class="form-label"></label>
                                <select asp-for="LoaiVisa" class="form-select">
                                    <option value="">-- Chọn loại visa --</option>
                                    <option value="Du lịch">Du lịch</option>
                                    <option value="Thương mại">Thương mại</option>
                                    <option value="Lao động">Lao động</option>
                                    <option value="Học tập">Học tập</option>
                                    <option value="Thăm thân">Thăm thân</option>
                                    <option value="Ngoại giao">Ngoại giao</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span asp-validation-for="LoaiVisa" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NgayHetHanVisa" class="form-label"></label>
                                <input asp-for="NgayHetHanVisa" class="form-control" type="date" />
                                <span asp-validation-for="NgayHetHanVisa" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- ===== Thông tin cơ sở lưu trú ===== -->
                    <div class="register-section d-none" id="sectionChuLuuTru">
                        <h5>Thông tin cơ sở lưu trú</h5>

                        <div class="mb-3">
                            <label asp-for="TenCoSo" class="form-label"></label>
                            <input asp-for="TenCoSo" class="form-control" placeholder="Tên khách sạn, nhà trọ, homestay..." />
                            <span asp-validation-for="TenCoSo" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChiCoSo" class="form-label"></label>
                            <input asp-for="DiaChiCoSo" class="form-control" placeholder="Địa chỉ đầy đủ của cơ sở" />
                            <span asp-validation-for="DiaChiCoSo" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoDienThoaiCoSo" class="form-label"></label>
                                <input asp-for="SoDienThoaiCoSo" class="form-control" placeholder="Số điện thoại liên hệ" />
                                <span asp-validation-for="SoDienThoaiCoSo" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EmailCoSo" class="form-label"></label>
                                <input asp-for="EmailCoSo" class="form-control" type="email" placeholder="Email cơ sở" />
                                <span asp-validation-for="EmailCoSo" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg">Đăng ký</button>
                    </div>

                    <div class="text-center">
                        <p class="mb-0">
                            Đã có tài khoản?
                            <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-semibold">Đăng nhập</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        (function () {
            var vaiTroSelect = document.getElementById('vaiTroSelect');
            var sectionNNN = document.getElementById('sectionNguoiNuocNgoai');
            var sectionCLT = document.getElementById('sectionChuLuuTru');

            function toggleSections() {
                var val = vaiTroSelect.value;
                if (val === 'NguoiNuocNgoai') {
                    sectionNNN.classList.remove('d-none');
                    sectionCLT.classList.add('d-none');
                } else if (val === 'ChuLuuTru') {
                    sectionNNN.classList.add('d-none');
                    sectionCLT.classList.remove('d-none');
                } else {
                    sectionNNN.classList.add('d-none');
                    sectionCLT.classList.add('d-none');
                }
            }

            vaiTroSelect.addEventListener('change', toggleSections);

            // Trigger on page load in case of validation failure returning the form
            toggleSections();
        })();
    </script>
}
