@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var userName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
}

<header class="public-header">
    <!-- A. Top utility bar -->
    <div class="public-topbar">
        <div class="public-container public-topbar-inner">
            <div class="portal-title">
                <span class="flag-vn"></span>
                <span>CỔNG THÔNG TIN ĐIỆN TỬ CHÍNH THỨC NƯỚC CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</span>
            </div>
            <div class="portal-meta">
                <span id="portal-realtime"><i class="bi bi-clock me-1"></i>Đang tải thời gian...</span>
                <div class="d-flex gap-2 align-items-center">
                    <a href="#" id="lang-vi" class="fw-bold text-white">VI</a>
                    <span class="text-white-50">|</span>
                    <a href="#" id="lang-en" class="text-white-50">EN</a>
                </div>
            </div>
        </div>
    </div>

    <!-- B. Brand header -->
    <div class="public-brandbar">
        <div class="public-container public-brandbar-inner">
            <div class="brand-left">
                <div class="portal-logo-container">
                    <img class="portal-emblem" src="~/images/bo-cong-an-logo.png" alt="Logo Bộ Công an" style="object-fit: contain; padding: 4px;" />
                    <div class="portal-titles">
                        <span class="portal-title-gov">ỦY BAN NHÂN DÂN THÀNH PHỐ ĐÀ NẴNG</span>
                        <span class="portal-title-main">CÔNG AN THÀNH PHỐ ĐÀ NẴNG</span>
                        <span class="portal-title-sub">CỔNG KHAI BÁO TẠM TRÚ & LƯU TRÚ NGƯỜI NƯỚC NGOÀI</span>
                    </div>
                </div>
            </div>
            <div class="brand-right">
                <span class="version">Phiên bản: 2.1.0</span>
                <span id="portal-greeting" class="greeting">Đang tải thông tin hỗ trợ...</span>
            </div>
        </div>
    </div>

    <!-- C. Main navigation bar -->
    <nav class="navbar navbar-expand-lg navbar-dark public-navbar">
        <div class="public-container public-navbar-inner">
            <button class="navbar-toggler my-2 ms-auto" type="button" data-bs-toggle="collapse"
                    data-bs-target="#publicNavbar" aria-controls="publicNavbar"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="publicNavbar">
                <div class="public-nav-menu">
                    <a class="public-nav-link active" asp-controller="TrangChu" asp-action="Index"><i class="bi bi-house-door-fill me-1"></i> Trang chủ</a>
                    <a class="public-nav-link" href="#quy-trinh"><i class="bi bi-journal-check me-1"></i> Quy trình khai báo</a>
                    <a class="public-nav-link" href="#phap-luat"><i class="bi bi-card-checklist me-1"></i> Quy định pháp luật</a>
                    <a class="public-nav-link" href="#thong-ke"><i class="bi bi-bar-chart-line me-1"></i> Số liệu công khai</a>
                    <a class="public-nav-link" href="#lien-he"><i class="bi bi-telephone-inbound me-1"></i> Hotline hỗ trợ</a>
                </div>

                <div class="public-auth-actions">
                    @if (isAuthenticated)
                    {
                        <div class="user-greeting">
                            <span class="text-white-50">Xin chào,</span>
                            <span class="text-white fw-bold">@userName</span>
                            @{
                                var roleBadgeClass = userRole switch
                                {
                                    "NguoiNuocNgoai" => "bg-primary border border-primary",
                                    "ChuLuuTru" => "bg-success border border-success",
                                    "CanBoXNC" => "bg-warning text-dark border border-warning",
                                    "CongAn" => "bg-danger border border-danger",
                                    "Admin" => "bg-light text-dark border border-secondary",
                                    _ => "bg-secondary"
                                };
                                var roleDisplayName = userRole switch
                                {
                                    "NguoiNuocNgoai" => "Người nước ngoài",
                                    "ChuLuuTru" => "Chủ lưu trú",
                                    "CanBoXNC" => "Cán bộ XNC",
                                    "CongAn" => "Công an",
                                    "Admin" => "Quản trị",
                                    _ => userRole ?? ""
                                };
                                var dashboardUrl = userRole switch
                                {
                                    "NguoiNuocNgoai" => Url.Action("TongQuan", "NguoiNuocNgoai"),
                                    "ChuLuuTru" => Url.Action("TongQuan", "CoSoLuuTru"),
                                    "CanBoXNC" => Url.Action("TongQuan", "CanBo"),
                                    "CongAn" => Url.Action("TongQuan", "CongAn"),
                                    "Admin" => Url.Action("TongQuan", "QuanTri"),
                                    _ => "/"
                                };
                            }
                            <span class="badge @roleBadgeClass">@roleDisplayName</span>
                        </div>
                        <a href="@dashboardUrl" class="btn-auth btn-login"><i class="bi bi-speedometer2 me-1"></i> Trang quản trị</a>
                        <form asp-controller="TaiKhoan" asp-action="DangXuat" method="post" class="d-inline m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-auth btn-register">Đăng xuất</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn-auth btn-login" asp-controller="TaiKhoan" asp-action="DangNhap"><i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập</a>
                    }
                </div>
            </div>
        </div>
    </nav>
</header>
