<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị hệ thống QL Người nước ngoài</title>
    <!-- Thư viện CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
</head>
<body>
    @{
        var controllerName = ViewContext.RouteData.Values["Controller"]?.ToString();
        var actionName = ViewContext.RouteData.Values["Action"]?.ToString();
        var userName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Administrator";
    }

    <!-- 1. PORTAL TOPBAR QUỐC GIA -->
    <partial name="_PortalTopbar" />

    <!-- 2. ADMIN CONTAINER WRAPPER -->
    <div class="admin-wrapper">
        <!-- 2.1 SIDEBAR BÊN TRÁI -->
        <aside class="admin-sidebar">
            <div class="admin-sidebar-header">
                <img class="admin-sidebar-logo" src="~/images/bo-cong-an-logo.png" alt="Logo Phòng Quản lý Xuất nhập cảnh Công an TP Đà Nẵng" style="object-fit: contain; padding: 2px;" />
                <div class="admin-sidebar-title">
                    <h1>Phòng QL XNC</h1>
                    <span>Công an TP Đà Nẵng</span>
                </div>
            </div>

            <ul class="admin-sidebar-menu">
                <li class="admin-menu-item @(actionName == "TongQuan" ? "active" : "")">
                    <a asp-controller="QuanTri" asp-action="TongQuan"><i class="bi bi-grid-fill"></i> Tổng quan</a>
                </li>
                <li class="admin-menu-item @(actionName == "TaiKhoan" ? "active" : "")">
                    <a asp-controller="QuanTri" asp-action="TaiKhoan"><i class="bi bi-people-fill"></i> Quản lý tài khoản</a>
                </li>
                <li class="admin-menu-item @(actionName == "VaiTro" ? "active" : "")">
                    <a asp-controller="QuanTri" asp-action="VaiTro"><i class="bi bi-shield-lock-fill"></i> Vai trò</a>
                </li>
                <li class="admin-menu-item @(actionName == "PhanQuyen" ? "active" : "")">
                    <a asp-controller="QuanTri" asp-action="PhanQuyen"><i class="bi bi-key-fill"></i> Phân quyền</a>
                </li>
                <li class="admin-menu-item @(actionName == "DanhMucPhuongXa" ? "active" : "")">
                    <a asp-controller="QuanTri" asp-action="DanhMucPhuongXa"><i class="bi bi-map-fill"></i> Danh mục phường/xã</a>
                </li>
                <li class="admin-menu-item @(actionName == "NhatKyHeThong" ? "active" : "")">
                    <a asp-controller="QuanTri" asp-action="NhatKyHeThong"><i class="bi bi-journal-text"></i> Nhật ký hệ thống</a>
                </li>
            </ul>
        </aside>

        <!-- 2.2 NỘI DUNG CHÍNH & TOPBAR -->
        <div class="admin-main-container">
            <!-- TOPBAR TRONG -->
            <header class="admin-topbar shadow-sm">
                <div class="admin-topbar-left">
                    <button class="admin-sidebar-toggle" aria-label="Toggle Sidebar Menu">
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="fw-bold text-uppercase text-secondary small d-none d-md-inline-block">
                        Hệ thống quản lý người nước ngoài - Đà Nẵng
                    </span>
                </div>
                <div class="admin-topbar-right">
                    <div class="admin-user-info">
                        <span class="admin-user-name">@userName</span>
                        <span class="admin-user-role">Quản trị viên</span>
                    </div>
                    <form asp-controller="TaiKhoan" asp-action="DangXuat" method="post" class="d-inline m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-1 px-3">
                            <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            </header>

            <!-- KHU VỰC CHỨA NỘI DUNG VÀ WATERMARK -->
            <main class="admin-content" role="main">
                <!-- TempData Toast Alerts -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["SuccessMessage"]" data-type="success"></div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["ErrorMessage"]" data-type="danger"></div>
                }
                @if (TempData["WarningMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["WarningMessage"]" data-type="warning"></div>
                }
                @if (TempData["InfoMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["InfoMessage"]" data-type="info"></div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Thư viện Javascript -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-layout.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
