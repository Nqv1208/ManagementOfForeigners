<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cổng khai báo tạm trú Đà Nẵng</title>
    
    <!-- Thư viện CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="auth-layout-body">
    <!-- 1. Top portal bar -->
    <partial name="_PortalTopbar" />

    <!-- 2. Smaller government banner -->
    <header class="portal-header-banner py-2">
        <div class="container d-flex align-items-center justify-content-between">
            <div class="portal-logo-container d-flex align-items-center gap-2">
                <img class="portal-emblem" src="~/images/bo-cong-an-logo.png" alt="Logo Bộ Công an" style="height: 48px; width: 48px; object-fit: contain; padding: 2px;" />
                <div class="portal-titles">
                    <span class="portal-title-gov" style="font-size: 0.75rem; display: block; opacity: 0.9;">Ủy ban nhân dân thành phố Đà Nẵng</span>
                    <span class="portal-title-main" style="font-size: 0.95rem; font-weight: bold; display: block;">Công an thành phố Đà Nẵng</span>
                    <span class="portal-title-sub" style="font-size: 0.75rem; display: block; opacity: 0.8;">Hệ thống Quản lý người nước ngoài</span>
                </div>
            </div>
            <div class="d-none d-md-block text-end">
                <a asp-controller="TrangChu" asp-action="Index" class="btn btn-outline-light btn-sm text-decoration-none">
                    <i class="bi bi-house-door-fill me-1"></i> Trang chủ
                </a>
            </div>
        </div>
    </header>

    <!-- 3. Main body container -->
    <main role="main" class="auth-main-container">
        @RenderBody()
    </main>

    <!-- 4. Mini footer bottom bar -->
    <footer class="auth-mini-footer py-2 text-center text-white-50 mt-auto" style="font-size: 0.8rem; border-top: 2px solid var(--gov-yellow, #f2a100); background-color: #1a1a1a;">
        <div class="container">
            <span>&copy; 2026 - Bản quyền thuộc về Công an Thành phố Đà Nẵng. Bảo lưu mọi quyền.</span>
        </div>
    </footer>

    <!-- Thư viện Javascript -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/landing.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
