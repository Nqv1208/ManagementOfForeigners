<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ thống quản lý người nước ngoài</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/auth-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth-pages.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="auth-layout-body">
    <div class="auth-shell">
        <!-- <div class="auth-utilitybar">
            <div class="auth-container auth-utilitybar-inner">
                <span>Cổng thông tin điện tử chính thức phục vụ quản lý cư trú người nước ngoài</span>
                <div class="auth-utility-actions" aria-label="Tiện ích">
                    <span id="auth-current-time">--:--</span>
                    <span class="auth-language" aria-label="Ngôn ngữ">VI | EN</span>
                </div>
            </div>
        </div> -->

        <header class="auth-brand-header">
            <div class="auth-container auth-brand-inner">
                <a asp-controller="TrangChu" asp-action="Index" class="auth-brand-link" aria-label="Trang chủ">
                    <img src="~/images/bo-cong-an-logo.png" alt="Logo Bộ Công an" class="auth-brand-logo" />
                    <span class="auth-brand-copy">
                        <span class="auth-brand-overline">Ủy ban nhân dân thành phố Đà Nẵng</span>
                        <span class="auth-brand-title">Công an thành phố Đà Nẵng</span>
                        <span class="auth-brand-system">Hệ thống quản lý người nước ngoài</span>
                    </span>
                </a>
                <a asp-controller="TrangChu" asp-action="Index" class="auth-home-link">
                    <i class="bi bi-house-door" aria-hidden="true"></i>
                    <span>Trang chủ</span>
                </a>
            </div>
        </header>

        <main class="auth-main" role="main">
            @RenderBody()
        </main>

        <footer class="auth-footer">
            <div class="auth-container auth-footer-inner">
                <span>&copy; 2026 Công an thành phố Đà Nẵng</span>
                <nav class="auth-footer-links" aria-label="Liên kết hỗ trợ">
                    <a asp-controller="TrangChu" asp-action="Index">Hướng dẫn</a>
                    <a asp-controller="TrangChu" asp-action="Index">Hỗ trợ</a>
                    <a asp-controller="TrangChu" asp-action="Index">Điều khoản sử dụng</a>
                </nav>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/auth-interactions.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
