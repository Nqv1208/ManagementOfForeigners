<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cổng khai báo tạm trú Đà Nẵng</title>
    <!-- Thư viện CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/public-layout.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="public-page">
        <!-- Header -->
        @await Html.PartialAsync("_PublicHeader")

        <!-- TempData Toast Alerts -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="temp-data-alert d-none" data-message="@TempData["SuccessMessage"]" data-type="success"></div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="temp-data-alert d-none" data-message="@TempData["ErrorMessage"]" data-type="danger"></div>
        }
        @if (TempData["WarningMessage"] != null)
        {
            <div class="temp-data-alert d-none" data-message="@TempData["WarningMessage"]" data-type="warning"></div>
        }
        @if (TempData["InfoMessage"] != null)
        {
            <div class="temp-data-alert d-none" data-message="@TempData["InfoMessage"]" data-type="info"></div>
        }

        <!-- Main Content -->
        <main role="main" class="public-main">
            @RenderBody()
        </main>

        <!-- Footer -->
        @await Html.PartialAsync("_PublicFooter")
    </div>

    <!-- Thư viện Javascript -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/landing.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
