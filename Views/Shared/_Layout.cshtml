<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cổng khai báo tạm trú Đà Nẵng</title>
    <!-- Thư viện CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
</head>
<body>
    @{
        var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
        var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        var userName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
    }

    <!-- 1. TOPBAR HÀNH CHÍNH QUỐC GIA -->
    <div class="portal-topbar">
        <div class="container d-flex flex-wrap justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <span class="flag-vn"></span>
                <span class="fw-semibold text-white text-uppercase" style="letter-spacing: 0.5px; font-size: 0.72rem;">Cổng thông tin điện tử chính thức nước Cộng hòa xã hội chủ nghĩa Việt Nam</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span id="portal-realtime" class="me-2"><i class="bi bi-clock me-1"></i>Đang tải thời gian...</span>
                <div class="d-flex gap-2 border-start border-secondary ps-3">
                    <a href="#" id="lang-vi" class="fw-bold text-white">VI</a>
                    <span class="text-secondary">|</span>
                    <a href="#" id="lang-en" class="text-white-50 text-decoration-none">EN</a>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. BANNER HÀNH CHÍNH TP ĐÀ NẴNG -->
    <header class="portal-header-banner">
        <div class="container d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div class="portal-logo-container">
                <div class="portal-emblem">
                    <i class="bi bi-shield-shaded"></i>
                </div>
                <div class="portal-titles">
                    <span class="portal-title-gov">Ủy ban nhân dân thành phố Đà Nẵng</span>
                    <span class="portal-title-main">Công an thành phố Đà Nẵng</span>
                    <span class="portal-title-sub">Cổng khai báo tạm trú & lưu trú người nước ngoài</span>
                </div>
            </div>
            <div class="d-none d-lg-block text-end">
                <span class="d-block text-white-50 small font-monospace">Phiên bản: 2.1.0</span>
                <span id="portal-greeting" class="fw-medium text-warning small">Đang tải thông tin hỗ trợ...</span>
            </div>
        </div>
    </header>

    <!-- 3. THANH ĐIỀU HƯỚNG PHẲNG HÀNH CHÍNH -->
    <nav class="navbar navbar-expand-lg navbar-dark portal-navbar mb-4">
        <div class="container">
            <a class="navbar-brand d-lg-none" asp-controller="Home" asp-action="Index">
                🌐 QL Người nước ngoài
            </a>
            <button class="navbar-toggler my-2 ms-auto" type="button" data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door-fill me-1"></i> Trang chủ</a>
                    </li>

                    @if (isAuthenticated)
                    {
                        @* ===== Menu cho Người nước ngoài ===== *@
                        if (userRole == "NguoiNuocNgoai")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Foreigner" asp-action="KhaiBaoTamTru"><i class="bi bi-file-earmark-text me-1"></i> Khai báo tạm trú</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Foreigner" asp-action="ThongTinCaNhan"><i class="bi bi-person-bounding-box me-1"></i> Thông tin cá nhân</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Foreigner" asp-action="LichSuCuTru"><i class="bi bi-clock-history me-1"></i> Lịch sử cư trú</a>
                            </li>
                        }

                        @* ===== Menu cho Chủ lưu trú ===== *@
                        if (userRole == "ChuLuuTru")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Accommodation" asp-action="KhaiBaoLuuTru"><i class="bi bi-building-add me-1"></i> Khai báo lưu trú</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Accommodation" asp-action="DanhSachLuuTru"><i class="bi bi-card-list me-1"></i> Danh sách lưu trú</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Accommodation" asp-action="ThongTinCoSo"><i class="bi bi-house-gear me-1"></i> Thông tin cơ sở</a>
                            </li>
                        }

                        @* ===== Menu cho Cán bộ xuất nhập cảnh ===== *@
                        if (userRole == "CanBoXNC")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Officer" asp-action="TraCuu"><i class="bi bi-search me-1"></i> Tra cứu</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Officer" asp-action="ThongKe"><i class="bi bi-bar-chart me-1"></i> Thống kê</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Officer" asp-action="CanhBaoViPham"><i class="bi bi-exclamation-octagon me-1"></i> Cảnh báo vi phạm</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Officer" asp-action="DanhSachBaoCao"><i class="bi bi-flag me-1"></i> Báo cáo vi phạm</a>
                            </li>
                        }

                        @* ===== Menu cho Công an Phường/Xã ===== *@
                        if (userRole == "CongAn")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Police" asp-action="DanhSachKhaiBao"><i class="bi bi-check2-circle me-1"></i> Phê duyệt khai báo</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Police" asp-action="TraCuu"><i class="bi bi-shield-shaded me-1"></i> Tra cứu</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Police" asp-action="CanhBaoViPham"><i class="bi bi-bell me-1"></i> Cảnh báo</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Police" asp-action="BaoCaoViPham"><i class="bi bi-file-earmark-break me-1"></i> Báo cáo</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Police" asp-action="ThongKe"><i class="bi bi-graph-up me-1"></i> Thống kê</a>
                            </li>
                        }

                        @* ===== Menu cho Quản trị viên ===== *@
                        if (userRole == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-shield-lock me-1"></i> Dashboard QTV</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="QuanLyTaiKhoan"><i class="bi bi-people me-1"></i> Quản lý TK</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="QuanLyPhanQuyen"><i class="bi bi-shield-check me-1"></i> Phân quyền</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="DanhMucPhuongXa"><i class="bi bi-geo-alt me-1"></i> Phường/Xã</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="NhatKyHoatDong"><i class="bi bi-clock-history me-1"></i> Nhật ký</a>
                            </li>
                        }
                    }
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    @if (isAuthenticated)
                    {
                        <li class="nav-item d-flex align-items-center me-3">
                            <div class="d-flex align-items-center gap-2 py-2 py-lg-0">
                                <span class="text-white-50 small">Xin chào,</span>
                                <span class="text-white fw-bold">@userName</span>
                                @{
                                    var roleBadgeClass = userRole switch
                                    {
                                        "NguoiNuocNgoai" => "bg-primary",
                                        "ChuLuuTru" => "bg-success",
                                        "CanBoXNC" => "bg-warning text-dark",
                                        "CongAn" => "bg-danger",
                                        "Admin" => "bg-dark text-white border border-secondary",
                                        _ => "bg-secondary"
                                    };
                                    var roleDisplayName = userRole switch
                                    {
                                        "NguoiNuocNgoai" => "Người nước ngoài",
                                        "ChuLuuTru" => "Chủ lưu trú",
                                        "CanBoXNC" => "Cán bộ XNC",
                                        "CongAn" => "Công an",
                                        "Admin" => "Quản trị",
                                        _ => userRole ?? ""
                                    };
                                    var dashboardUrl = "/";
                                    if (userRole == "NguoiNuocNgoai") dashboardUrl = "/Foreigner/Dashboard";
                                    else if (userRole == "ChuLuuTru") dashboardUrl = "/Accommodation/Dashboard";
                                    else if (userRole == "CanBoXNC") dashboardUrl = "/Officer/Dashboard";
                                    else if (userRole == "CongAn") dashboardUrl = "/Police/Dashboard";
                                    else if (userRole == "Admin") dashboardUrl = "/Admin/Dashboard";
                                }
                                <span class="badge @roleBadgeClass">@roleDisplayName</span>
                            </div>
                        </li>
                        <li class="nav-item me-2">
                            <a href="@dashboardUrl" class="btn btn-outline-warning btn-sm px-3 rounded-1"><i class="bi bi-speedometer2 me-1"></i> Trang quản trị</a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm px-3 rounded-1">Đăng xuất</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-1"></i> Đăng ký tài khoản</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- 4. MAIN CONTAINER -->
    <div class="container pb-5" style="min-height: 60vh; padding-top: 1rem;">
        <!-- TempData Alerts -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 border-start border-5 border-success shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 border-start border-5 border-danger shadow-sm" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
            </div>
        }
        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show border-0 border-start border-5 border-warning shadow-sm" role="alert">
                <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["WarningMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
            </div>
        }
        @if (TempData["InfoMessage"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show border-0 border-start border-5 border-info shadow-sm" role="alert">
                <i class="bi bi-info-circle-fill me-2"></i> @TempData["InfoMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- 5. FOOTER HÀNH CHÍNH ĐIỆN TỬ -->
    <footer class="portal-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="bg-white bg-opacity-10 text-white rounded-circle p-2 d-inline-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                            <i class="bi bi-shield-shaded text-warning"></i>
                        </div>
                        <h5 class="m-0 border-0 p-0 text-white fw-bold">PHÒNG QUẢN LÝ XUẤT NHẬP CẢNH - CÔNG AN TP ĐÀ NẴNG</h5>
                    </div>
                    <p class="text-white-50 small mb-2"><i class="bi bi-geo-alt-fill text-warning me-2"></i>Địa chỉ: 78 Lê Lợi, Phường Thạch Thang, Quận Hải Châu, TP. Đà Nẵng</p>
                    <p class="text-white-50 small mb-2"><i class="bi bi-telephone-fill text-warning me-2"></i>Điện thoại tiếp nhận hồ sơ: 0236.3822.464</p>
                    <p class="text-white-50 small mb-2"><i class="bi bi-envelope-fill text-warning me-2"></i>Email hỗ trợ: qlxnc@danang.gov.vn</p>
                </div>
                <div class="col-md-6 col-lg-3">
                    <h5>LIÊN KẾT HỆ THỐNG</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2 small">
                        <li><a href="https://dichvucong.gov.vn" target="_blank"><i class="bi bi-link-45deg me-1"></i> Cổng Dịch vụ công Quốc gia</a></li>
                        <li><a href="https://dichvucong.bocongan.gov.vn" target="_blank"><i class="bi bi-link-45deg me-1"></i> Cổng Dịch vụ công Bộ Công an</a></li>
                        <li><a href="https://danang.gov.vn" target="_blank"><i class="bi bi-link-45deg me-1"></i> Cổng TTĐT TP. Đà Nẵng</a></li>
                        <li><a href="https://congan.danang.gov.vn" target="_blank"><i class="bi bi-link-45deg me-1"></i> Cổng thông tin Công an TP. Đà Nẵng</a></li>
                    </ul>
                </div>
                <div class="col-md-6 col-lg-3">
                    <h5>HỖ TRỢ KỸ THUẬT</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2 small">
                        <li><a href="tel:0236.1022"><i class="bi bi-headset me-1"></i> Tổng đài dịch vụ công: 0236.1022</a></li>
                        <li><a href="mailto:qlxnc@danang.gov.vn"><i class="bi bi-envelope me-1"></i> Hộp thư qlxnc@danang.gov.vn</a></li>
                        <li><a href="~/docs.pdf" target="_blank"><i class="bi bi-file-earmark-pdf me-1"></i> Tài liệu hướng dẫn (PDF)</a></li>
                        <li><a href="~/docs.docx" target="_blank"><i class="bi bi-file-earmark-word me-1"></i> Hướng dẫn biểu mẫu (DOCX)</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="portal-footer-bottom text-center">
            <div class="container text-white-50 small">
                <p class="mb-1">&copy; 2026 - Bản quyền thuộc về Công an Thành phố Đà Nẵng. Bảo lưu mọi quyền.</p>
                <p class="mb-0 text-secondary" style="font-size: 0.75rem;">Phát triển và bảo trì kỹ thuật bởi Phòng Công nghệ thông tin - Công an Thành phố Đà Nẵng.</p>
            </div>
        </div>
    </footer>

    <!-- Thư viện Javascript -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/landing.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
