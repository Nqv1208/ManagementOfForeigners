<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cổng nghiệp vụ Cán bộ QL XNC</title>
    <!-- CSS Dependencies -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/officer-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/officer-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/officer-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/officer-pages.css" asp-append-version="true" />
</head>
<body>
    @{
        var controllerName = ViewContext.RouteData.Values["Controller"]?.ToString();
        var actionName = ViewContext.RouteData.Values["Action"]?.ToString();
        var userName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Cán bộ nghiệp vụ";
    }

    <!-- 1. PORTAL TOPBAR QUỐC GIA -->
    <partial name="_PortalTopbar" />

    <!-- 2. OFFICER CONTAINER WRAPPER -->
    <div class="officer-wrapper">
        <!-- 2.1 SIDEBAR BÊN TRÁI -->
        <aside class="officer-sidebar">
            <div class="officer-sidebar-header">
                <img class="officer-sidebar-logo" src="~/images/bo-cong-an-logo.png" alt="Logo Bộ Công an" />
                <div class="officer-sidebar-title">
                    <h1>Phòng QL XNC</h1>
                    <span>Công an TP Đà Nẵng</span>
                </div>
            </div>

            <ul class="officer-sidebar-menu">
                <li class="officer-menu-item @(actionName == "TongQuan" ? "active" : "")">
                    <a asp-controller="CanBo" asp-action="TongQuan"><i class="bi bi-grid-fill"></i> Tổng quan</a>
                </li>
                <li class="officer-menu-item @(actionName == "TraCuu" || actionName == "ChiTietNguoiNuocNgoai" ? "active" : "")">
                    <a asp-controller="CanBo" asp-action="TraCuu"><i class="bi bi-people-fill"></i> Tra cứu NNN</a>
                </li>
                <li class="officer-menu-item @(actionName == "HoSoTamTru" ? "active" : "")">
                    <a asp-controller="CanBo" asp-action="HoSoTamTru"><i class="bi bi-file-earmark-text-fill"></i> Hồ sơ tạm trú</a>
                </li>
                <li class="officer-menu-item @(actionName == "ViPhamCanhBao" || actionName == "CanhBaoViPham" ? "active" : "")">
                    <a asp-controller="CanBo" asp-action="ViPhamCanhBao"><i class="bi bi-exclamation-triangle-fill"></i> Vi phạm & cảnh báo</a>
                </li>
                <li class="officer-menu-item @(actionName == "DanhSachBaoCao" ? "active" : "")">
                    <a asp-controller="CanBo" asp-action="DanhSachBaoCao"><i class="bi bi-megaphone-fill"></i> Báo cáo từ địa bàn</a>
                </li>
                <li class="officer-menu-item @(actionName == "ThongKe" ? "active" : "")">
                    <a asp-controller="CanBo" asp-action="ThongKe"><i class="bi bi-graph-up-arrow"></i> Thống kê XNC</a>
                </li>
                <li class="officer-menu-item @(actionName == "CoSoLuuTru" ? "active" : "")">
                    <a asp-controller="CanBo" asp-action="CoSoLuuTru"><i class="bi bi-house-door-fill"></i> Cơ sở lưu trú</a>
                </li>
            </ul>
        </aside>

        <!-- 2.2 NỘI DUNG CHÍNH & TOPBAR -->
        <div class="officer-main-container">
            <!-- TOPBAR TRONG -->
            <header class="officer-topbar shadow-sm">
                <div class="officer-topbar-left">
                    <button class="officer-sidebar-toggle" aria-label="Toggle Sidebar Menu">
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="fw-bold text-uppercase text-secondary small d-none d-md-inline-block">
                        Hệ thống quản lý người nước ngoài - Phòng Quản lý Xuất nhập cảnh
                    </span>
                </div>
                <div class="officer-topbar-right">
                    <div class="officer-user-info">
                        <span class="officer-user-name">@userName</span>
                        <span class="officer-user-role">Cán bộ QL XNC</span>
                    </div>
                    <form asp-controller="TaiKhoan" asp-action="DangXuat" method="post" class="d-inline m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-1 px-3">
                            <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            </header>

            <!-- KHU VỰC CHỨA NỘI DUNG -->
            <main class="officer-content" role="main">
                <!-- TempData Toast Alerts -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["SuccessMessage"]" data-type="success"></div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["ErrorMessage"]" data-type="danger"></div>
                }
                @if (TempData["WarningMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["WarningMessage"]" data-type="warning"></div>
                }
                @if (TempData["InfoMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["InfoMessage"]" data-type="info"></div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <!-- JS Dependencies -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/officer-layout.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
