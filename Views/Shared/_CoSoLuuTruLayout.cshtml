@inject ManagementOfForeigners.Data.ApplicationDbContext DbContext
@using Microsoft.EntityFrameworkCore
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cổng Thông tin Cơ sở lưu trú</title>
    <!-- CSS Dependencies -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cosoluutru-layout.css" asp-append-version="true" />
</head>
<body>
    @{
        var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        var facility = DbContext.CoSoLuuTrus
            .Include(c => c.ChuCoSoLuuTru)
            .FirstOrDefault(c => c.ChuCoSoLuuTru.MaTaiKhoan == userId);
        
        var facilityName = facility?.TenCoSo ?? "Cơ sở lưu trú";
        var ownerName = facility?.ChuCoSoLuuTru?.HoTen ?? User.Identity?.Name ?? "Chủ cơ sở";
        
        var controllerName = ViewContext.RouteData.Values["Controller"]?.ToString();
        var actionName = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    <!-- 1. PORTAL TOPBAR QUỐC GIA -->
    <partial name="_PortalTopbar" />

    <!-- 2. COSO CONTAINER WRAPPER -->
    <div class="coso-wrapper">
        <!-- 2.1 SIDEBAR BÊN TRÁI -->
        <aside class="coso-sidebar">
            <div class="coso-sidebar-header">
                <div class="coso-sidebar-logo-container">
                    <i class="bi bi-building-fill"></i>
                </div>
                <div class="coso-sidebar-title">
                    <h1>@facilityName</h1>
                    <span>Chủ cơ sở lưu trú</span>
                </div>
            </div>

            <ul class="coso-sidebar-menu">
                <li class="coso-menu-item @(actionName == "TongQuan" ? "active" : "")">
                    <a asp-controller="CoSoLuuTru" asp-action="TongQuan">
                        <i class="bi bi-grid-fill"></i> Tổng quan
                    </a>
                </li>
                <li class="coso-menu-item @(actionName == "KhaiBaoLuuTru" ? "active" : "")">
                    <a asp-controller="CoSoLuuTru" asp-action="KhaiBaoLuuTru">
                        <i class="bi bi-file-earmark-plus-fill"></i> Khai báo mới
                    </a>
                </li>
                <li class="coso-menu-item @(actionName == "DanhSachKhaiBao" ? "active" : "")">
                    <a asp-controller="CoSoLuuTru" asp-action="DanhSachKhaiBao">
                        <i class="bi bi-file-earmark-text-fill"></i> Hồ sơ khai báo
                    </a>
                </li>
                <li class="coso-menu-item @(actionName == "DanhSachLuuTru" ? "active" : "")">
                    <a asp-controller="CoSoLuuTru" asp-action="DanhSachLuuTru">
                        <i class="bi bi-people-fill"></i> Khách đang lưu trú
                    </a>
                </li>
                <li class="coso-menu-item @(actionName == "LichSuCuTru" ? "active" : "")">
                    <a asp-controller="CoSoLuuTru" asp-action="LichSuCuTru">
                        <i class="bi bi-clock-history"></i> Lịch sử lưu trú
                    </a>
                </li>
                <li class="coso-menu-item @(actionName == "ThongTinCoSo" || actionName == "CapNhatCoSo" ? "active" : "")">
                    <a asp-controller="CoSoLuuTru" asp-action="ThongTinCoSo">
                        <i class="bi bi-house-gear-fill"></i> Thông tin cơ sở
                    </a>
                </li>
            </ul>
        </aside>

        <!-- 2.2 NỘI DUNG CHÍNH & TOPBAR -->
        <div class="coso-main-container">
            <!-- TOPBAR TRONG -->
            <header class="coso-topbar shadow-sm">
                <div class="coso-topbar-left">
                    <button class="coso-sidebar-toggle" aria-label="Toggle Sidebar Menu">
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="fw-bold text-uppercase text-success small d-none d-md-inline-block">
                        <i class="bi bi-building-check me-1"></i> Trang quản lý dành cho Cơ sở lưu trú
                    </span>
                </div>
                <div class="coso-topbar-right">
                    <div class="coso-user-info">
                        <span class="coso-user-name">@ownerName</span>
                        <span class="coso-user-role">@facilityName</span>
                    </div>
                    <form asp-controller="TaiKhoan" asp-action="DangXuat" method="post" class="d-inline m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-1 px-3">
                            <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            </header>

            <!-- KHU VỰC NỘI DUNG CHÍNH -->
            <main class="coso-content" role="main">
                <!-- TempData Toast Alerts -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["SuccessMessage"]" data-type="success"></div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["ErrorMessage"]" data-type="danger"></div>
                }
                @if (TempData["WarningMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["WarningMessage"]" data-type="warning"></div>
                }
                @if (TempData["InfoMessage"] != null)
                {
                    <div class="temp-data-alert d-none" data-message="@TempData["InfoMessage"]" data-type="info"></div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <!-- JS Dependencies -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/cosoluutru-layout.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
