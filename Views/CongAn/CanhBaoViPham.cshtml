@model ManagementOfForeigners.Models.ViewModels.CanBo.CanhBaoViewModel
@{
    Layout = "~/Views/Shared/_PoliceLayout.cshtml";
    ViewBag.Title = "Gửi cảnh báo vi phạm - Công an";
}

<div class="container-fluid">
    <div class="police-page-header mb-4">
        <h5 class="fw-bold mb-1" style="color: var(--police-primary-dark);">Gửi cảnh báo vi phạm cư trú</h5>
        <p class="text-muted mb-0 fs-7">Gửi thông báo nhắc nhở, cảnh báo vi phạm quy chế cư trú, đi lại của người nước ngoài trên địa bàn</p>
    </div>

    <div class="row g-4">
        <!-- Left Column: Input Form -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                <div class="card-body p-4">
                    <form asp-action="CanhBaoViPham" method="post" id="warningForm" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="row g-3">
                            <!-- Search & Select Foreigner -->
                            <div class="col-md-12">
                                <label class="form-label fw-semibold text-dark fs-7">Người nước ngoài liên quan <span class="text-danger">*</span></label>
                                <div class="input-group mb-2">
                                    <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                                    <input type="text" id="foreignerSearch" class="form-control border-start-0" placeholder="Nhập tên hoặc số hộ chiếu để tìm kiếm..." style="border-radius: 0 8px 8px 0;" />
                                </div>
                                <select asp-for="MaNguoiNuocNgoai" asp-items="ViewBag.NguoiNuocNgoais" class="form-select" id="MaNguoiNuocNgoai" style="border-radius: 8px;" required>
                                    <option value="">-- Chọn người nước ngoài --</option>
                                </select>
                                <span asp-validation-for="MaNguoiNuocNgoai" class="text-danger small"></span>
                            </div>

                            <!-- Violation Type Presets -->
                            <div class="col-md-8">
                                <label asp-for="LoaiViPham" class="form-label fw-semibold text-dark fs-7">Loại vi phạm <span class="text-danger">*</span></label>
                                <select id="LoaiViPhamPreset" class="form-select mb-2" style="border-radius: 8px;" required>
                                    <option value="">-- Chọn loại vi phạm quy chuẩn --</option>
                                    <option value="Chưa khai báo tạm trú">Chưa khai báo tạm trú</option>
                                    <option value="Quá hạn lưu trú">Quá hạn lưu trú</option>
                                    <option value="Không đúng địa chỉ cư trú">Không đúng địa chỉ cư trú</option>
                                    <option value="Thông tin hộ chiếu/visa không khớp">Thông tin hộ chiếu/visa không khớp</option>
                                    <option value="Có dấu hiệu vi phạm quy định cư trú">Có dấu hiệu vi phạm quy định cư trú</option>
                                    <option value="Khác">Khác...</option>
                                </select>
                                <input type="hidden" asp-for="LoaiViPham" id="LoaiViPham" />
                                <input type="text" id="LoaiViPhamCustom" class="form-control d-none" placeholder="Nhập mô tả hành vi vi phạm khác..." style="border-radius: 8px;" />
                                <span asp-validation-for="LoaiViPham" class="text-danger small"></span>
                            </div>

                            <!-- Severity Dropdown -->
                            <div class="col-md-4">
                                <label asp-for="MucDoViPham" class="form-label fw-semibold text-dark fs-7">Mức độ <span class="text-danger">*</span></label>
                                <select asp-for="MucDoViPham" class="form-select" style="border-radius: 8px;" required>
                                    <option value="">-- Chọn mức độ --</option>
                                    <option value="Nhẹ">Nhẹ</option>
                                    <option value="Trung bình">Trung bình</option>
                                    <option value="Nghiêm trọng">Nghiêm trọng</option>
                                </select>
                                <span asp-validation-for="MucDoViPham" class="text-danger small"></span>
                            </div>

                            <!-- Warning Content -->
                            <div class="col-12">
                                <label asp-for="NoiDungCanhBao" class="form-label fw-semibold text-dark fs-7">Nội dung cảnh báo <span class="text-danger">*</span></label>
                                <textarea asp-for="NoiDungCanhBao" class="form-control" rows="4" placeholder="Mô tả cụ thể hành vi vi phạm và các yêu cầu chấp hành quy định..." style="border-radius: 8px;" required></textarea>
                                <span asp-validation-for="NoiDungCanhBao" class="text-danger small"></span>
                            </div>

                            <!-- Internal Notes -->
                            <div class="col-12">
                                <label asp-for="GhiChu" class="form-label fw-semibold text-dark fs-7"></label>
                                <textarea asp-for="GhiChu" class="form-control" rows="2" placeholder="Ghi chú nghiệp vụ nội bộ (nếu có)..." style="border-radius: 8px;"></textarea>
                                <span asp-validation-for="GhiChu" class="text-danger small"></span>
                            </div>

                            <!-- Buttons -->
                            <div class="col-12 d-flex justify-content-between mt-4">
                                <a asp-action="TongQuan" class="btn btn-outline-secondary btn-sm px-3 fw-semibold" style="border-radius: 6px;">
                                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                                </a>
                                <button type="button" id="btnSubmitConfirm" class="btn btn-success btn-sm px-4 fw-semibold text-white" style="border-radius: 6px;">
                                    <i class="bi bi-send me-1"></i> Gửi cảnh báo
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Column: Foreigner Info Card & Guidelines -->
        <div class="col-lg-4">
            <!-- Dynamic Info Card -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                <div class="card-header bg-light border-0 py-3 px-4">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-person-badge me-2 text-primary"></i>Thông tin người nước ngoài</h6>
                </div>
                <div class="card-body p-4" id="foreignerDetailsCard">
                    <div class="text-center py-4 text-muted" id="noForeignerSelected">
                        <i class="bi bi-person-slash fs-1 d-block mb-2 text-secondary"></i>
                        <small>Vui lòng chọn một người nước ngoài bên trái để xem thông tin chi tiết.</small>
                    </div>
                    <div class="d-none text-start" id="foreignerSelectedInfo">
                        <div class="mb-3">
                            <label class="text-muted fs-8 d-block">Họ và tên</label>
                            <span class="fw-bold text-dark fs-6" id="infoName"></span>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted fs-8 d-block">Số hộ chiếu</label>
                            <span class="fw-bold text-dark fs-6" id="infoPassport"></span>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted fs-8 d-block">Quốc tịch</label>
                            <span class="fw-bold text-dark fs-6 animate-pulse" id="infoNationality"></span>
                        </div>
                        <div class="mb-0">
                            <label class="text-muted fs-8 d-block">Địa bàn theo dõi</label>
                            <span class="badge bg-success bg-opacity-10 text-success fw-semibold">Phường Hải Châu, Đà Nẵng</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Guidelines -->
            <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                <div class="card-header bg-light border-0 py-3 px-4">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-info-circle me-2 text-success"></i>Cẩm nang xử lý vi phạm</h6>
                </div>
                <div class="card-body p-4 text-start fs-8">
                    <div class="mb-3 pb-2 border-bottom">
                        <span class="badge bg-warning bg-opacity-15 text-warning-emphasis mb-1 fw-bold">Nhẹ</span>
                        <p class="text-muted mb-0">Các vi phạm lần đầu, trễ hạn khai báo dưới 3 ngày. Nhắc nhở người nước ngoài hoặc chủ cơ sở cập nhật thông tin.</p>
                    </div>
                    <div class="mb-3 pb-2 border-bottom">
                        <span class="badge bg-orange bg-opacity-15 text-orange mb-1 fw-bold" style="background-color: rgba(253, 126, 20, 0.15); color: #fd7e14;">Trung bình</span>
                        <p class="text-muted mb-0">Không khai báo tạm trú quá 3 ngày, thông tin sai lệch nhưng không có dấu hiệu gian lận. Yêu cầu làm việc trực tiếp.</p>
                    </div>
                    <div class="mb-0">
                        <span class="badge bg-danger bg-opacity-15 text-danger mb-1 fw-bold">Nghiêm trọng</span>
                        <p class="text-muted mb-0">Hộ chiếu giả, Visa quá hạn dài, có dấu hiệu hoạt động phi pháp. Cần báo cáo lên Cục/Phòng XNC xử lý trục xuất.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Submit Confirm Modal -->
<div class="modal fade" id="submitConfirmModal" tabindex="-1" aria-labelledby="submitConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="border-radius: 16px; overflow: hidden;">
            <div class="modal-header bg-warning text-dark border-0 p-4">
                <h5 class="modal-title fw-bold" id="submitConfirmModalLabel"><i class="bi bi-exclamation-triangle-fill me-2"></i>Xác nhận gửi cảnh báo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-start fs-7">
                <p class="mb-3">Bạn đang tạo cảnh báo vi phạm cư trú cho người nước ngoài sau:</p>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item d-flex justify-content-between px-0 py-2 border-0 bg-transparent">
                        <span class="text-muted">Đối tượng:</span>
                        <span class="fw-bold text-dark" id="modalForeignerName"></span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between px-0 py-2 border-0 bg-transparent">
                        <span class="text-muted">Hành vi vi phạm:</span>
                        <span class="fw-bold text-danger" id="modalViolationType"></span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between px-0 py-2 border-0 bg-transparent">
                        <span class="text-muted">Mức độ:</span>
                        <span class="badge" id="modalViolationSeverity"></span>
                    </li>
                </ul>
                <p class="mb-0 text-muted small"><i class="bi bi-info-circle me-1"></i>Hồ sơ cảnh báo này sẽ được gửi trực tiếp đến hệ thống và lưu trữ trong hồ sơ cư trú của người nước ngoài.</p>
            </div>
            <div class="modal-footer border-0 p-4 pt-0 justify-content-between">
                <button type="button" class="btn btn-secondary btn-sm px-3 fw-semibold" data-bs-dismiss="modal" style="border-radius: 6px;">Hủy bỏ</button>
                <button type="button" id="btnConfirmSubmitForm" class="btn btn-success btn-sm px-4 fw-semibold text-white" style="border-radius: 6px;">Xác nhận gửi</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Filter dropdown list
            const searchInput = document.getElementById("foreignerSearch");
            const select = document.getElementById("MaNguoiNuocNgoai");
            if (searchInput && select) {
                const originalOptions = Array.from(select.options);

                searchInput.addEventListener("input", function () {
                    const query = searchInput.value.toLowerCase().trim();
                    select.innerHTML = "";
                    const filtered = originalOptions.filter((opt, index) => {
                        if (index === 0) return true;
                        return opt.text.toLowerCase().includes(query);
                    });
                    filtered.forEach(opt => select.appendChild(opt));
                    triggerForeignerDetailsChange();
                });
            }

            // 2. Dynamic Info Card
            const foreignerSelectedInfo = document.getElementById("foreignerSelectedInfo");
            const noForeignerSelected = document.getElementById("noForeignerSelected");
            const infoName = document.getElementById("infoName");
            const infoPassport = document.getElementById("infoPassport");
            const infoNationality = document.getElementById("infoNationality");

            function triggerForeignerDetailsChange() {
                if (!select || select.value === "") {
                    if (foreignerSelectedInfo) foreignerSelectedInfo.classList.add("d-none");
                    if (noForeignerSelected) noForeignerSelected.classList.remove("d-none");
                } else {
                    const selectedText = select.options[select.selectedIndex].text;
                    const parts = selectedText.split(" - Hộ chiếu: ");
                    const name = parts[0];
                    const subParts = parts[1] ? parts[1].split(" (") : [];
                    const passport = subParts[0] || "";
                    const nationality = subParts[1] ? subParts[1].replace(")", "") : "";

                    if (infoName) infoName.textContent = name;
                    if (infoPassport) infoPassport.textContent = passport;
                    if (infoNationality) infoNationality.textContent = nationality;

                    if (noForeignerSelected) noForeignerSelected.classList.add("d-none");
                    if (foreignerSelectedInfo) foreignerSelectedInfo.classList.remove("d-none");
                }
            }

            if (select) {
                select.addEventListener("change", triggerForeignerDetailsChange);
                triggerForeignerDetailsChange();
            }

            // 3. Preset dropdown category
            const presetSelect = document.getElementById("LoaiViPhamPreset");
            const realInput = document.getElementById("LoaiViPham");
            const customInput = document.getElementById("LoaiViPhamCustom");

            if (presetSelect && realInput && customInput) {
                // Initialize preset based on value if any
                if (realInput.value) {
                    const foundOption = Array.from(presetSelect.options).find(opt => opt.value === realInput.value);
                    if (foundOption) {
                        presetSelect.value = realInput.value;
                    } else {
                        presetSelect.value = "Khác";
                        customInput.classList.remove("d-none");
                        customInput.value = realInput.value;
                    }
                }

                presetSelect.addEventListener("change", function () {
                    const val = presetSelect.value;
                    if (val === "Khác") {
                        customInput.classList.remove("d-none");
                        realInput.value = customInput.value;
                        customInput.setAttribute("required", "required");
                    } else {
                        customInput.classList.add("d-none");
                        realInput.value = val;
                        customInput.removeAttribute("required");
                    }
                });

                customInput.addEventListener("input", function () {
                    if (presetSelect.value === "Khác") {
                        realInput.value = customInput.value;
                    }
                });
            }

            // 4. Modal confirm
            const btnSubmitConfirm = document.getElementById("btnSubmitConfirm");
            const submitConfirmModalEl = document.getElementById("submitConfirmModal");
            const modalForeignerName = document.getElementById("modalForeignerName");
            const modalViolationType = document.getElementById("modalViolationType");
            const modalViolationSeverity = document.getElementById("modalViolationSeverity");
            const warningForm = document.getElementById("warningForm");

            if (btnSubmitConfirm && submitConfirmModalEl && warningForm) {
                const modal = new bootstrap.Modal(submitConfirmModalEl);

                btnSubmitConfirm.addEventListener("click", function () {
                    // Custom validate to ensure hidden input LoaiViPham has value
                    if (presetSelect && presetSelect.value === "") {
                        presetSelect.setCustomValidity("Vui lòng chọn loại vi phạm.");
                    } else {
                        presetSelect.setCustomValidity("");
                    }

                    if (!warningForm.checkValidity()) {
                        warningForm.classList.add("was-validated");
                        warningForm.reportValidity();
                        return;
                    }

                    // Populate modal data
                    modalForeignerName.textContent = infoName.textContent || "Chưa xác định";
                    modalViolationType.textContent = realInput.value || "Chưa nhập hành vi vi phạm";
                    
                    const severity = document.getElementById("MucDoViPham").value;
                    modalViolationSeverity.textContent = severity;
                    
                    // Style badge
                    modalViolationSeverity.className = "badge";
                    if (severity === "Nhẹ") {
                        modalViolationSeverity.classList.add("bg-warning", "text-dark");
                    } else if (severity === "Trung bình") {
                        modalViolationSeverity.classList.add("bg-orange");
                        modalViolationSeverity.style.backgroundColor = "#fd7e14";
                        modalViolationSeverity.style.color = "#fff";
                    } else {
                        modalViolationSeverity.classList.add("bg-danger");
                    }

                    modal.show();
                });

                const btnConfirmSubmitForm = document.getElementById("btnConfirmSubmitForm");
                if (btnConfirmSubmitForm) {
                    btnConfirmSubmitForm.addEventListener("click", function () {
                        warningForm.submit();
                    });
                }
            }
        });
    </script>
}
