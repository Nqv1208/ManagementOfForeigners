@model ManagementOfForeigners.Models.ViewModels.CongAn.TongQuanViewModel
@{
    Layout = "~/Views/Shared/_PoliceLayout.cshtml";
    ViewBag.Title = "Bảng điều khiển - Công an Phường/Xã";
}

<div class="container-fluid">
    <!-- Header banner -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="police-hero">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-4">
                    <div>
                        <span class="badge bg-success px-3 py-2 mb-2" style="border-radius: 30px;">Công an Phường/Xã phụ trách</span>
                        <h2 class="fw-bold mb-1" style="color: #1f2937;">Địa bàn: @Model.TenDiaBan, Đà Nẵng</h2>
                        <p class="text-muted mb-0">Quản lý tạm trú, phê duyệt khai báo, gửi cảnh báo & báo cáo vi phạm người nước ngoài trên địa bàn</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="DanhSachKhaiBao" class="btn btn-success">
                            <i class="bi bi-patch-check me-1"></i> Duyệt khai báo
                        </a>
                        <a asp-action="TraCuu" class="btn btn-outline-success">
                            <i class="bi bi-search me-1"></i> Tra cứu địa bàn
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Analytics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="police-stat-card is-warning">
                <div class="stat-content">
                    <span class="stat-label">Chờ duyệt tạm trú</span>
                    <span class="stat-value">@Model.TotalPending</span>
                </div>
                <div class="stat-icon warning">
                    <i class="bi bi-clock-history"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="police-stat-card is-success">
                <div class="stat-content">
                    <span class="stat-label">Đã duyệt hôm nay</span>
                    <span class="stat-value">@Model.TotalApproved</span>
                </div>
                <div class="stat-icon success">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="police-stat-card is-info-teal">
                <div class="stat-content">
                    <span class="stat-label">Người nước ngoài địa bàn</span>
                    <span class="stat-value">@Model.TotalForeigners</span>
                </div>
                <div class="stat-icon info-teal">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="police-stat-card is-neutral">
                <div class="stat-content">
                    <span class="stat-label">Cảnh báo đã gửi</span>
                    <span class="stat-value">@Model.TotalWarnings</span>
                </div>
                <div class="stat-icon neutral">
                    <i class="bi bi-exclamation-octagon-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Pending Declarations -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark">Hồ sơ khai báo tạm trú chờ duyệt</h5>
                    <a asp-action="DanhSachKhaiBao" class="text-decoration-none fs-8 fw-semibold text-success">Xem tất cả <i class="bi bi-chevron-right fs-9"></i></a>
                </div>
                <div class="card-body p-4">
                    @if (!Model.RecentPending.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-shield-check text-success animate-pulse" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3 mb-0">Tuyệt vời! Không có hồ sơ nào đang chờ duyệt.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="police-table-themed align-middle mb-0 fs-8">
                                <thead>
                                    <tr>
                                        <th>Họ tên khách</th>
                                        <th>Hộ chiếu</th>
                                        <th>Địa chỉ lưu trú</th>
                                        <th>Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dec in Model.RecentPending)
                                    {
                                        <tr>
                                            <td class="fw-bold text-dark">@dec.TaiKhoan.NguoiNuocNgoai?.HoTen</td>
                                            <td>@dec.TaiKhoan.NguoiNuocNgoai?.SoHoChieu</td>
                                            <td><small class="text-muted style-multiline-ellipsis">@dec.DiaChiLuuTru</small></td>
                                            <td>
                                                <a asp-action="ChiTietKhaiBao" asp-route-id="@dec.MaHSKhaiBao" class="btn btn-outline-success btn-xs">
                                                    <i class="bi bi-eye"></i> Chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Warnings -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark">Cảnh báo vi phạm đã gửi</h5>
                </div>
                <div class="card-body p-4">
                    @if (!Model.RecentWarnings.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-envelope text-muted" style="font-size: 2.5rem;"></i>
                            <p class="text-muted mt-2 mb-0">Bạn chưa gửi cảnh báo vi phạm nào.</p>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var warn in Model.RecentWarnings)
                            {
                                var borderStyle = "border-left: 4px solid #6c757d !important;";
                                var badgeClass = "bg-secondary-subtle text-secondary";
                                if (warn.MucDoViPham == "Nghiêm trọng")
                                {
                                    borderStyle = "border-left: 4px solid #dc2626 !important;";
                                    badgeClass = "bg-danger-subtle text-danger";
                                }
                                else if (warn.MucDoViPham == "Trung bình")
                                {
                                    borderStyle = "border-left: 4px solid #f59e0b !important;";
                                    badgeClass = "bg-warning-subtle text-warning-emphasis";
                                }
                                else if (warn.MucDoViPham == "Nhẹ")
                                {
                                    borderStyle = "border-left: 4px solid #087f5b !important;";
                                    badgeClass = "bg-success-subtle text-success";
                                }
                                <div class="p-3 bg-white border rounded-3 shadow-xs" style="@borderStyle">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="fw-bold text-dark fs-7">@warn.NguoiNuocNgoai.HoTen</span>
                                        <small class="text-muted fs-8">@warn.NgayCanhBao.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <div class="d-flex align-items-center gap-2 mb-2 fs-8 text-muted">
                                        <span>Loại: <strong class="text-dark">@warn.LoaiViPham</strong></span>
                                        <span class="vr"></span>
                                        <span class="badge @badgeClass">@warn.MucDoViPham</span>
                                    </div>
                                    <p class="mb-0 text-secondary fs-8 style-multiline-ellipsis">@warn.NoiDungCanhBao</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
