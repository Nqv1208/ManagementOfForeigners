@model ManagementOfForeigners.Models.Entities.HoSoKhaiBaoTamTru
@{
    Layout = "~/Views/Shared/_PoliceLayout.cshtml";
    ViewBag.Title = "Chi tiết hồ sơ khai báo tạm trú";
    var foreigner = Model.TaiKhoan.NguoiNuocNgoai;
}

<div class="container-fluid">
    <!-- Back Button -->
    <div class="mb-4">
        <a asp-action="DanhSachKhaiBao" class="btn btn-outline-secondary fw-semibold px-3 py-2" style="border-radius: 8px;">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>



    <div class="row g-4">
        <!-- Foreigner Information -->
        <div class="col-lg-5 col-md-12">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px; overflow: hidden;">
                <div class="card-header bg-white border-0 p-4 pb-0"><h5 class="fw-bold mb-0 text-dark"><i class="bi bi-person-badge me-2 text-success"></i>Thông tin khách khai báo</h5></div>
                <div class="card-body p-4 text-start">
                    @if (foreigner == null)
                    {
                        <p class="text-danger mb-0">Hồ sơ người nước ngoài không tìm thấy hoặc chưa được liên kết.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush fs-7">
                            <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                                <span class="text-muted">Họ và tên:</span>
                                <span class="fw-bold text-dark">@foreigner.HoTen</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                                <span class="text-muted">Số hộ chiếu:</span>
                                <span class="fw-bold text-dark">@foreigner.SoHoChieu</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                                <span class="text-muted">Quốc tịch:</span>
                                <span class="fw-bold text-dark">@foreigner.QuocTich</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                                <span class="text-muted">Giới tính:</span>
                                <span class="fw-bold text-dark">@foreigner.GioiTinh</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                                <span class="text-muted">Loại Visa / Hạn Visa:</span>
                                <span class="fw-bold text-dark">@foreigner.LoaiVisa (@foreigner.NgayHetHanVisa.ToString("dd/MM/yyyy"))</span>
                            </li>
                            <li class="list-group-item p-3 border-0 bg-light rounded-3">
                                <span class="text-muted d-block mb-1">Nơi cư trú thực tế hiện tại:</span>
                                <span class="fw-bold text-dark fs-8 text-break">@foreigner.NoiCuTruHienTai</span>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- Declaration Details -->
        <div class="col-lg-7 col-md-12">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-file-earmark-text me-2"></i>Thông tin chi tiết khai báo</h5>
                    @await Html.PartialAsync("_StatusBadge", Model.TrangThai)
                </div>

                <div class="card-body p-4">
                    <div class="row g-3 fs-7 mb-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <div class="text-muted fs-8 mb-1">Mã hồ sơ</div>
                                <div class="fw-bold text-dark"><code class="text-secondary fw-semibold">@Model.MaHSKhaiBao</code></div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <div class="text-muted fs-8 mb-1">Ngày nộp hồ sơ</div>
                                <div class="fw-bold text-dark">@Model.NgayKhaiBao.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <div class="text-muted fs-8 mb-1">Thời gian tạm trú bắt đầu</div>
                                <div class="fw-bold text-dark">@Model.NgayBatDau.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <div class="text-muted fs-8 mb-1">Thời gian tạm trú kết thúc</div>
                                <div class="fw-bold text-dark">@Model.NgayKetThuc.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-3 bg-light rounded-3">
                                <div class="text-muted fs-8 mb-1">Mục đích lưu trú</div>
                                <div class="fw-bold text-dark text-break">@Model.MucDichLuuTru</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-3 bg-light rounded-3">
                                <div class="text-muted fs-8 mb-1">Địa chỉ đăng ký tạm trú</div>
                                <div class="fw-bold text-dark text-break">@Model.DiaChiLuuTru</div>
                            </div>
                        </div>

                        @if (Model.CoSoLuuTru != null)
                        {
                            <div class="col-12">
                                <div class="p-3 bg-light rounded-3">
                                    <div class="text-muted fs-8 mb-1">Cơ sở bảo lãnh / Cơ sở lưu trú liên kết</div>
                                    <div class="fw-bold text-dark">@Model.CoSoLuuTru.TenCoSo <small class="text-muted">(Mã: @Model.CoSoLuuTru.MaCoSoLuuTru)</small></div>
                                </div>
                            </div>
                        }

                        @if (Model.TrangThai == "Từ chối")
                        {
                            <div class="col-12">
                                <div class="p-3 bg-danger bg-opacity-10 text-danger border border-danger border-opacity-20 rounded-3">
                                    <div class="fs-8 fw-semibold mb-1"><i class="bi bi-x-circle-fill me-1"></i> Lý do từ chối phê duyệt</div>
                                    <div class="fw-bold">@Model.LyDoTuChoi</div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Actions Form (only if Pending) -->
                    @if (Model.TrangThai == "Chờ duyệt")
                    {
                        <div class="border-top pt-4">
                            <div class="d-flex gap-2 justify-content-end mb-3 flex-wrap">
                                <!-- Reject Toggle Button -->
                                <button type="button" class="btn btn-outline-danger fw-semibold px-4 py-2" data-bs-toggle="collapse" data-bs-target="#tuChoiFormCollapse" aria-expanded="false" aria-controls="tuChoiFormCollapse" style="border-radius: 8px;">
                                    <i class="bi bi-x-circle me-1"></i> Từ chối duyệt
                                </button>

                                <!-- Approve Action -->
                                <form asp-action="PheDuyet" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn phê duyệt hồ sơ khai báo này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.MaHSKhaiBao" />
                                    <button type="submit" class="btn btn-success fw-semibold px-4 py-2 text-white" style="border-radius: 8px;">
                                        <i class="bi bi-check-circle me-1"></i> Phê duyệt hồ sơ
                                    </button>
                                </form>
                            </div>

                            <!-- Reject Reason Collapse Form -->
                            <div class="collapse mt-3" id="tuChoiFormCollapse">
                                <div class="card card-body bg-light border-0 shadow-sm p-4" style="border-radius: 12px;">
                                    <h6 class="fw-bold mb-3 text-dark"><i class="bi bi-exclamation-circle me-1 text-danger"></i> Nhập lý do từ chối duyệt</h6>
                                    <form asp-action="TuChoi" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn từ chối hồ sơ khai báo này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="MaHSKhaiBao" value="@Model.MaHSKhaiBao" />
                                        
                                        <div class="mb-3">
                                            <textarea name="LyDoTuChoi" class="form-control" rows="3" placeholder="Lý do từ chối (Ví dụ: Địa chỉ lưu trú không hợp lệ, thiếu tài liệu, sai mục đích...)" style="border-radius: 8px;" required></textarea>
                                        </div>
                                        <div class="d-flex justify-content-end gap-2">
                                            <button type="button" class="btn btn-secondary btn-sm px-3 py-2 fw-semibold" data-bs-toggle="collapse" data-bs-target="#tuChoiFormCollapse" style="border-radius: 6px;">Hủy bỏ</button>
                                            <button type="submit" class="btn btn-danger btn-sm px-3 py-2 fw-semibold" style="border-radius: 6px;">Xác nhận từ chối</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
