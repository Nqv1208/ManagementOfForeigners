@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.NguoiNuocNgoai>
@{
    Layout = "~/Views/Shared/_PoliceLayout.cshtml";
    ViewBag.Title = "Tra cứu địa bàn - Công an";

    var showAdvanced = ViewBag.SelectedQuocTich != null || ViewBag.SelectedLoaiVisa != null;
    var expandedVal = showAdvanced ? "true" : "false";
    var collapseClass = showAdvanced ? "show" : "";
    var nationalities = ViewBag.Nationalities as List<string>;
    var visaTypes = ViewBag.VisaTypes as List<string>;
}

<div class="container-fluid">
    <div class="police-page-header mb-4">
        <h5 class="fw-bold mb-1" style="color: var(--police-primary-dark);">Tra cứu người nước ngoài tại @ViewBag.TenDiaBan</h5>
        <p class="text-muted mb-0 fs-7">Danh sách người nước ngoài đang sinh sống và cư trú thực tế trong địa bàn phụ trách của Công an phường/xã</p>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-body p-4">
            <!-- Search Form -->
            <form asp-action="TraCuu" method="get" class="mb-4">
                <div class="row g-3">
                    <div class="col-md-9">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" name="search" class="form-control border-start-0" value="@ViewBag.Search" placeholder="Tìm theo họ tên, số hộ chiếu, địa chỉ tạm trú..." style="border-radius: 0 8px 8px 0;" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-success w-100 fw-semibold" style="border-radius: 8px;">Tìm kiếm</button>
                    </div>
                </div>

                <!-- Advanced Filter Toggle -->
                <div class="mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-xs text-success" data-bs-toggle="collapse" data-bs-target="#advancedFilterCollapse" aria-expanded="@expandedVal">
                        <i class="bi bi-sliders me-1"></i> Bộ lọc nâng cao
                    </button>
                </div>

                <!-- Collapsible Panel -->
                <div class="collapse @collapseClass" id="advancedFilterCollapse">
                    <div class="card card-body bg-light border-0 mt-3 p-3" style="border-radius: 12px;">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-muted">Quốc tịch</label>
                                <select name="quocTich" class="form-select" style="border-radius: 8px;">
                                    <option value="">-- Tất cả quốc tịch --</option>
                                    @if (nationalities != null)
                                    {
                                        foreach (var nationality in nationalities)
                                        {
                                            if (nationality == ViewBag.SelectedQuocTich)
                                            {
                                                <option value="@nationality" selected="selected">@nationality</option>
                                            }
                                            else
                                            {
                                                <option value="@nationality">@nationality</option>
                                            }
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-muted">Loại Visa</label>
                                <select name="loaiVisa" class="form-select" style="border-radius: 8px;">
                                    <option value="">-- Tất cả loại Visa --</option>
                                    @if (visaTypes != null)
                                    {
                                        foreach (var visa in visaTypes)
                                        {
                                            if (visa == ViewBag.SelectedLoaiVisa)
                                            {
                                                <option value="@visa" selected="selected">@visa</option>
                                            }
                                            else
                                            {
                                                <option value="@visa">@visa</option>
                                            }
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">Không tìm thấy người nước ngoài nào đang cư trú tại địa bàn @ViewBag.TenDiaBan.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="police-table-themed align-middle mb-0 fs-7">
                        <thead>
                            <tr>
                                <th>Mã NNN</th>
                                <th>Họ và tên</th>
                                <th>Số hộ chiếu</th>
                                <th>Quốc tịch</th>
                                <th>Loại Visa</th>
                                <th>Nơi cư trú địa bàn</th>
                                <th class="text-center">Thao tác nhanh</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var foreigner in Model)
                            {
                                <tr>
                                    <td><code class="text-secondary fw-semibold">@foreigner.MaNguoiNuocNgoai</code></td>
                                    <td class="fw-bold text-dark">@foreigner.HoTen</td>
                                    <td>@foreigner.SoHoChieu</td>
                                    <td>@foreigner.QuocTich</td>
                                    <td><span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-20 px-2 py-1">@foreigner.LoaiVisa</span></td>
                                    <td><small class="text-muted">@foreigner.NoiCuTruHienTai</small></td>
                                    <td class="text-center">
                                         <div class="dropdown">
                                             <button class="btn btn-outline-secondary border-0 p-1 btn-xs" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                 <i class="bi bi-three-dots"></i>
                                             </button>
                                             <ul class="dropdown-menu dropdown-menu-end shadow-sm border" style="border-radius: 8px; font-size: 0.85rem;">
                                                 <li>
                                                     <a class="dropdown-item py-2 text-warning fw-semibold" asp-action="CanhBaoViPham" asp-route-maNguoiNuocNgoai="@foreigner.MaNguoiNuocNgoai">
                                                         <i class="bi bi-exclamation-triangle me-2 text-warning"></i>Gửi cảnh báo
                                                     </a>
                                                 </li>
                                                 <li>
                                                     <a class="dropdown-item py-2 text-danger fw-semibold" asp-action="BaoCaoViPham" asp-route-maNguoiNuocNgoai="@foreigner.MaNguoiNuocNgoai">
                                                         <i class="bi bi-flag me-2 text-danger"></i>Báo cáo XNC
                                                     </a>
                                                 </li>
                                             </ul>
                                         </div>
                                     </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-4">
                    @Html.PagedListPager(Model, page => Url.Action("TraCuu", new { page, search = ViewBag.Search, quocTich = ViewBag.SelectedQuocTich, loaiVisa = ViewBag.SelectedLoaiVisa }),
                        new X.PagedList.Mvc.Core.PagedListRenderOptions {
                            LiElementClasses = new string[] { "page-item" },
                            PageClasses = new string[] { "page-link" },
                            UlElementClasses = new string[] { "pagination", "pagination-sm" }
                        })
                </div>
            }
        </div>
    </div>
</div>
