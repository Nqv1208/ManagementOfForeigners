@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.HoSoKhaiBaoTamTru>
@{
    Layout = "~/Views/Shared/_PoliceLayout.cshtml";
    ViewBag.Title = "Danh sách khai báo tạm trú";
}

<div class="container-fluid">
    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-header bg-success text-white p-4" style="background-color: var(--police-primary) !important;">
            <h5 class="fw-bold mb-0">Quản lý khai báo tạm trú - Địa bàn @ViewBag.TenDiaBan</h5>
            <p class="text-white-50 mb-0 fs-7">Phê duyệt, từ chối và kiểm tra hồ sơ khai báo tạm trú của người nước ngoài</p>
        </div>

        <div class="card-body p-4">
            <!-- Filter Form & Tabs -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
                <div class="btn-group shadow-sm" role="group" aria-label="Status Filter" style="border-radius: 8px; overflow: hidden;">
                    <a asp-action="DanhSachKhaiBao" asp-route-trangThai="Chờ duyệt" class="btn @(ViewBag.TrangThai == "Chờ duyệt" ? "btn-success text-white" : "btn-light text-dark") fw-semibold px-3 py-2 fs-8">
                        <i class="bi bi-clock-history"></i> Chờ duyệt
                    </a>
                    <a asp-action="DanhSachKhaiBao" asp-route-trangThai="Đã duyệt" class="btn @(ViewBag.TrangThai == "Đã duyệt" ? "btn-success text-white" : "btn-light text-dark") fw-semibold px-3 py-2 fs-8">
                        <i class="bi bi-check-circle"></i> Đã duyệt
                    </a>
                    <a asp-action="DanhSachKhaiBao" asp-route-trangThai="Từ chối" class="btn @(ViewBag.TrangThai == "Từ chối" ? "btn-success text-white" : "btn-light text-dark") fw-semibold px-3 py-2 fs-8">
                        <i class="bi bi-x-circle"></i> Từ chối
                    </a>
                </div>

                <!-- Search Input -->
                <form asp-action="DanhSachKhaiBao" method="get" class="d-flex gap-2">
                    <input type="hidden" name="trangThai" value="@ViewBag.TrangThai" />
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" value="@ViewBag.Search" placeholder="Họ tên, số hộ chiếu..." style="border-radius: 0 8px 8px 0;" />
                    </div>
                    <button type="submit" class="btn btn-primary fw-semibold" style="border-radius: 8px;">Tìm</button>
                </form>
            </div>



            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-file-earmark-x text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">Không tìm thấy hồ sơ khai báo tạm trú nào.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 fs-7">
                        <thead>
                            <tr class="table-gov-header">
                                <th>Mã hồ sơ</th>
                                <th>Khách nước ngoài</th>
                                <th>Số hộ chiếu</th>
                                <th>Quốc tịch</th>
                                <th>Ngày khai báo</th>
                                <th>Thời gian tạm trú</th>
                                <th>Địa chỉ lưu trú</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dec in Model)
                            {
                                <tr>
                                    <td><code class="text-secondary fw-semibold">@dec.MaHSKhaiBao</code></td>
                                    <td class="fw-bold text-dark">@dec.TaiKhoan.NguoiNuocNgoai?.HoTen</td>
                                    <td>@dec.TaiKhoan.NguoiNuocNgoai?.SoHoChieu</td>
                                    <td>@dec.TaiKhoan.NguoiNuocNgoai?.QuocTich</td>
                                    <td>@dec.NgayKhaiBao.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <small class="d-block fw-semibold text-dark">
                                            @dec.NgayBatDau.ToString("dd/MM/yyyy") - @dec.NgayKetThuc.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        <small class="text-muted style-multiline-ellipsis" style="max-width: 180px; display: inline-block;">
                                            @dec.DiaChiLuuTru
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        @await Html.PartialAsync("_StatusBadge", dec.TrangThai)
                                    </td>
                                     <td class="text-center">
                                         <div class="d-inline-flex gap-1 align-items-center justify-content-center">
                                             <a asp-action="ChiTietKhaiBao" asp-route-id="@dec.MaHSKhaiBao" class="btn btn-outline-primary btn-xs" style="border-radius: 6px; font-size: 0.75rem;">
                                                 <i class="bi bi-eye"></i> Chi tiết
                                             </a>
                                             @if (dec.TrangThai == "Chờ duyệt")
                                             {
                                                 <form asp-action="PheDuyet" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn phê duyệt hồ sơ khai báo này?');" style="display:inline-block; margin: 0;">
                                                     @Html.AntiForgeryToken()
                                                     <input type="hidden" name="id" value="@dec.MaHSKhaiBao" />
                                                     <button type="submit" class="btn btn-success btn-xs fw-semibold text-white px-2 py-1" style="border-radius: 6px; font-size: 0.75rem; border: none; background-color: var(--primary);">
                                                         <i class="bi bi-check-circle"></i> Duyệt
                                                     </button>
                                                 </form>
                                                 
                                                 <button type="button" class="btn btn-danger btn-xs fw-semibold text-white px-2 py-1 quick-reject-btn" 
                                                         data-id="@dec.MaHSKhaiBao" 
                                                         data-bs-toggle="modal" 
                                                         data-bs-target="#quickRejectModal" 
                                                         style="border-radius: 6px; font-size: 0.75rem; border: none; background-color: var(--danger);">
                                                     <i class="bi bi-x-circle"></i> Từ chối
                                                 </button>
                                             }
                                         </div>
                                     </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-4">
                    @Html.PagedListPager(Model, page => Url.Action("DanhSachKhaiBao", new { page, search = ViewBag.Search, trangThai = ViewBag.TrangThai }),
                        new X.PagedList.Mvc.Core.PagedListRenderOptions {
                            LiElementClasses = new string[] { "page-item" },
                            PageClasses = new string[] { "page-link" },
                            UlElementClasses = new string[] { "pagination", "pagination-sm" }
                        })
                </div>
            }
        </div>
    </div>
</div>

<!-- Quick Reject Modal -->
<div class="modal fade" id="quickRejectModal" tabindex="-1" aria-labelledby="quickRejectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 12px; overflow: hidden; border: none;">
            <div class="modal-header bg-danger text-white">
                <h6 class="modal-title fw-bold" id="quickRejectModalLabel"><i class="bi bi-exclamation-triangle-fill me-1"></i>Từ chối phê duyệt hồ sơ</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="TuChoi" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="MaHSKhaiBao" id="quickRejectId" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-dark fs-7">Lý do từ chối</label>
                        <textarea name="LyDoTuChoi" class="form-control" rows="3" placeholder="Nhập lý do từ chối (Ví dụ: Thiếu thông tin, sai số hộ chiếu...)" style="border-radius: 8px;" required></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="background-color: #f8fafc;">
                    <button type="button" class="btn btn-outline-secondary btn-sm px-3 py-1.5 fw-semibold" data-bs-dismiss="modal" style="border-radius: 6px; font-size: 0.85rem;">Hủy</button>
                    <button type="submit" class="btn btn-danger btn-sm px-3 py-1.5 fw-semibold" style="border-radius: 6px; font-size: 0.85rem;">Xác nhận từ chối</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.quick-reject-btn').click(function() {
                var id = $(this).data('id');
                $('#quickRejectId').val(id);
            });
        });
    </script>
}
