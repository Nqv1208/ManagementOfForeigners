@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.HoSoKhaiBaoTamTru>
@{
    Layout = "~/Views/Shared/_PoliceLayout.cshtml";
    ViewBag.Title = "Danh sách khai báo tạm trú";
}

<div class="container-fluid">
    <div class="police-page-header mb-4">
        <h5 class="fw-bold mb-1" style="color: var(--police-primary-dark);">Quản lý khai báo tạm trú - Địa bàn @ViewBag.TenDiaBan</h5>
        <p class="text-muted mb-0 fs-7">Phê duyệt, từ chối và kiểm tra hồ sơ khai báo tạm trú của người nước ngoài</p>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-body p-4">
            <!-- Filter Form & Tabs -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
                <div class="filter-tabs" role="group" aria-label="Status Filter">
                    <a asp-action="DanhSachKhaiBao" asp-route-trangThai="Chờ duyệt" class="filter-tab @(ViewBag.TrangThai == "Chờ duyệt" ? "active" : "") text-decoration-none">
                        <i class="bi bi-clock-history"></i> Chờ duyệt (@ViewBag.CountPending)
                    </a>
                    <a asp-action="DanhSachKhaiBao" asp-route-trangThai="Đã duyệt" class="filter-tab @(ViewBag.TrangThai == "Đã duyệt" ? "active" : "") text-decoration-none">
                        <i class="bi bi-check-circle"></i> Đã duyệt (@ViewBag.CountApproved)
                    </a>
                    <a asp-action="DanhSachKhaiBao" asp-route-trangThai="Từ chối" class="filter-tab @(ViewBag.TrangThai == "Từ chối" ? "active" : "") text-decoration-none">
                        <i class="bi bi-x-circle"></i> Từ chối (@ViewBag.CountRejected)
                    </a>
                </div>

                <!-- Search Input -->
                <form asp-action="DanhSachKhaiBao" method="get" class="d-flex gap-2">
                    <input type="hidden" name="trangThai" value="@ViewBag.TrangThai" />
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" value="@ViewBag.Search" placeholder="Họ tên, số hộ chiếu..." style="border-radius: 0 8px 8px 0;" />
                    </div>
                    <button type="submit" class="btn btn-primary fw-semibold" style="border-radius: 8px;">Tìm</button>
                </form>
            </div>



            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-file-earmark-x text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">Không tìm thấy hồ sơ khai báo tạm trú nào.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="police-table-themed align-middle mb-0 fs-7">
                        <thead>
                            <tr>
                                <th>Hồ sơ</th>
                                <th>Người khai báo</th>
                                <th>Lưu trú</th>
                                <th>Thời gian</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dec in Model)
                            {
                                <tr>
                                    <td>
                                        <code class="text-secondary fw-semibold">@dec.MaHSKhaiBao</code>
                                        <div class="text-muted small mt-1">Ngày nộp: @dec.NgayKhaiBao.ToString("dd/MM/yyyy")</div>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark">@dec.TaiKhoan.NguoiNuocNgoai?.HoTen</div>
                                        <div class="text-muted small mt-1">
                                            HC: @(dec.TaiKhoan.NguoiNuocNgoai?.SoHoChieu ?? "N/A") | 
                                            <span class="badge bg-light text-dark">@(dec.TaiKhoan.NguoiNuocNgoai?.QuocTich ?? "N/A")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="style-multiline-ellipsis text-muted" style="max-width: 250px; display: inline-block;">
                                            @dec.DiaChiLuuTru
                                        </div>
                                        @if (dec.CoSoLuuTru != null)
                                        {
                                            <div class="text-success small mt-1">
                                                Cơ sở: @dec.CoSoLuuTru.TenCoSo
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <div class="small text-muted">
                                            @dec.NgayBatDau.ToString("dd/MM/yyyy") đến @dec.NgayKetThuc.ToString("dd/MM/yyyy")
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @await Html.PartialAsync("_StatusBadge", dec.TrangThai)
                                    </td>
                                    <td class="text-center">
                                        <div class="dropdown">
                                            <button class="btn btn-outline-secondary border-0 p-1 btn-xs" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" asp-action="ChiTietKhaiBao" asp-route-id="@dec.MaHSKhaiBao">
                                                        <i class="bi bi-eye me-2"></i>Xem chi tiết
                                                    </a>
                                                </li>
                                                @if (dec.TrangThai == "Chờ duyệt")
                                                {
                                                    <li>
                                                        <form asp-action="PheDuyet" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn phê duyệt hồ sơ khai báo này?');" class="d-block">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@dec.MaHSKhaiBao" />
                                                            <button type="submit" class="dropdown-item text-success">
                                                                <i class="bi bi-check-circle me-2"></i>Phê duyệt nhanh
                                                            </button>
                                                        </form>
                                                    </li>
                                                    <li>
                                                        <button type="button" class="dropdown-item text-danger quick-reject-btn" 
                                                                data-id="@dec.MaHSKhaiBao" 
                                                                data-bs-toggle="modal" 
                                                                data-bs-target="#quickRejectModal">
                                                            <i class="bi bi-x-circle me-2"></i>Từ chối nhanh
                                                        </button>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-4">
                    @Html.PagedListPager(Model, page => Url.Action("DanhSachKhaiBao", new { page, search = ViewBag.Search, trangThai = ViewBag.TrangThai }),
                        new X.PagedList.Mvc.Core.PagedListRenderOptions {
                            LiElementClasses = new string[] { "page-item" },
                            PageClasses = new string[] { "page-link" },
                            UlElementClasses = new string[] { "pagination", "pagination-sm" }
                        })
                </div>
            }
        </div>
    </div>
</div>

<!-- Quick Reject Modal -->
<div class="modal fade" id="quickRejectModal" tabindex="-1" aria-labelledby="quickRejectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 12px; overflow: hidden; border: none;">
            <div class="modal-header bg-danger text-white">
                <h6 class="modal-title fw-bold" id="quickRejectModalLabel"><i class="bi bi-exclamation-triangle-fill me-1"></i>Từ chối phê duyệt hồ sơ</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="TuChoi" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="MaHSKhaiBao" id="quickRejectId" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-dark fs-7">Lý do từ chối</label>
                        <textarea name="LyDoTuChoi" class="form-control" rows="3" placeholder="Nhập lý do từ chối (Ví dụ: Thiếu thông tin, sai số hộ chiếu...)" style="border-radius: 8px;" required></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="background-color: #f8fafc;">
                    <button type="button" class="btn btn-outline-secondary btn-sm px-3 py-1.5 fw-semibold" data-bs-dismiss="modal" style="border-radius: 6px; font-size: 0.85rem;">Hủy</button>
                    <button type="submit" class="btn btn-danger btn-sm px-3 py-1.5 fw-semibold" style="border-radius: 6px; font-size: 0.85rem;">Xác nhận từ chối</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.quick-reject-btn').click(function() {
                var id = $(this).data('id');
                $('#quickRejectId').val(id);
            });
        });
    </script>
}
