@model ManagementOfForeigners.Models.ViewModels.CanBo.CanhBaoViewModel
@{
    Layout = "~/Views/Shared/_OfficerLayout.cshtml";
    ViewBag.Title = "Gửi cảnh báo vi phạm";
}

<div class="officer-page-header mb-4">
    <div>
        <h4>Gửi Cảnh Báo Vi Phạm</h4>
        <p class="text-muted mb-0">Ban hành và gửi cảnh báo vi phạm cư trú, xuất nhập cảnh cho người nước ngoài</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="card border-0 shadow-sm" style="border-radius: 14px; border: 1px solid var(--color-border) !important;">
            <div class="card-body p-4">
                <form asp-action="CanhBaoViPham" method="post" class="needs-validation">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                    <div class="row g-3">
                        <!-- Người nước ngoài -->
                        <div class="col-md-12">
                            <label asp-for="MaNguoiNuocNgoai" class="form-label fw-semibold text-dark fs-7">Người nước ngoài liên quan</label>
                            <select asp-for="MaNguoiNuocNgoai" asp-items="ViewBag.NguoiNuocNgoais" class="form-select" style="border-radius: 8px; height: 42px; font-size: 0.88rem;">
                                <option value="">-- Chọn người nước ngoài liên quan --</option>
                            </select>
                            <span asp-validation-for="MaNguoiNuocNgoai" class="text-danger small"></span>
                        </div>

                        <!-- Loại vi phạm -->
                        <div class="col-md-8">
                            <label asp-for="LoaiViPham" class="form-label fw-semibold text-dark fs-7">Hành vi vi phạm</label>
                            <input asp-for="LoaiViPham" class="form-control" placeholder="Ví dụ: Quá hạn tạm trú, Chưa khai báo di chuyển..." style="border-radius: 8px; height: 42px; font-size: 0.88rem;" />
                            <span asp-validation-for="LoaiViPham" class="text-danger small"></span>
                        </div>

                        <!-- Mức độ vi phạm -->
                        <div class="col-md-4">
                            <label asp-for="MucDoViPham" class="form-label fw-semibold text-dark fs-7">Mức độ</label>
                            <select asp-for="MucDoViPham" class="form-select" style="border-radius: 8px; height: 42px; font-size: 0.88rem;">
                                <option value="">-- Mức độ --</option>
                                <option value="Nhẹ">Nhẹ</option>
                                <option value="Trung bình">Trung bình</option>
                                <option value="Nghiêm trọng">Nghiêm trọng</option>
                            </select>
                            <span asp-validation-for="MucDoViPham" class="text-danger small"></span>
                        </div>

                        <!-- Nội dung cảnh báo -->
                        <div class="col-12">
                            <label asp-for="NoiDungCanhBao" class="form-label fw-semibold text-dark fs-7">Nội dung cảnh báo chi tiết</label>
                            <textarea asp-for="NoiDungCanhBao" class="form-control" rows="4" placeholder="Mô tả cụ thể hành vi vi phạm và hình thức xử lý..." style="border-radius: 8px; font-size: 0.88rem;"></textarea>
                            <span asp-validation-for="NoiDungCanhBao" class="text-danger small"></span>
                        </div>

                        <!-- Ghi chú -->
                        <div class="col-12">
                            <label asp-for="GhiChu" class="form-label fw-semibold text-dark fs-7">Ghi chú bổ sung</label>
                            <textarea asp-for="GhiChu" class="form-control" rows="2" placeholder="Ghi chú thêm (nếu có)..." style="border-radius: 8px; font-size: 0.88rem;"></textarea>
                            <span asp-validation-for="GhiChu" class="text-danger small"></span>
                        </div>

                        <div class="col-12 d-flex justify-content-between mt-4">
                            <a asp-action="ViPhamCanhBao" class="btn btn-outline-secondary px-4 fw-semibold" style="border-radius: 8px; height: 40px; display: inline-flex; align-items: center;">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-success px-4 fw-semibold" style="border-radius: 8px; height: 40px;">
                                <i class="bi bi-send me-1"></i> Gửi cảnh báo
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
