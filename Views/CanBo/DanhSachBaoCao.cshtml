@using X.PagedList.Mvc.Core
@using X.PagedList
@using ManagementOfForeigners.Models.Entities
@model IPagedList<ManagementOfForeigners.Models.Entities.BaoCaoViPham>

@{
    ViewBag.Title = "Tiếp nhận báo cáo vi phạm";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-header gov-card-header p-4">
            <h5 class="fw-bold mb-0">Tiếp nhận và xử lý báo cáo vi phạm</h5>
            <p class="text-white-50 mb-0 fs-7">Báo cáo do Công an Phường/Xã gửi lên Phòng Quản lý Xuất nhập cảnh.</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="DanhSachBaoCao" method="get" class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" value="@ViewBag.Search" placeholder="Họ tên, hộ chiếu, nội dung báo cáo..." style="border-radius: 0 8px 8px 0;" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="trangThai" class="form-select" style="border-radius: 8px;">
                        <option value="">Tất cả trạng thái</option>
                        <option value="@TrangThaiXuLyConst.ChuaXuLy" selected="@(ViewBag.TrangThai == TrangThaiXuLyConst.ChuaXuLy)">@TrangThaiXuLyConst.ChuaXuLy</option>
                        <option value="@TrangThaiXuLyConst.DangXuLy" selected="@(ViewBag.TrangThai == TrangThaiXuLyConst.DangXuLy)">@TrangThaiXuLyConst.DangXuLy</option>
                        <option value="@TrangThaiXuLyConst.DaXuLy" selected="@(ViewBag.TrangThai == TrangThaiXuLyConst.DaXuLy)">@TrangThaiXuLyConst.DaXuLy</option>
                    </select>
                </div>
                <div class="col-md-3 d-grid">
                    <button class="btn btn-primary fw-semibold" type="submit" style="border-radius: 8px;">Lọc báo cáo</button>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-flag text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">Không có báo cáo vi phạm phù hợp.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 fs-7">
                        <thead>
                            <tr>
                                <th>Ngày báo cáo</th>
                                <th>Người nước ngoài</th>
                                <th>Công an gửi</th>
                                <th>Nội dung</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Xử lý</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var report in Model)
                            {
                                <tr>
                                    <td>@report.NgayBaoCao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <div class="fw-bold">@report.NguoiNuocNgoai.HoTen</div>
                                        <small class="text-muted">HC: @report.NguoiNuocNgoai.SoHoChieu</small>
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@report.CanBo.HoTen</div>
                                        <small class="text-muted">@report.CanBo.PhuongXa.TenPhuongXa</small>
                                    </td>
                                    <td style="max-width: 360px;">@report.NoiDungBaoCao</td>
                                    <td>@await Html.PartialAsync("_StatusBadge", report.TrangThaiXuLy)</td>
                                    <td class="text-end">
                                        <form asp-action="CapNhatTrangThaiBaoCao" method="post" class="d-inline-flex gap-2" onsubmit="return confirm('Cập nhật trạng thái báo cáo này?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@report.MaBaoCao" />
                                            <select name="trangThai" class="form-select form-select-sm" style="width: 140px;">
                                                <option value="@TrangThaiXuLyConst.ChuaXuLy" selected="@(report.TrangThaiXuLy == TrangThaiXuLyConst.ChuaXuLy)">@TrangThaiXuLyConst.ChuaXuLy</option>
                                                <option value="@TrangThaiXuLyConst.DangXuLy" selected="@(report.TrangThaiXuLy == TrangThaiXuLyConst.DangXuLy)">@TrangThaiXuLyConst.DangXuLy</option>
                                                <option value="@TrangThaiXuLyConst.DaXuLy" selected="@(report.TrangThaiXuLy == TrangThaiXuLyConst.DaXuLy)">@TrangThaiXuLyConst.DaXuLy</option>
                                            </select>
                                            <button class="btn btn-sm btn-primary" type="submit">Lưu</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-center mt-4">
                    @Html.PagedListPager(Model, page => Url.Action("DanhSachBaoCao", new { page, search = ViewBag.Search, trangThai = ViewBag.TrangThai }),
                        new X.PagedList.Mvc.Core.PagedListRenderOptions {
                            LiElementClasses = new string[] { "page-item" },
                            PageClasses = new string[] { "page-link" },
                            UlElementClasses = new string[] { "pagination", "pagination-sm" }
                        })
                </div>
            }
        </div>
    </div>
</div>
