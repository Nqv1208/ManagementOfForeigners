@model ManagementOfForeigners.Models.ViewModels.CanBo.TongQuanViewModel
@{
    Layout = "~/Views/Shared/_OfficerLayout.cshtml";
    ViewBag.Title = "Tổng quan nghiệp vụ";
}

<div class="officer-page-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h4>Tổng Quan Nghiệp Vụ</h4>
            <p class="text-muted mb-0">Hồ sơ nghiệp vụ, tra cứu, xử lý vi phạm và giám sát lưu trú người nước ngoài</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="TraCuu" class="btn btn-success fw-semibold px-3 py-2" style="border-radius: 8px;">
                <i class="bi bi-search me-1"></i> Tra cứu nhanh
            </a>
            <a asp-action="ThongKe" class="btn btn-outline-success fw-semibold px-3 py-2" style="border-radius: 8px;">
                <i class="bi bi-graph-up-arrow me-1"></i> Thống kê
            </a>
        </div>
    </div>
</div>

<!-- 4 Stat Cards -->
<div class="row g-4 mb-4">
    <!-- Total Stays -->
    <div class="col-xl-3 col-md-6">
        <div class="officer-stat-card is-info">
            <div class="stat-content">
                <span class="stat-label">Đang tạm trú</span>
                <span class="stat-value">@Model.ActiveStaysCount</span>
            </div>
            <div class="stat-icon">
                <i class="bi bi-people-fill"></i>
            </div>
        </div>
    </div>

    <!-- New Declarations -->
    <div class="col-xl-3 col-md-6">
        <div class="officer-stat-card is-success">
            <div class="stat-content">
                <span class="stat-label">Khai báo mới (7 ngày)</span>
                <span class="stat-value">@Model.NewDeclarationsCount</span>
            </div>
            <div class="stat-icon">
                <i class="bi bi-file-earmark-text-fill"></i>
            </div>
        </div>
    </div>

    <!-- Review Needed -->
    <div class="col-xl-3 col-md-6">
        <div class="officer-stat-card is-warning">
            <div class="stat-content">
                <span class="stat-label">Yêu cầu rà soát</span>
                <span class="stat-value">@Model.ReviewNeededCount</span>
            </div>
            <div class="stat-icon">
                <i class="bi bi-exclamation-octagon-fill"></i>
            </div>
        </div>
    </div>

    <!-- Pending Reports -->
    <div class="col-xl-3 col-md-6">
        <div class="officer-stat-card is-danger">
            <div class="stat-content">
                <span class="stat-label">Báo cáo chờ xử lý</span>
                <span class="stat-value">@Model.PendingReportsCount</span>
            </div>
            <div class="stat-icon">
                <i class="bi bi-flag-fill"></i>
            </div>
        </div>
    </div>
</div>

<!-- 2 Columns: Review Needed Declarations & Pending Reports -->
<div class="row g-4 mb-4">
    <!-- Left Column: Review Needed Declarations -->
    <div class="col-lg-7">
        <div class="officer-table-card h-100">
            <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                <span class="cell-title" style="font-size: 1rem;">Khai báo cần rà soát</span>
                <span class="badge-custom badge-warning">Cần xử lý gấp</span>
            </div>
            <div class="card-body p-4">
                @if (!Model.ReviewNeededDeclarations.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-clipboard-check text-muted mb-2" style="font-size: 2.2rem; display: block;"></i>
                        <span class="cell-title d-block mb-1">Không có hồ sơ cần rà soát</span>
                        <span class="cell-sub d-block">Tất cả hồ sơ hiện đã được xử lý hoặc chưa phát sinh yêu cầu mới.</span>
                    </div>
                }
                else
                {
                    <div class="officer-table-wrap">
                        <table class="officer-table" style="min-width: 500px;">
                            <thead>
                                <tr>
                                    <th>Khách / Hộ chiếu</th>
                                    <th>Cơ sở tạm trú</th>
                                    <th>Ngày khai</th>
                                    <th class="text-end" style="width: 80px;">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dec in Model.ReviewNeededDeclarations)
                                {
                                    var foreignerName = dec.TaiKhoan?.NguoiNuocNgoai?.HoTen ?? "N/A";
                                    var passport = dec.TaiKhoan?.NguoiNuocNgoai?.SoHoChieu ?? "N/A";
                                    var fId = dec.TaiKhoan?.NguoiNuocNgoai?.MaNguoiNuocNgoai ?? "";
                                    <tr>
                                        <td>
                                            <div class="cell-title">@foreignerName</div>
                                            <div class="cell-sub">Hộ chiếu: @passport</div>
                                        </td>
                                        <td>
                                            <div class="text-truncate" style="max-width: 180px;" title="@dec.CoSoLuuTru.TenCoSo">@dec.CoSoLuuTru.TenCoSo</div>
                                        </td>
                                        <td>@dec.NgayKhaiBao.ToString("dd/MM/yyyy")</td>
                                        <td class="text-end">
                                            <div class="dropdown">
                                                <button class="btn btn-link text-secondary p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border" style="border-radius: 8px; font-size: 0.85rem;">
                                                    <li>
                                                        <a class="dropdown-item py-2" asp-action="HoSoTamTru" asp-route-search="@passport">
                                                            <i class="bi bi-file-earmark-text me-2 text-primary"></i> Xem chi tiết hồ sơ
                                                        </a>
                                                    </li>
                                                    @if (!string.IsNullOrEmpty(fId))
                                                    {
                                                        <li>
                                                            <a class="dropdown-item py-2" asp-action="ChiTietNguoiNuocNgoai" asp-route-id="@fId">
                                                                <i class="bi bi-person me-2 text-success"></i> Xem hồ sơ NNN
                                                            </a>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column: Pending Reports -->
    <div class="col-lg-5">
        <div class="officer-table-card h-100">
            <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                <span class="cell-title" style="font-size: 1rem;">Báo cáo vi phạm từ địa bàn</span>
                <a asp-action="DanhSachBaoCao" class="text-decoration-none fs-8 fw-semibold text-success">Tất cả <i class="bi bi-chevron-right fs-9"></i></a>
            </div>
            <div class="card-body p-4">
                @if (!Model.PendingReports.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-shield-check text-muted mb-2" style="font-size: 2.2rem; display: block;"></i>
                        <span class="cell-title d-block mb-1">Chưa có báo cáo vi phạm</span>
                        <span class="cell-sub d-block">Không có tin báo vi phạm mới cần phê duyệt từ Công an xã/phường.</span>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var report in Model.PendingReports)
                        {
                            <div class="p-3 rounded-3 d-flex align-items-start gap-3" style="background-color: #f8fafc; border: 1px solid var(--color-border);">
                                <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-2 fs-5 d-inline-flex align-items-center justify-content-center" style="width: 36px; height: 36px; min-width: 36px;">
                                    <i class="bi bi-flag-fill" style="font-size: 16px;"></i>
                                </div>
                                <div class="w-100">
                                    <div class="d-flex justify-content-between flex-wrap gap-2 mb-1">
                                        <span class="fw-bold text-dark fs-7">@report.NguoiNuocNgoai.HoTen</span>
                                        <small class="text-muted fs-8">@report.NgayBaoCao.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <div class="text-muted fs-8 mb-2">
                                        Gửi từ: <span class="text-dark fw-semibold">@report.CanBo.HoTen (@report.CanBo.PhuongXa.TenPhuongXa)</span>
                                    </div>
                                    <p class="mb-0 text-secondary fs-8 cell-truncate" style="line-height: 1.4;">@report.NoiDungBaoCao</p>
                                    <div class="text-end mt-2">
                                        <a asp-action="DanhSachBaoCao" asp-route-search="@report.NguoiNuocNgoai.SoHoChieu" class="btn btn-xs btn-outline-danger py-1 px-2.5 fw-semibold" style="font-size: 0.75rem; border-radius: 6px;">
                                            Xử lý báo cáo
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Risky Facilities Table -->
<div class="officer-table-card mb-4">
    <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
        <div>
            <span class="cell-title" style="font-size: 1rem; display: block;">Cơ sở lưu trú rủi ro trung bình / cao</span>
            <p class="text-muted mb-0 fs-8">Đánh giá dựa trên số vụ vi phạm cư trú phát sinh tại cơ sở</p>
        </div>
        <span class="badge-custom badge-danger">
            Số cơ sở: @Model.RiskyFacilitiesCount
        </span>
    </div>
    <div class="card-body p-4">
        @if (!Model.RiskyFacilities.Any())
        {
            <div class="text-center py-4">
                <div class="status-icon status-icon--success status-icon--md mx-auto mb-2">
                    <div class="status-icon__inner">
                        <i class="bi bi-check-lg"></i>
                    </div>
                </div>
                <span class="cell-title d-block mb-1">Không có cơ sở rủi ro</span>
                <span class="cell-sub d-block">Hiện tại không phát hiện cơ sở lưu trú nào ở mức cảnh báo trung bình/cao.</span>
            </div>
        }
        else
        {
            <div class="officer-table-wrap">
                <table class="officer-table">
                    <thead>
                        <tr>
                            <th>Tên cơ sở lưu trú</th>
                            <th>Địa bàn (Phường/Xã)</th>
                            <th class="text-center">Đang tạm trú</th>
                            <th class="text-center">Tổng hồ sơ</th>
                            <th class="text-center">Số vi phạm</th>
                            <th>Mức rủi ro</th>
                            <th class="text-center" style="width: 140px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var facility in Model.RiskyFacilities)
                        {
                            var riskClass = facility.MucRuiRo == "Cao" ? "badge-danger" : "badge-warning";
                            <tr>
                                <td class="fw-bold text-dark">@facility.TenCoSo</td>
                                <td>@facility.PhuongXa</td>
                                <td class="text-center fw-semibold text-secondary">@facility.SoKhachDangO</td>
                                <td class="text-center text-muted">@facility.TongHoSo</td>
                                <td class="text-center text-danger fw-bold">@facility.TongViPham</td>
                                <td>
                                    <span class="badge-custom @riskClass">
                                        <i class="bi bi-shield-exclamation me-1"></i>@facility.MucRuiRo
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="CoSoLuuTru" asp-route-search="@facility.TenCoSo" class="btn btn-xs btn-outline-success fw-semibold">
                                        Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
