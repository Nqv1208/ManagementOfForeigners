@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.NguoiNuocNgoai>
@{
    ViewBag.Title = "Tra cứu người nước ngoài";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-header gov-card-header p-4">
            <h5 class="fw-bold mb-0">Tra cứu thông tin người nước ngoài</h5>
            <p class="text-white-50 mb-0 fs-7">Tìm kiếm, lọc danh sách người nước ngoài đang hoạt động trên địa bàn thành phố</p>
        </div>

        <div class="card-body p-4">
            <!-- Filter Form -->
            <form asp-action="TraCuu" method="get" class="row g-3 mb-4">
                <div class="col-lg-4 col-md-12">
                    <label class="form-label fw-semibold text-dark fs-7">Tìm kiếm nhanh</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" value="@ViewBag.Search" placeholder="Tìm theo họ tên, số hộ chiếu, nơi cư trú..." style="border-radius: 0 8px 8px 0;" />
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-semibold text-dark fs-7">Quốc tịch</label>
                    <select name="quocTich" class="form-select" style="border-radius: 8px;">
                        <option value="">-- Tất cả quốc tịch --</option>
                        @foreach (var nation in ViewBag.Nationalities)
                        {
                            @if (ViewBag.QuocTich == nation)
                            {
                                <option value="@nation" selected>@nation</option>
                            }
                            else
                            {
                                <option value="@nation">@nation</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-semibold text-dark fs-7">Loại Visa</label>
                    <select name="loaiVisa" class="form-select" style="border-radius: 8px;">
                        <option value="">-- Tất cả loại visa --</option>
                        @foreach (var visa in ViewBag.VisaTypes)
                        {
                            @if (ViewBag.LoaiVisa == visa)
                            {
                                <option value="@visa" selected>@visa</option>
                            }
                            else
                            {
                                <option value="@visa">@visa</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-lg-2 col-md-12 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100 fw-semibold" style="border-radius: 8px; height: 38px;">
                        <i class="bi bi-funnel-fill me-1"></i> Lọc kết quả
                    </button>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-search-heart text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">Không tìm thấy người nước ngoài nào phù hợp với điều kiện tìm kiếm.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 fs-7">
                        <thead>
                            <tr class="table-gov-header">
                                <th>Mã NNN</th>
                                <th>Họ và tên</th>
                                <th>Số hộ chiếu</th>
                                <th>Quốc tịch</th>
                                <th>Loại Visa</th>
                                <th>Thời hạn Visa</th>
                                <th>Nơi cư trú hiện tại</th>
                                <th class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var foreigner in Model)
                            {
                                <tr>
                                    <td><code class="text-secondary fw-semibold">@foreigner.MaNguoiNuocNgoai</code></td>
                                    <td class="fw-bold text-dark">@foreigner.HoTen</td>
                                    <td>@foreigner.SoHoChieu</td>
                                    <td>@foreigner.QuocTich</td>
                                    <td><span class="badge bg-secondary">@foreigner.LoaiVisa</span></td>
                                    <td>
                                        @if (foreigner.NgayHetHanVisa < DateTime.Now)
                                        {
                                            <span class="text-danger fw-semibold"><i class="bi bi-x-circle-fill"></i> Quá hạn (@foreigner.NgayHetHanVisa.ToString("dd/MM/yyyy"))</span>
                                        }
                                        else
                                        {
                                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Còn hạn (@foreigner.NgayHetHanVisa.ToString("dd/MM/yyyy"))</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted style-multiline-ellipsis" style="max-width: 200px; display: inline-block;">
                                            @foreigner.NoiCuTruHienTai
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-inline-flex gap-2">
                                            <a asp-action="ChiTietNguoiNuocNgoai" asp-route-id="@foreigner.MaNguoiNuocNgoai" class="btn btn-primary btn-xs" style="border-radius: 6px;">
                                                <i class="bi bi-eye"></i> Xem hồ sơ
                                            </a>
                                            <a asp-action="CanhBaoViPham" asp-route-maNguoiNuocNgoai="@foreigner.MaNguoiNuocNgoai" class="btn btn-warning btn-xs text-dark" style="border-radius: 6px;">
                                                <i class="bi bi-exclamation-triangle"></i> Cảnh báo
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-4">
                    @Html.PagedListPager(Model, page => Url.Action("TraCuu", new { page, search = ViewBag.Search, quocTich = ViewBag.QuocTich, loaiVisa = ViewBag.LoaiVisa }),
                        new X.PagedList.Mvc.Core.PagedListRenderOptions {
                            LiElementClasses = new string[] { "page-item" },
                            PageClasses = new string[] { "page-link" },
                            UlElementClasses = new string[] { "pagination", "pagination-sm" }
                        })
                </div>
            }
        </div>
    </div>
</div>
