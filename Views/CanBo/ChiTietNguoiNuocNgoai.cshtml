@model ManagementOfForeigners.Models.Entities.NguoiNuocNgoai
@{
    Layout = "~/Views/Shared/_OfficerLayout.cshtml";
    ViewBag.Title = "Hồ sơ người nước ngoài - Chi tiết";
    var declarations = ViewBag.Declarations as List<ManagementOfForeigners.Models.Entities.HoSoKhaiBaoTamTru> ?? new();
    var stays = ViewBag.Stays as List<ManagementOfForeigners.Models.Entities.LichSuCuTru> ?? new();
    var warnings = ViewBag.Warnings as List<ManagementOfForeigners.Models.Entities.CanhBaoViPham> ?? new();
    var editHistories = ViewBag.EditHistories as List<ManagementOfForeigners.Models.Entities.LichSuCapNhatThongTinCaNhan> ?? new();
    var noiCuTruHienTai = ViewBag.NoiCuTruHienTai as string ?? "Chưa có dữ liệu cư trú hiện tại";
}

<div class="officer-page-header mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h4>Chi Tiết Hồ Sơ Cá Nhân</h4>
            <p class="text-muted mb-0">Hồ sơ thông tin chi tiết, lịch sử tạm trú, cập nhật thông tin và xử lý vi phạm</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="TraCuu" class="btn btn-outline-secondary fw-semibold" style="border-radius: 8px; height: 38px; display: inline-flex; align-items: center;">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <a asp-action="CanhBaoViPham" asp-route-maNguoiNuocNgoai="@Model.MaNguoiNuocNgoai" class="btn btn-warning fw-semibold text-dark" style="border-radius: 8px; height: 38px; display: inline-flex; align-items: center;">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> Gửi cảnh báo vi phạm
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: Personal Card -->
    <div class="col-lg-4 col-md-12">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 14px; border: 1px solid var(--color-border) !important; overflow: hidden;">
            <div class="card-header bg-light border-0 p-4 text-center">
                <div class="d-inline-flex align-items-center justify-content-center bg-white text-success rounded-circle mb-3 border" style="width: 70px; height: 70px; font-size: 2rem; box-shadow: 0 4px 8px rgba(0,0,0,0.02);">
                    <i class="bi bi-person-fill"></i>
                </div>
                <h5 class="fw-bold mb-1 text-dark">@Model.HoTen</h5>
                <p class="text-muted mb-0 fs-8">Hộ chiếu: <span class="text-dark fw-bold">@Model.SoHoChieu</span></p>
            </div>
            <div class="card-body p-4 text-start">
                <ul class="list-group list-group-flush fs-7">
                    <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                        <span class="text-muted"><i class="bi bi-globe me-1 text-success"></i> Quốc tịch:</span>
                        <span class="fw-bold text-dark">@Model.QuocTich</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                        <span class="text-muted"><i class="bi bi-gender-ambiguous me-1 text-success"></i> Giới tính:</span>
                        <span class="fw-bold text-dark">@Model.GioiTinh</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                        <span class="text-muted"><i class="bi bi-calendar3 me-1 text-success"></i> Ngày sinh:</span>
                        <span class="fw-bold text-dark">@Model.NgaySinh.ToString("dd/MM/yyyy")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                        <span class="text-muted"><i class="bi bi-shield-lock me-1 text-success"></i> Loại Visa:</span>
                        <span class="badge-custom badge-info" style="min-height: 20px; padding: 2px 8px; font-size: 11px;">@Model.LoaiVisa</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between p-3 border-0 bg-light rounded-3 mb-2">
                        <span class="text-muted"><i class="bi bi-calendar-check me-1 text-success"></i> Hạn Visa:</span>
                        <span class="fw-bold text-dark">@Model.NgayHetHanVisa.ToString("dd/MM/yyyy")</span>
                    </li>
                    <li class="list-group-item p-3 border-0 bg-light rounded-3">
                        <span class="text-muted d-block mb-1"><i class="bi bi-geo-alt me-1 text-success"></i> Nơi cư trú hiện tại:</span>
                        <span class="fw-bold text-dark fs-8">@noiCuTruHienTai</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Right Column: Tabs Panel -->
    <div class="col-lg-8 col-md-12">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 14px; border: 1px solid var(--color-border) !important;">
            <div class="card-header bg-white border-0 p-4 pb-0">
                <ul class="nav nav-tabs card-header-tabs" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold text-dark py-3" id="tam-tru-tab" data-bs-toggle="tab" data-bs-target="#tam-tru" type="button" role="tab" aria-controls="tam-tru" aria-selected="true">
                            <i class="bi bi-file-earmark-text me-1 text-success"></i> Khai báo tạm trú (@declarations.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-dark py-3" id="luu-tru-tab" data-bs-toggle="tab" data-bs-target="#luu-tru" type="button" role="tab" aria-controls="luu-tru" aria-selected="false">
                            <i class="bi bi-building me-1 text-success"></i> Lưu trú cơ sở (@stays.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-dark py-3" id="vi-pham-tab" data-bs-toggle="tab" data-bs-target="#vi-pham" type="button" role="tab" aria-controls="vi-pham" aria-selected="false">
                            <i class="bi bi-exclamation-octagon me-1 text-danger"></i> Cảnh báo (@warnings.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-dark py-3" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab" aria-controls="history" aria-selected="false">
                            <i class="bi bi-clock-history me-1 text-muted"></i> Nhật ký sửa đổi (@editHistories.Count)
                        </button>
                    </li>
                </ul>
            </div>

            <div class="card-body p-4">
                <div class="tab-content" id="myTabContent">
                    <!-- Khai báo tạm trú Tab -->
                    <div class="tab-pane fade show active" id="tam-tru" role="tabpanel" aria-labelledby="tam-tru-tab">
                        @if (!declarations.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-journal-x text-muted" style="font-size: 2.5rem;"></i>
                                <p class="text-muted mt-2 mb-0">Chưa có hồ sơ khai báo tạm trú nào.</p>
                            </div>
                        }
                        else
                        {
                            <div class="officer-table-wrap">
                                <table class="officer-table" style="min-width: 600px;">
                                    <thead>
                                        <tr>
                                            <th>Mã hồ sơ</th>
                                            <th>Cơ sở tạm trú</th>
                                            <th>Mục đích</th>
                                            <th>Thời hạn</th>
                                            <th>Ngày khai</th>
                                            <th>Trạng thái</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var dec in declarations)
                                        {
                                            var statusBadgeClass = dec.TrangThai switch
                                            {
                                                "Chờ duyệt" => "badge-warning",
                                                "Đã duyệt" => "badge-success",
                                                "Từ chối" => "badge-danger",
                                                "Cần rà soát" or "Sai thông tin" => "badge-warning",
                                                "Đã xử lý" => "badge-success",
                                                _ => "badge-neutral"
                                            };
                                            <tr>
                                                <td><code class="text-secondary fw-semibold">@dec.MaHSKhaiBao</code></td>
                                                <td class="fw-bold">@dec.CoSoLuuTru.TenCoSo</td>
                                                <td>@dec.MucDichLuuTru</td>
                                                <td>@dec.NgayBatDau.ToString("dd/MM/yyyy") - @dec.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                                                <td>@dec.NgayKhaiBao.ToString("dd/MM/yyyy")</td>
                                                <td>
                                                    <span class="badge-custom @statusBadgeClass" style="min-height: 20px; padding: 2px 8px; font-size: 11px;">
                                                        @dec.TrangThai
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    <!-- Lưu trú tại cơ sở Tab -->
                    <div class="tab-pane fade" id="luu-tru" role="tabpanel" aria-labelledby="luu-tru-tab">
                        @if (!stays.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-building-exclamation text-muted" style="font-size: 2.5rem;"></i>
                                <p class="text-muted mt-2 mb-0">Chưa có bản ghi lưu trú nào tại cơ sở.</p>
                            </div>
                        }
                        else
                        {
                            <div class="officer-table-wrap">
                                <table class="officer-table" style="min-width: 600px;">
                                    <thead>
                                        <tr>
                                            <th>Cơ sở</th>
                                            <th>Phòng</th>
                                            <th>Check-in</th>
                                            <th>Check-out</th>
                                            <th>Trạng thái</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var stay in stays)
                                        {
                                            var statusBadgeClass = stay.TrangThai == "Đang ở" ? "badge-success" : "badge-neutral";
                                            <tr>
                                                <td class="fw-bold text-dark">@stay.CoSoLuuTru.TenCoSo</td>
                                                <td>@stay.Phong</td>
                                                <td>@stay.NgayBatDau.ToString("dd/MM/yyyy")</td>
                                                <td>@(stay.NgayKetThuc.HasValue ? stay.NgayKetThuc.Value.ToString("dd/MM/yyyy") : "Đang lưu trú")</td>
                                                <td>
                                                    <span class="badge-custom @statusBadgeClass" style="min-height: 20px; padding: 2px 8px; font-size: 11px;">
                                                        @stay.TrangThai
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    <!-- Cảnh báo vi phạm Tab -->
                    <div class="tab-pane fade" id="vi-pham" role="tabpanel" aria-labelledby="vi-pham-tab">
                        @if (!warnings.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-shield-check text-muted" style="font-size: 2.5rem;"></i>
                                <p class="text-muted mt-2 mb-0">Hồ sơ trong sạch, chưa có cảnh báo vi phạm nào.</p>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3">
                                @foreach (var w in warnings)
                                {
                                    var severityClass = w.MucDoViPham switch
                                    {
                                        "Nhẹ" => "badge-info",
                                        "Trung bình" => "badge-warning",
                                        "Nghiêm trọng" => "badge-danger",
                                        _ => "badge-neutral"
                                    };
                                    <div class="p-3 bg-light rounded-3" style="border: 1px solid var(--color-border);">
                                        <div class="d-flex justify-content-between flex-wrap gap-2 mb-2">
                                            <div>
                                                <span class="badge-custom @severityClass" style="min-height: 20px; padding: 2px 8px; font-size: 11px;">@w.MucDoViPham</span>
                                                <span class="text-dark fw-bold ms-2 fs-7">@w.LoaiViPham</span>
                                            </div>
                                            <small class="text-muted">@w.NgayCanhBao.ToString("dd/MM/yyyy HH:mm")</small>
                                        </div>
                                        <p class="mb-2 text-secondary fs-8" style="line-height: 1.4;">@w.NoiDungCanhBao</p>
                                        <div class="text-muted fs-9 border-top pt-2">Cán bộ xử lý: <span class="fw-semibold text-dark">@w.CanBo.HoTen</span></div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Nhật ký sửa đổi Tab -->
                    <div class="tab-pane fade" id="history" role="tabpanel" aria-labelledby="history-tab">
                        @if (!editHistories.Any())
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-clock-history text-muted" style="font-size: 2.5rem;"></i>
                                <p class="text-muted mt-2 mb-0">Chưa ghi nhận nhật ký cập nhật thông tin nào.</p>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3 timeline">
                                @foreach (var history in editHistories)
                                {
                                    <div class="p-3 border-start border-3 border-success bg-light rounded-3 ms-2">
                                        <div class="d-flex justify-content-between flex-wrap gap-2 mb-1">
                                            <span class="fw-bold text-dark fs-7">Cập nhật thông tin</span>
                                            <small class="text-muted fs-8">@history.NgayCapNhat.ToString("dd/MM/yyyy HH:mm:ss")</small>
                                        </div>
                                        <div class="text-muted fs-8 mb-2">Trường thay đổi: <code class="text-danger fw-semibold">@history.TruongCapNhat</code></div>
                                        <div class="row g-2 mb-2 bg-white p-2 rounded border border-light">
                                            <div class="col-6 border-end">
                                                <small class="text-muted d-block fs-9">Giá trị cũ:</small>
                                                <span class="text-danger fs-8 fw-semibold text-break">@history.GiaTriCu</span>
                                            </div>
                                            <div class="col-6">
                                                <small class="text-muted d-block fs-9">Giá trị mới:</small>
                                                <span class="text-success fs-8 fw-semibold text-break">@history.GiaTriMoi</span>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(history.LyDoCapNhat))
                                        {
                                            <div class="text-muted fs-9 pt-1">Lý do: <span class="fw-semibold text-dark">@history.LyDoCapNhat</span></div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
