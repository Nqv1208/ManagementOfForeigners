@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Đăng ký thành công";
}

<div class="auth-status-page">
    <div class="auth-status-wrap">
        <section class="auth-card auth-status-card" aria-labelledby="register-success-title">
            <div class="auth-card-body">
                <div class="status-icon status-icon--success status-icon--lg mx-auto mb-4" aria-hidden="true">
                    <div class="status-icon__inner">
                        <i class="bi bi-check-lg"></i>
                    </div>
                </div>
                <h1 class="auth-status-title" id="register-success-title">Yêu cầu đăng ký đã được tiếp nhận</h1>
                <p class="auth-status-text">
                    Tài khoản của bạn đã được tiếp nhận và đang chờ xét duyệt theo quy trình quản lý.
                </p>
                <div class="auth-status-actions mt-4">
                    <a asp-controller="TaiKhoan" asp-action="DangNhap" class="btn btn-primary">Về trang đăng nhập</a>
                    <a asp-controller="TrangChu" asp-action="Index" class="btn btn-outline-primary">Trang chủ</a>
                </div>
            </div>
        </section>
    </div>
</div>
