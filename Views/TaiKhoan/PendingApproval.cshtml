@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Tài khoản chờ duyệt";
}

<div class="auth-status-page">
    <div class="auth-status-wrap">
        <section class="auth-card auth-status-card" aria-labelledby="pending-approval-title">
            <div class="auth-card-body">
                <div class="auth-status-icon is-pending" aria-hidden="true">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <h1 class="auth-status-title" id="pending-approval-title">Tài khoản đang chờ xét duyệt</h1>
                <p class="auth-status-text">
                    Tài khoản của bạn đã được ghi nhận nhưng chưa được kích hoạt. Sau khi cán bộ phụ trách hoàn tất xét duyệt,
                    bạn có thể đăng nhập và sử dụng các chức năng theo vai trò được cấp.
                </p>

                <div class="auth-status-note">
                    <h2>Hỗ trợ trạng thái hồ sơ</h2>
                    <ul>
                        <li>Vui lòng kiểm tra lại thông tin đăng ký nếu được yêu cầu bổ sung.</li>
                        <li>Không tạo nhiều tài khoản cho cùng một cơ sở lưu trú khi hồ sơ đang được xử lý.</li>
                        <li>Nếu cần hỗ trợ, liên hệ bộ phận tiếp nhận hoặc Công an Phường/Xã nơi cơ sở hoạt động.</li>
                    </ul>
                </div>

                <div class="auth-status-actions">
                    <a asp-controller="TaiKhoan" asp-action="DangNhap" class="btn btn-primary">
                        <i class="bi bi-arrow-left-circle me-2" aria-hidden="true"></i>Quay lại đăng nhập
                    </a>
                    <a asp-controller="TrangChu" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-house-door me-2" aria-hidden="true"></i>Trang chủ
                    </a>
                </div>
            </div>
        </section>
    </div>
</div>
