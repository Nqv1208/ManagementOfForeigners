@model DangNhapViewModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-login-page">
    <div class="auth-login-wrap">
        <section class="auth-card auth-login-card" aria-labelledby="login-title">
            <div class="auth-card-header">
                <h1 class="auth-card-title" id="login-title">Đăng nhập</h1>
                <p class="auth-card-description">
                    Sử dụng tài khoản đã được cấp hoặc đã đăng ký để thực hiện các thủ tục quản lý cư trú.
                </p>
            </div>

            <div class="auth-card-body">
                <form asp-action="DangNhap" asp-controller="TaiKhoan" method="post" class="auth-login-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-0" role="alert"></div>

                    <div class="auth-form-group">
                        <label asp-for="TenDangNhap" class="auth-form-label">Tên đăng nhập hoặc email</label>
                        <input asp-for="TenDangNhap" class="form-control" autocomplete="username" placeholder="Nhập tên đăng nhập hoặc email" autofocus />
                        <span asp-validation-for="TenDangNhap" class="field-validation-error"></span>
                    </div>

                    <div class="auth-form-group">
                        <label asp-for="MatKhau" class="auth-form-label"></label>
                        <div class="auth-password-field">
                            <input asp-for="MatKhau" id="MatKhau" class="form-control" autocomplete="current-password" placeholder="Nhập mật khẩu" />
                            <button type="button" class="auth-password-toggle" data-auth-password-toggle="MatKhau" aria-label="Hiện mật khẩu">
                                <i class="bi bi-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        <span asp-validation-for="MatKhau" class="field-validation-error"></span>
                    </div>

                    <div class="auth-login-options">
                        <div class="form-check">
                            <input asp-for="GhiNho" class="form-check-input" />
                            <label asp-for="GhiNho" class="form-check-label"></label>
                        </div>
                        <span class="auth-helper-text">Tài khoản chờ duyệt sẽ được thông báo trạng thái riêng.</span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i>Đăng nhập
                    </button>
                </form>

                <div class="auth-register-cta">
                    <span class="auth-helper-text">Chưa có tài khoản?</span>
                    <a asp-controller="TaiKhoan" asp-action="DangKy" class="auth-form-link">Đăng ký tài khoản dịch vụ công</a>
                </div>

                <aside class="auth-support-box" aria-label="Hỗ trợ đăng nhập">
                    <h2 class="auth-support-title">Hỗ trợ người dùng</h2>
                    <div class="auth-support-links">
                        <a asp-controller="TrangChu" asp-action="Index" class="auth-form-link">Hướng dẫn sử dụng</a>
                        <a asp-controller="TrangChu" asp-action="Index" class="auth-form-link">Liên hệ hỗ trợ</a>
                    </div>
                </aside>
            </div>
        </section>

        @if (Env.EnvironmentName == "Development")
        {
            <section class="card auth-dev-accounts" aria-label="Tài khoản kiểm thử">
                <div class="card-body">
                    <h2 class="auth-dev-accounts-title">
                        <i class="bi bi-info-circle me-1" aria-hidden="true"></i>Tài khoản kiểm thử
                    </h2>
                    <div class="table-responsive">
                        <table class="table table-sm table-borderless align-middle">
                            <thead>
                                <tr>
                                    <th>Vai trò</th>
                                    <th>Username</th>
                                    <th>Mật khẩu</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Chủ cơ sở lưu trú</td>
                                    <td><strong>khachsan01</strong></td>
                                    <td><code>KhachSan@@123</code></td>
                                </tr>
                                <tr>
                                    <td>Người nước ngoài</td>
                                    <td><strong>john.smith</strong></td>
                                    <td><code>User@@123</code></td>
                                </tr>
                                <tr>
                                    <td>Công an Phường/Xã</td>
                                    <td><strong>congan01</strong></td>
                                    <td><code>CongAn@@123</code></td>
                                </tr>
                                <tr>
                                    <td>Cán bộ xuất nhập cảnh</td>
                                    <td><strong>canbo01</strong></td>
                                    <td><code>CanBo@@123</code></td>
                                </tr>
                                <tr>
                                    <td>Quản trị hệ thống</td>
                                    <td><strong>admin</strong></td>
                                    <td><code>Admin@@123</code></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        }
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
