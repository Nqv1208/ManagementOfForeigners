@model ManagementOfForeigners.Models.ViewModels.DangKyUnifiedViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Đăng ký tài khoản";
    var isLodgingOwner = Model?.AccountType == "LodgingOwner";
    var isForeigner = !isLodgingOwner;
}

<div class="auth-register-page">
    <div class="auth-register-shell">
        <section class="auth-card auth-register-card" aria-labelledby="register-title">
            <div class="auth-card-header auth-register-heading">
                <div class="auth-register-heading-main w-100">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                        <div>
                            <h1 class="auth-card-title" id="register-title">Đăng ký tài khoản dịch vụ công</h1>
                            <p class="auth-card-description mb-0">
                                Vui lòng chọn loại tài khoản và nhập thông tin chính xác để phục vụ việc xác minh, quản lý cư trú theo quy định.
                            </p>
                        </div>
                        <a asp-action="DangNhap" class="auth-form-link fs-7 mt-1"><i class="bi bi-box-arrow-in-right me-1"></i>Đã có tài khoản? Đăng nhập</a>
                    </div>
                    
                    <div class="auth-role-selector-wrap mt-3 d-flex align-items-center gap-3">
                        <span class="auth-role-label fw-bold text-muted fs-7">Loại tài khoản:</span>
                        <div class="auth-segmented" role="tablist" aria-label="Loại tài khoản đăng ký">
                            <button type="button"
                                    class="auth-segmented-button @(isForeigner ? "is-active" : "")"
                                    data-auth-account-type="Foreigner"
                                    aria-selected="@(isForeigner ? "true" : "false")">
                                <i class="bi bi-person-badge" aria-hidden="true"></i>
                                <span>Người nước ngoài</span>
                            </button>
                            <button type="button"
                                    class="auth-segmented-button @(isLodgingOwner ? "is-active" : "")"
                                    data-auth-account-type="LodgingOwner"
                                    aria-selected="@(isLodgingOwner ? "true" : "false")">
                                <i class="bi bi-building" aria-hidden="true"></i>
                                <span>Cơ sở lưu trú</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="auth-card-body">
                <form asp-action="DangKy" asp-controller="TaiKhoan" method="post" class="auth-register-form" data-auth-register-form>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-0" role="alert"></div>
                    <input type="hidden" asp-for="AccountType" id="AccountType" />

                    <!-- Account Information (Always Visible) -->
                    <section class="auth-register-section" aria-labelledby="account-section-title">
                        <h2 class="auth-section-title" id="account-section-title">
                             <i class="bi bi-shield-lock" aria-hidden="true"></i>Thông tin tài khoản
                        </h2>
                        <p class="auth-section-desc mb-3 text-muted fs-7">Dùng để đăng nhập và nhận thông báo từ hệ thống.</p>
                        <div class="auth-form-grid">
                            <div class="auth-form-group">
                                <label asp-for="TenDangNhap" class="auth-required"></label>
                                <input asp-for="TenDangNhap" class="form-control" autocomplete="username" placeholder="Tên đăng nhập" />
                                <span asp-validation-for="TenDangNhap" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="Email" class="auth-required"></label>
                                <input asp-for="Email" class="form-control" type="email" autocomplete="email" placeholder="email@example.com" />
                                <span asp-validation-for="Email" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="SoDienThoai" class="auth-required"></label>
                                <input asp-for="SoDienThoai" class="form-control" autocomplete="tel" placeholder="Số điện thoại liên hệ" />
                                <span asp-validation-for="SoDienThoai" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group d-none d-md-block">
                                <!-- Spacer for alignment -->
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="MatKhau" class="auth-required"></label>
                                <div class="auth-password-field">
                                    <input asp-for="MatKhau" id="RegisterMatKhau" class="form-control" autocomplete="new-password" placeholder="Tối thiểu 6 ký tự" />
                                    <button type="button" class="auth-password-toggle" data-auth-password-toggle="RegisterMatKhau" aria-label="Hiện mật khẩu">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="MatKhau" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="XacNhanMatKhau" class="auth-required"></label>
                                <div class="auth-password-field">
                                    <input asp-for="XacNhanMatKhau" id="RegisterXacNhanMatKhau" class="form-control" autocomplete="new-password" placeholder="Nhập lại mật khẩu" />
                                    <button type="button" class="auth-password-toggle" data-auth-password-toggle="RegisterXacNhanMatKhau" aria-label="Hiện mật khẩu">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="XacNhanMatKhau" class="field-validation-error"></span>
                            </div>
                        </div>
                    </section>

                    <!-- FOREIGNER FLOW ONLY: Personal Details -->
                    <section class="auth-register-section @(isForeigner ? "" : "auth-hidden")"
                             data-auth-section="Foreigner"
                             aria-labelledby="foreigner-section-title">
                        <h2 class="auth-section-title" id="foreigner-section-title">
                            <i class="bi bi-person-vcard" aria-hidden="true"></i>Thông tin người nước ngoài
                        </h2>
                        <p class="auth-section-desc mb-3 text-muted fs-7">Vui lòng nhập đúng thông tin theo hộ chiếu.</p>
                        <div class="auth-form-grid">
                            <div class="auth-form-group">
                                <label asp-for="HoTen" class="auth-required">Họ và tên</label>
                                <input asp-for="HoTen" class="form-control text-uppercase" autocomplete="name" placeholder="Họ và tên viết hoa không dấu (Ví dụ: JOHN SMITH)" />
                                <span asp-validation-for="HoTen" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="NgaySinh" class="auth-required"></label>
                                <input asp-for="NgaySinh" class="form-control" type="date" />
                                <span asp-validation-for="NgaySinh" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="GioiTinh" class="auth-required"></label>
                                <select asp-for="GioiTinh" class="form-select">
                                    <option value="">Chọn giới tính</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span asp-validation-for="GioiTinh" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="QuocTich" class="auth-required"></label>
                                <input asp-for="QuocTich" class="form-control" placeholder="Ví dụ: Hàn Quốc" />
                                <span asp-validation-for="QuocTich" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="SoHoChieu" class="auth-required"></label>
                                <input asp-for="SoHoChieu" class="form-control" placeholder="Số hộ chiếu" />
                                <span asp-validation-for="SoHoChieu" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="LoaiHoChieu"></label>
                                <input asp-for="LoaiHoChieu" class="form-control" placeholder="Phổ thông / ngoại giao" />
                                <span asp-validation-for="LoaiHoChieu" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="HanHoChieu"></label>
                                <input asp-for="HanHoChieu" class="form-control" type="date" />
                                <span asp-validation-for="HanHoChieu" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group auth-field-span-2">
                                <label asp-for="DiaChiLienHe"></label>
                                <input asp-for="DiaChiLienHe" class="form-control" placeholder="Địa chỉ liên hệ hiện tại" />
                                <span asp-validation-for="DiaChiLienHe" class="field-validation-error"></span>
                            </div>
                        </div>
                    </section>

                    <!-- LODGING OWNER FLOW: Representative Details -->
                    <section class="auth-register-section @(isLodgingOwner ? "" : "auth-hidden")"
                             data-auth-section="LodgingOwner"
                             aria-labelledby="lodging-representative-title">
                        <h2 class="auth-section-title" id="lodging-representative-title">
                            <i class="bi bi-person-lines-fill" aria-hidden="true"></i>Thông tin người đại diện
                        </h2>
                        <p class="auth-section-desc mb-3 text-muted fs-7">Thông tin cá nhân của chủ hoặc người đại diện cơ sở lưu trú.</p>
                        <div class="auth-form-grid">
                            <div class="auth-form-group">
                                <label asp-for="HoTenNguoiDaiDien" class="auth-required"></label>
                                <input asp-for="HoTenNguoiDaiDien" class="form-control" autocomplete="name" placeholder="Họ tên người đại diện" />
                                <span asp-validation-for="HoTenNguoiDaiDien" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="SoGiayToNguoiDaiDien" class="auth-required"></label>
                                <input asp-for="SoGiayToNguoiDaiDien" class="form-control" placeholder="CCCD / CMND / hộ chiếu" />
                                <span asp-validation-for="SoGiayToNguoiDaiDien" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="NgaySinhNguoiDaiDien"></label>
                                <input asp-for="NgaySinhNguoiDaiDien" class="form-control" type="date" />
                                <span asp-validation-for="NgaySinhNguoiDaiDien" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="GioiTinhNguoiDaiDien"></label>
                                <select asp-for="GioiTinhNguoiDaiDien" class="form-select">
                                    <option value="">Chọn giới tính</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span asp-validation-for="GioiTinhNguoiDaiDien" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="ChucVu"></label>
                                <input asp-for="ChucVu" class="form-control" placeholder="Chủ cơ sở / quản lý" />
                                <span asp-validation-for="ChucVu" class="field-validation-error"></span>
                            </div>
                        </div>

                        <!-- LODGING OWNER FLOW: Facility Details -->
                        <h2 class="auth-section-title mt-4" id="lodging-facility-title">
                            <i class="bi bi-building-check" aria-hidden="true"></i>Thông tin cơ sở lưu trú
                        </h2>
                        <p class="auth-section-desc mb-3 text-muted fs-7">Thông tin chi tiết về cơ sở lưu trú tại địa bàn quản lý.</p>
                        <div class="auth-form-grid">
                            <div class="auth-form-group">
                                <label asp-for="TenCoSoLuuTru" class="auth-required"></label>
                                <input asp-for="TenCoSoLuuTru" class="form-control" placeholder="Tên cơ sở lưu trú" />
                                <span asp-validation-for="TenCoSoLuuTru" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="SoDienThoaiCoSo" class="auth-required"></label>
                                <input asp-for="SoDienThoaiCoSo" class="form-control" autocomplete="tel" placeholder="Số điện thoại cơ sở" />
                                <span asp-validation-for="SoDienThoaiCoSo" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="EmailCoSo"></label>
                                <input asp-for="EmailCoSo" class="form-control" type="email" placeholder="Email cơ sở" />
                                <span asp-validation-for="EmailCoSo" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="TinhThanh"></label>
                                <input asp-for="TinhThanh" class="form-control" readonly />
                            </div>
                            <div class="auth-form-group">
                                <label asp-for="PhuongXaId" class="auth-required"></label>
                                <select asp-for="PhuongXaId" asp-items="ViewBag.PhuongXas" class="form-select">
                                    <option value="">Chọn Phường/Xã</option>
                                </select>
                                <span asp-validation-for="PhuongXaId" class="field-validation-error"></span>
                            </div>
                            <div class="auth-form-group auth-field-span-2">
                                <label asp-for="DiaChiCoSo" class="auth-required"></label>
                                <input asp-for="DiaChiCoSo" class="form-control" placeholder="Số nhà, tên đường, tổ dân phố..." />
                                <span asp-validation-for="DiaChiCoSo" class="field-validation-error"></span>
                            </div>
                        </div>
                    </section>

                    <!-- COMMITMENT CHECKBOX (Always visible below target sections) -->
                    <section class="auth-commitment" aria-label="Cam kết thông tin">
                        <div class="form-check">
                            <input asp-for="CamKetThongTin" class="form-check-input" type="checkbox" data-auth-commitment />
                            <label asp-for="CamKetThongTin" class="form-check-label text-dark fw-semibold" style="font-size: 0.92rem;">
                                Tôi cam đoan các thông tin khai báo là đúng sự thật và chịu trách nhiệm trước pháp luật.
                            </label>
                        </div>
                        <span asp-validation-for="CamKetThongTin" class="field-validation-error d-block"></span>
                    </section>

                    <!-- ACTIONS SECTION -->
                    <div class="auth-footer-actions d-flex align-items-center justify-content-between flex-wrap gap-2 w-100">
                        <div class="d-flex align-items-center gap-2">
                            <a asp-controller="TrangChu" asp-action="Index" class="btn btn-outline-secondary px-3 py-2">
                                <i class="bi bi-x-circle me-2" aria-hidden="true"></i>Hủy bỏ
                            </a>
                            <button type="button" class="btn btn-outline-secondary px-3 py-2" data-auth-reset>
                                <i class="bi bi-arrow-counterclockwise me-2" aria-hidden="true"></i>Làm mới
                            </button>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button type="submit" class="btn btn-primary px-4 py-2" data-auth-requires-commitment>
                                <i class="bi bi-check2-circle me-2" aria-hidden="true"></i>Đăng ký
                            </button>
                        </div>
                    </div>
                </form>

                <div class="text-center mt-4 pt-3 border-top border-light">
                    <span class="text-muted fs-7">Đã có tài khoản?</span>
                    <a asp-action="DangNhap" class="auth-form-link fs-7 ms-1 fw-bold">Đăng nhập ngay</a>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
