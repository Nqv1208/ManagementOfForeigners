@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.LichSuCuTru>
@{
    ViewBag.Title = "Lịch sử khai báo lưu trú";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="coso-page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h5 class="fw-bold mb-1" style="color: var(--coso-primary-dark);"><i class="bi bi-clock-history me-2 text-success"></i>Lịch sử lưu trú tại cơ sở</h5>
            <p class="text-muted mb-0 fs-7">Toàn bộ hồ sơ check-in/check-out thực tế của khách nước ngoài tại cơ sở</p>
        </div>
        <a asp-action="KhaiBaoLuuTru" class="btn btn-success fw-bold px-3 py-2 d-flex align-items-center gap-1" style="border-radius: 8px;">
            <i class="bi bi-person-plus-fill"></i> Khai báo mới
        </a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 16px; border: 1px solid var(--coso-border) !important;">
        <div class="card-body p-4">
            <!-- Search Form with Filters -->
            <form asp-action="LichSuCuTru" method="get" class="row g-3 mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-semibold text-dark fs-7">Từ khóa</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" value="@ViewBag.Search" placeholder="Họ tên, số hộ chiếu hoặc phòng..." style="border-radius: 0 8px 8px 0;" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold text-dark fs-7">Trạng thái khách</label>
                    <select name="status" class="form-select" style="border-radius: 8px;">
                        <option value="">-- Tất cả trạng thái --</option>
                        <option value="Đang ở" selected="@(ViewBag.Status == "Đang ở")">Đang ở</option>
                        <option value="Đã rời" selected="@(ViewBag.Status == "Đã rời")">Đã rời</option>
                        <option value="Quá hạn" selected="@(ViewBag.Status == "Quá hạn")">Quá hạn</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold text-dark fs-7">Từ ngày</label>
                    <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" style="border-radius: 8px;" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold text-dark fs-7">Đến ngày</label>
                    <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" style="border-radius: 8px;" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-success w-100 fw-semibold" style="border-radius: 8px; padding-top: 10px; padding-bottom: 10px;" title="Lọc"><i class="bi bi-funnel"></i></button>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">Không tìm thấy bản ghi lịch sử lưu trú nào.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 fs-7">
                        <thead>
                            <tr class="text-muted border-bottom">
                                <th>Mã lưu trú</th>
                                <th>Phòng</th>
                                <th>Họ và tên</th>
                                <th>Số hộ chiếu</th>
                                <th>Quốc tịch</th>
                                <th>Thời gian cư trú</th>
                                <th>Trạng thái</th>
                                <th>Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stay in Model)
                            {
                                <tr class="@(stay.TrangThai == "Quá hạn" ? "table-danger table-opacity-10" : "")">
                                    <td><code class="text-secondary fw-semibold">@stay.MaLSLuuTru</code></td>
                                    <td><span class="badge bg-light text-dark border">Phòng @stay.Phong</span></td>
                                    <td class="fw-bold text-dark">@stay.NguoiNuocNgoai.HoTen</td>
                                    <td>@stay.NguoiNuocNgoai.SoHoChieu</td>
                                    <td>@stay.NguoiNuocNgoai.QuocTich</td>
                                    <td>
                                        <small class="d-block text-dark fw-semibold">@stay.NgayBatDau.ToString("dd/MM/yyyy")</small>
                                        <small class="text-muted">đến @(stay.NgayKetThuc.HasValue ? stay.NgayKetThuc.Value.ToString("dd/MM/yyyy") : "Chưa Check-out")</small>
                                    </td>
                                    <td>
                                        @await Html.PartialAsync("_StatusBadge", stay.TrangThai)
                                    </td>
                                    <td><small class="text-muted">@(string.IsNullOrEmpty(stay.GhiChu) ? "Không có" : stay.GhiChu)</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-4">
                    @Html.PagedListPager(Model, page => Url.Action("LichSuCuTru", new { page, search = ViewBag.Search, status = ViewBag.Status, fromDate = ViewBag.FromDate, toDate = ViewBag.ToDate }),
                        new X.PagedList.Mvc.Core.PagedListRenderOptions {
                            LiElementClasses = new string[] { "page-item" },
                            PageClasses = new string[] { "page-link" },
                            UlElementClasses = new string[] { "pagination", "pagination-sm" }
                        })
                </div>
            }
        </div>
    </div>
</div>
