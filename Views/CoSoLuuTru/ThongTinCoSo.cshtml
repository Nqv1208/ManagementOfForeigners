@model ManagementOfForeigners.Models.Entities.CoSoLuuTru
@{
    ViewBag.Title = "Thông tin cơ sở lưu trú";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="coso-page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h5 class="fw-bold mb-1" style="color: var(--coso-primary-dark);"><i class="bi bi-house-gear-fill me-2 text-success"></i>Thông tin hồ sơ cơ sở</h5>
            <p class="text-muted mb-0 fs-7">Chi tiết thông tin đăng ký hoạt động và liên hệ của cơ sở lưu trú</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="TongQuan" class="btn btn-outline-secondary fw-semibold px-3 py-2" style="border-radius: 8px;">
                <i class="bi bi-arrow-left"></i> Bảng điều khiển
            </a>
            <a asp-action="CapNhatCoSo" class="btn btn-success fw-bold px-3 py-2 d-flex align-items-center gap-1" style="border-radius: 8px;">
                <i class="bi bi-pencil-square"></i> Chỉnh sửa thông tin
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Side: Profile Details -->
        <div class="col-lg-8">
            <!-- Section 1: Hồ sơ cơ sở -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; border: 1px solid var(--coso-border) !important;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-building me-2 text-success"></i>Thông tin đăng ký kinh doanh</h6>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="row g-3 fs-7 mt-1">
                        <div class="col-md-6">
                            <span class="text-muted d-block mb-1">Mã cơ sở lưu trú:</span>
                            <span class="fw-bold text-dark fs-6">@Model.MaCoSoLuuTru</span>
                        </div>
                        <div class="col-md-6">
                            <span class="text-muted d-block mb-1">Trạng thái phê duyệt:</span>
                            @if (Model.TrangThai == "Đang hoạt động")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20 px-2 py-1"><i class="bi bi-check-circle-fill me-1"></i>Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-20 px-2 py-1"><i class="bi bi-exclamation-triangle-fill me-1"></i>Ngừng hoạt động / Chưa duyệt</span>
                            }
                        </div>
                        <div class="col-12 mt-3">
                            <span class="text-muted d-block mb-1">Tên cơ sở lưu trú:</span>
                            <span class="fw-bold text-dark fs-6">@Model.TenCoSo</span>
                        </div>
                        <div class="col-md-6 mt-3">
                            <span class="text-muted d-block mb-1">Phường/Xã quản lý trực tiếp:</span>
                            <span class="fw-semibold text-dark">@Model.PhuongXa.TenPhuongXa</span>
                        </div>
                        <div class="col-12 mt-3">
                            <span class="text-muted d-block mb-1">Địa chỉ thực tế:</span>
                            <span class="fw-semibold text-dark">@Model.DiaChi</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 2: Liên hệ -->
            <div class="card border-0 shadow-sm" style="border-radius: 16px; border: 1px solid var(--coso-border) !important;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-person-lines-fill me-2 text-success"></i>Thông tin liên hệ & đại diện pháp luật</h6>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="row g-3 fs-7 mt-1">
                        <div class="col-md-6">
                            <span class="text-muted d-block mb-1">Người đại diện pháp luật:</span>
                            <span class="fw-bold text-dark fs-6 text-uppercase">@Model.ChuCoSoLuuTru.HoTen</span>
                        </div>
                        <div class="col-md-6">
                            <span class="text-muted d-block mb-1">Số điện thoại liên hệ:</span>
                            <span class="fw-semibold text-dark">@Model.SoDienThoai</span>
                        </div>
                        <div class="col-md-6 mt-3">
                            <span class="text-muted d-block mb-1">Email nhận thông báo:</span>
                            <span class="fw-semibold text-dark">@Model.Email</span>
                        </div>
                        <div class="col-md-6 mt-3">
                            <span class="text-muted d-block mb-1">Tài khoản quản lý liên kết:</span>
                            <span class="badge bg-light text-dark border fw-semibold px-2 py-1"><i class="bi bi-person-fill text-muted me-1"></i>@Model.ChuCoSoLuuTru.TaiKhoan.TenDangNhap</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Activity & Fast Links -->
        <div class="col-lg-4">
            <!-- Section 3: Hoạt động -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; border: 1px solid var(--coso-border) !important;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-activity me-2 text-success"></i>Thống kê hoạt động cơ sở</h6>
                </div>
                <div class="card-body px-4">
                    <div class="list-group list-group-flush fs-7 mt-2">
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 bg-transparent">
                            <span class="text-muted"><i class="bi bi-people me-2 text-success"></i> Khách đang ở thực tế</span>
                            <span class="badge bg-success bg-opacity-10 text-success fw-bold">@ViewBag.ActiveGuestsCount khách</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 bg-transparent">
                            <span class="text-muted"><i class="bi bi-file-earmark-check me-2 text-primary"></i> Tổng số hồ sơ đã nộp</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary fw-bold">@ViewBag.TotalDeclarationsCount hồ sơ</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 bg-transparent">
                            <span class="text-muted"><i class="bi bi-hourglass-split me-2 text-warning"></i> Hồ sơ chờ phê duyệt</span>
                            <span class="badge bg-warning bg-opacity-10 text-warning fw-bold">@ViewBag.PendingDeclarationsCount hồ sơ</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 bg-transparent border-0">
                            <span class="text-muted"><i class="bi bi-x-circle me-2 text-danger"></i> Hồ sơ bị từ chối duyệt</span>
                            <span class="badge bg-danger bg-opacity-10 text-danger fw-bold">@ViewBag.RejectedDeclarationsCount hồ sơ</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Fast Links -->
            <div class="card border-0 shadow-sm" style="border-radius: 16px; border: 1px solid var(--coso-border) !important;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-link-45deg me-2 text-success"></i>Liên kết nhanh</h6>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="d-grid gap-2 fs-7">
                        <a asp-action="DanhSachKhaiBao" class="btn btn-outline-success text-start py-2 px-3 fw-medium" style="border-radius: 8px;">
                            <i class="bi bi-file-earmark-text-fill me-2"></i> Lịch sử nộp hồ sơ
                        </a>
                        <a asp-action="DanhSachLuuTru" class="btn btn-outline-success text-start py-2 px-3 fw-medium" style="border-radius: 8px;">
                            <i class="bi bi-people-fill me-2"></i> Danh sách khách đang ở
                        </a>
                        <a asp-action="LichSuCuTru" class="btn btn-outline-success text-start py-2 px-3 fw-medium" style="border-radius: 8px;">
                            <i class="bi bi-clock-history me-2"></i> Tra cứu lịch sử lưu trú
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
