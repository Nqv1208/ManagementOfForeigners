@model ManagementOfForeigners.Models.ViewModels.CoSoLuuTru.TongQuanViewModel
@{
    ViewBag.Title = "Bảng điều khiển - Chủ cơ sở";
}

<div class="container-fluid">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="coso-page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h5 class="fw-bold mb-1" style="color: var(--coso-primary-dark);"><i class="bi bi-grid-fill me-2 text-success"></i>Bảng điều khiển cơ sở lưu trú</h5>
                    <p class="text-muted mb-0 fs-7">Cơ sở: <strong>@Model.CoSoInfo.TenCoSo</strong> | Địa chỉ: <strong>@Model.CoSoInfo.DiaChi</strong></p>
                </div>
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20 px-3 py-2 fw-bold" style="border-radius: 20px;">
                    <i class="bi bg-transparent bi-check-circle-fill me-1"></i> Cơ sở: Đang hoạt động
                </span>
            </div>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="coso-stat-card">
                <div class="stat-content">
                    <span class="stat-label">Khách đang lưu trú</span>
                    <span class="stat-value">@Model.TotalStaying</span>
                </div>
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="coso-stat-card">
                <div class="stat-content">
                    <span class="stat-label">Hồ sơ chờ duyệt</span>
                    <span class="stat-value text-warning">@Model.TotalPendingDeclarations</span>
                </div>
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-file-earmark-text-fill"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="coso-stat-card">
                <div class="stat-content">
                    <span class="stat-label">Sắp check-out (hôm nay)</span>
                    <span class="stat-value text-info">@Model.TotalLeavingToday</span>
                </div>
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-door-open-fill"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="coso-stat-card">
                <div class="stat-content">
                    <span class="stat-label">Lưu trú quá hạn</span>
                    <span class="stat-value text-danger">@Model.TotalOverdue</span>
                </div>
                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-exclamation-octagon-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Action & Lists Grid -->
    <div class="row g-4">
        <!-- Quick Actions & Info -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px; border: 1px solid var(--coso-border) !important;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-lightning-charge me-2 text-warning"></i>Thao tác vận hành nhanh</h6>
                </div>
                <div class="card-body px-4">
                    <div class="d-grid gap-3">
                        <a asp-action="KhaiBaoLuuTru" class="coso-quick-action-card primary text-decoration-none">
                            <div class="icon-wrap">
                                <i class="bi bi-person-plus-fill"></i>
                            </div>
                            <div class="action-details">
                                <span class="action-title">Khai báo khách mới</span>
                                <span class="action-desc">Nhập đăng ký cư trú cho khách nước ngoài thực tế</span>
                            </div>
                            <i class="bi bi-chevron-right arrow-icon"></i>
                        </a>

                        <a asp-action="DanhSachKhaiBao" class="coso-quick-action-card success text-decoration-none">
                            <div class="icon-wrap">
                                <i class="bi bi-file-earmark-text-fill"></i>
                            </div>
                            <div class="action-details">
                                <span class="action-title">Hồ sơ khai báo</span>
                                <span class="action-desc">Xem lịch sử khai báo và trạng thái duyệt hồ sơ</span>
                            </div>
                            <i class="bi bi-chevron-right arrow-icon"></i>
                        </a>

                        <a asp-action="DanhSachLuuTru" class="coso-quick-action-card secondary text-decoration-none">
                            <div class="icon-wrap">
                                <i class="bi bi-people-fill"></i>
                            </div>
                            <div class="action-details">
                                <span class="action-title">Khách đang lưu trú</span>
                                <span class="action-desc">Theo dõi danh sách khách đang ở thực tế tại cơ sở</span>
                            </div>
                            <i class="bi bi-chevron-right arrow-icon"></i>
                        </a>
                    </div>

                    @if (Model.TotalOverdue > 0)
                    {
                        <div class="alert alert-danger mt-4 d-flex align-items-center gap-2" role="alert" style="border-radius: 10px;">
                            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                            <div class="fs-7">
                                Có <strong>@Model.TotalOverdue</strong> lượt lưu trú bị quá hạn. Vui lòng xác nhận check-out hoặc cập nhật thông tin.
                            </div>
                        </div>
                    }

                    <div class="mt-4 pt-4 border-top">
                        <h6 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle me-2 text-info"></i>Thông tin cơ sở lưu trú</h6>
                        <ul class="list-unstyled fs-7 text-secondary mb-0">
                            <li class="mb-2"><i class="bi bi-telephone me-2 text-success"></i> @Model.CoSoInfo.SoDienThoai</li>
                            <li class="mb-2"><i class="bi bi-envelope me-2 text-success"></i> @Model.CoSoInfo.Email</li>
                            <li><i class="bi bi-shield-check me-2 text-success"></i> Người đại diện: @Model.CoSoInfo.ChuCoSoLuuTru.HoTen</li>
                        </ul>
                        <a asp-action="ThongTinCoSo" class="btn btn-link p-0 fs-7 mt-3 text-decoration-none fw-semibold text-success">
                            Xem & Sửa Hồ Sơ Cơ Sở <i class="bi bi-arrow-right small"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main listings area -->
        <div class="col-lg-8">
            <!-- Recent Declarations -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; border: 1px solid var(--coso-border) !important;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-file-earmark-text-fill me-2 text-success"></i>Hồ sơ khai báo gần đây</h6>
                    <a asp-action="DanhSachKhaiBao" class="text-decoration-none fs-7 text-success fw-semibold">Xem toàn bộ <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="card-body px-4">
                    @if (!Model.RecentDeclarations.Any())
                    {
                        <div class="text-center py-4">
                            <p class="text-muted fs-7 mb-0">Chưa có hồ sơ khai báo nào.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 fs-7">
                                <thead>
                                    <tr class="text-muted">
                                        <th>Mã HS</th>
                                        <th>Khách hàng</th>
                                        <th>Hộ chiếu</th>
                                        <th>Thời gian lưu trú</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dec in Model.RecentDeclarations)
                                    {
                                        <tr>
                                            <td class="fw-semibold"><code>@dec.MaHSKhaiBao</code></td>
                                            <td class="fw-bold text-dark">@dec.TaiKhoan.NguoiNuocNgoai?.HoTen</td>
                                            <td>@dec.TaiKhoan.NguoiNuocNgoai?.SoHoChieu</td>
                                            <td>@dec.NgayBatDau.ToString("dd/MM/yyyy") - @dec.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                @if (dec.TrangThai == "Chờ duyệt")
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-20">Chờ duyệt</span>
                                                }
                                                else if (dec.TrangThai == "Đã duyệt")
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20">Đã duyệt</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-20">Từ từ chối</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Active Guests -->
            <div class="card border-0 shadow-sm" style="border-radius: 16px; border: 1px solid var(--coso-border) !important;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-people me-2 text-success"></i>Khách đang lưu trú tại cơ sở</h6>
                    <a asp-action="DanhSachLuuTru" class="text-decoration-none fs-7 text-success fw-semibold">Quản lý khách <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="card-body px-4">
                    @if (!Model.ActiveStays.Any())
                    {
                        <div class="text-center py-4">
                            <p class="text-muted fs-7 mb-0">Hiện chưa có khách đang ở thực tế.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 fs-7">
                                <thead>
                                    <tr class="text-muted">
                                        <th>Phòng</th>
                                        <th>Khách hàng</th>
                                        <th>Số hộ chiếu</th>
                                        <th>Ngày Check-in</th>
                                        <th>Dự kiến rời đi</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var stay in Model.ActiveStays)
                                    {
                                        <tr>
                                            <td><span class="badge bg-light text-dark border">Phòng @stay.Phong</span></td>
                                            <td class="fw-bold text-dark">@stay.NguoiNuocNgoai.HoTen</td>
                                            <td>@stay.NguoiNuocNgoai.SoHoChieu</td>
                                            <td>@stay.NgayBatDau.ToString("dd/MM/yyyy")</td>
                                            <td>@(stay.NgayKetThuc.HasValue ? stay.NgayKetThuc.Value.ToString("dd/MM/yyyy") : "Chưa đăng ký")</td>
                                            <td>
                                                @await Html.PartialAsync("_StatusBadge", stay.TrangThai)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
