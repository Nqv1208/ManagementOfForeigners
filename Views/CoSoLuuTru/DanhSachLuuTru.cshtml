@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.LichSuCuTru>
@{
    ViewBag.Title = "Danh sách khách hàng đang lưu trú";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-header gov-card-header p-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h5 class="fw-bold mb-0">Khách nước ngoài đang lưu trú</h5>
                <p class="text-white-50 mb-0 fs-7">Danh sách người nước ngoài đang cư trú thực tế tại cơ sở của bạn</p>
            </div>
            <a asp-action="KhaiBaoLuuTru" class="btn btn-light btn-sm fw-bold px-3 py-2" style="border-radius: 8px;">
                <i class="bi bi-person-plus me-1"></i> Khai báo mới
            </a>
        </div>

        <div class="card-body p-4">
            <!-- Alerts (Handled globally by layout toasts) -->

            <!-- Search Form -->
            <form asp-action="DanhSachLuuTru" method="get" class="row g-3 mb-4">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" value="@ViewBag.Search" placeholder="Tìm theo họ tên, số hộ chiếu hoặc phòng..." style="border-radius: 0 8px 8px 0;" />
                    </div>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100 fw-semibold" style="border-radius: 8px;">Tìm kiếm</button>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">Không tìm thấy khách hàng nào đang ở hoặc quá hạn.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 fs-7">
                        <thead>
                            <tr class="table-gov-header">
                                <th>Phòng</th>
                                <th>Họ và tên</th>
                                <th>Số hộ chiếu</th>
                                <th>Quốc tịch</th>
                                <th>Ngày Check-in</th>
                                <th>Rời đi dự kiến</th>
                                <th>Trạng thái</th>
                                <th class="text-center">Thao tác / Cập nhật lưu trú</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stay in Model)
                            {
                                <tr>
                                    <td><span class="fw-bold">@stay.Phong</span></td>
                                    <td class="fw-bold">@stay.NguoiNuocNgoai.HoTen</td>
                                    <td>@stay.NguoiNuocNgoai.SoHoChieu</td>
                                    <td>@stay.NguoiNuocNgoai.QuocTich</td>
                                    <td>@stay.NgayBatDau.ToString("dd/MM/yyyy")</td>
                                    <td>@(stay.NgayKetThuc.HasValue ? stay.NgayKetThuc.Value.ToString("dd/MM/yyyy") : "Chưa đăng ký")</td>
                                    <td>
                                        @await Html.PartialAsync("_StatusBadge", stay.TrangThai)
                                    </td>
                                    <td class="text-center">
                                        <div class="d-inline-flex gap-2">
                                            <!-- Check-out button -->
                                            <form asp-action="CapNhatTrangThai" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn trả phòng (check-out) cho vị khách này?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@stay.MaLSLuuTru" />
                                                <input type="hidden" name="actionType" value="checkout" />
                                                <button type="submit" class="btn btn-success btn-xs" style="border-radius: 6px;">
                                                    <i class="bi bi-door-open-fill"></i> Check-out
                                                </button>
                                            </form>

                                            <!-- Overdue button -->
                                            @if (stay.TrangThai != "Quá hạn")
                                            {
                                                <form asp-action="CapNhatTrangThai" method="post" onsubmit="return confirm('Bạn muốn đánh dấu trạng thái lưu trú của người này thành Quá hạn?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@stay.MaLSLuuTru" />
                                                    <input type="hidden" name="actionType" value="overdue" />
                                                    <button type="submit" class="btn btn-warning btn-xs text-dark" style="border-radius: 6px;">
                                                        <i class="bi bi-exclamation-triangle"></i> Quá hạn
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-4">
                    @Html.PagedListPager(Model, page => Url.Action("DanhSachLuuTru", new { page, search = ViewBag.Search }),
                        new X.PagedList.Mvc.Core.PagedListRenderOptions {
                            LiElementClasses = new string[] { "page-item" },
                            PageClasses = new string[] { "page-link" },
                            UlElementClasses = new string[] { "pagination", "pagination-sm" }
                        })
                </div>
            }
        </div>
    </div>
</div>
