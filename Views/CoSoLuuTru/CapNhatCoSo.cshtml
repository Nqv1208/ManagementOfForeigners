@model ManagementOfForeigners.Models.ViewModels.CoSoLuuTru.CoSoViewModel
@{
    ViewBag.Title = "Cập nhật thông tin cơ sở lưu trú";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                <div class="card-header gov-card-header p-4">
                    <h5 class="fw-bold mb-0">Cập nhật thông tin cơ sở</h5>
                    <p class="text-white-50 mb-0 fs-7">Chỉnh sửa thông tin liên hệ và địa chỉ của cơ sở lưu trú</p>
                </div>

                <div class="card-body p-4">
                    <form asp-action="CapNhatCoSo" method="post" class="needs-validation">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="TenCoSo" class="form-label fw-semibold text-dark fs-7"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-building text-muted"></i></span>
                                    <input asp-for="TenCoSo" class="form-control border-start-0" placeholder="Nhập tên khách sạn, nhà trọ..." style="border-radius: 0 8px 8px 0;" />
                                </div>
                                <span asp-validation-for="TenCoSo" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="DiaChi" class="form-label fw-semibold text-dark fs-7"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-geo-alt text-muted"></i></span>
                                    <input asp-for="DiaChi" class="form-control border-start-0" placeholder="Nhập địa chỉ chi tiết số nhà, tên đường..." style="border-radius: 0 8px 8px 0;" />
                                </div>
                                <span asp-validation-for="DiaChi" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="MaPhuongXa" class="form-label fw-semibold text-dark fs-7"></label>
                                <select asp-for="MaPhuongXa" asp-items="ViewBag.PhuongXas" class="form-select" style="border-radius: 8px;">
                                    <option value="">-- Chọn Phường/Xã --</option>
                                </select>
                                <span asp-validation-for="MaPhuongXa" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="SoDienThoai" class="form-label fw-semibold text-dark fs-7"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-telephone text-muted"></i></span>
                                    <input asp-for="SoDienThoai" class="form-control border-start-0" placeholder="Nhập số điện thoại liên hệ..." style="border-radius: 0 8px 8px 0;" />
                                </div>
                                <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-semibold text-dark fs-7"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control border-start-0" placeholder="Nhập địa chỉ email..." style="border-radius: 0 8px 8px 0;" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-12 d-flex justify-content-between mt-4">
                                <a asp-action="ThongTinCoSo" class="btn btn-outline-secondary px-4 fw-semibold" style="border-radius: 8px;">
                                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                                </a>
                                <button type="submit" class="btn btn-primary px-4 fw-semibold" style="border-radius: 8px;">
                                    <i class="bi bi-save me-1"></i> Lưu thay đổi
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
