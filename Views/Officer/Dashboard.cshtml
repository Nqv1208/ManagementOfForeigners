@model ManagementOfForeigners.Models.ViewModels.Officer.DashboardViewModel
@{
    ViewBag.Title = "Bảng điều khiển - Cán bộ XNC";
}

<div class="container py-4">
    <!-- Header banner -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white border-0 shadow-sm overflow-hidden" style="border-radius: 20px;">
                <div class="p-5 d-flex align-items-center justify-content-between flex-wrap gap-4">
                    <div>
                        <span class="badge bg-primary px-3 py-2 mb-2" style="border-radius: 30px;">Phòng Quản lý Xuất Nhập Cảnh</span>
                        <h2 class="fw-bold mb-1">Hệ thống Quản lý Người Nước Ngoài TP. Đà Nẵng</h2>
                        <p class="text-white-50 mb-0">Hồ sơ nghiệp vụ, tra cứu, xử lý vi phạm và thống kê báo cáo xuất nhập cảnh</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="TraCuu" class="btn btn-primary fw-semibold px-4 py-2" style="border-radius: 10px;">
                            <i class="bi bi-search me-1"></i> Tra cứu nhanh
                        </a>
                        <a asp-action="ThongKe" class="btn btn-outline-light fw-semibold px-4 py-2" style="border-radius: 10px;">
                            <i class="bi bi-graph-up me-1"></i> Thống kê
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Analytics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm text-white bg-dark h-100" style="border-radius: 16px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 fw-semibold mb-1 fs-7">Người nước ngoài</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalForeigners</h2>
                    </div>
                    <div class="bg-white bg-opacity-10 text-white rounded-circle p-3 fs-3 d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm text-white bg-primary h-100" style="border-radius: 16px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 fw-semibold mb-1 fs-7">Hồ sơ tạm trú</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalDeclarations</h2>
                    </div>
                    <div class="bg-white bg-opacity-10 text-white rounded-circle p-3 fs-3 d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-file-earmark-text-fill"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm text-white bg-warning h-100" style="border-radius: 16px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-dark-50 fw-semibold mb-1 fs-7 text-dark">Cảnh báo vi phạm</h6>
                        <h2 class="fw-bold mb-0 text-dark">@Model.TotalWarnings</h2>
                    </div>
                    <div class="bg-white bg-opacity-20 text-dark rounded-circle p-3 fs-3 d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm text-white bg-danger h-100" style="border-radius: 16px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 fw-semibold mb-1 fs-7">Báo cáo vi phạm</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalReports</h2>
                    </div>
                    <div class="bg-white bg-opacity-10 text-white rounded-circle p-3 fs-3 d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-flag-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Declarations -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark">Khai báo tạm trú mới nhất</h5>
                    <span class="badge bg-light text-dark px-3 py-2 fs-8" style="border-radius: 10px;">5 hồ sơ gần đây</span>
                </div>
                <div class="card-body p-4">
                    @if (!Model.RecentDeclarations.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-file-earmark-x text-muted" style="font-size: 2.5rem;"></i>
                            <p class="text-muted mt-2 mb-0">Chưa có hồ sơ khai báo nào.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 fs-8">
                                <thead>
                                    <tr class="table-light">
                                        <th>Khách</th>
                                        <th>Cơ sở</th>
                                        <th>Ngày khai</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dec in Model.RecentDeclarations)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold">@(dec.TaiKhoan?.NguoiNuocNgoai?.HoTen ?? "N/A")</div>
                                                <small class="text-muted">HC: @(dec.TaiKhoan?.NguoiNuocNgoai?.SoHoChieu ?? "N/A")</small>
                                            </td>
                                            <td>@(dec.CoSoLuuTru?.TenCoSo ?? "Nhà riêng / Cư trú tự do")</td>
                                            <td>@dec.NgayKhaiBao.ToString("dd/MM/yyyy")</td>
                                            <td>@await Html.PartialAsync("_StatusBadge", dec.TrangThai)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Warnings & Reports -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark">Cảnh báo vi phạm gần đây</h5>
                    <a asp-action="DanhSachCanhBao" class="text-decoration-none fs-8 fw-semibold text-primary">Xem tất cả <i class="bi bi-chevron-right fs-9"></i></a>
                </div>
                <div class="card-body p-4">
                    @if (!Model.RecentWarnings.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-shield-check text-muted" style="font-size: 2.5rem;"></i>
                            <p class="text-muted mt-2 mb-0">Chưa có cảnh báo vi phạm nào.</p>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var warn in Model.RecentWarnings)
                            {
                                <div class="p-3 bg-light rounded-3 d-flex align-items-start gap-3">
                                    <div class="bg-warning bg-opacity-20 text-warning rounded-circle p-2 fs-5 d-inline-flex align-items-center justify-content-center" style="width: 40px; height: 40px; min-width: 40px;">
                                        <i class="bi bi-exclamation-triangle"></i>
                                    </div>
                                    <div class="w-100">
                                        <div class="d-flex justify-content-between flex-wrap gap-2 mb-1">
                                            <span class="fw-bold text-dark fs-7">@warn.NguoiNuocNgoai.HoTen</span>
                                            <small class="text-muted fs-8">@warn.NgayCanhBao.ToString("dd/MM/yyyy HH:mm")</small>
                                        </div>
                                        <div class="text-muted fs-8 mb-2">Loại: <span class="text-dark fw-semibold">@warn.LoaiViPham</span> | Mức độ: <span class="badge bg-danger">@warn.MucDoViPham</span></div>
                                        <p class="mb-0 text-secondary fs-8 style-multiline-ellipsis">@warn.NoiDungCanhBao</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
