@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<ManagementOfForeigners.Models.Entities.CanhBaoViPham>
@{
    ViewBag.Title = "Danh sách cảnh báo vi phạm";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-header bg-dark text-white p-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h5 class="fw-bold mb-0">Danh sách cảnh báo vi phạm</h5>
                <p class="text-white-50 mb-0 fs-7">Lịch sử gửi các cảnh báo vi phạm cho người nước ngoài trên địa bàn</p>
            </div>
            <a asp-action="CanhBaoViPham" class="btn btn-light btn-sm fw-bold px-3 py-2" style="border-radius: 8px;">
                <i class="bi bi-plus-circle me-1"></i> Tạo cảnh báo mới
            </a>
        </div>

        <div class="card-body p-4">
            <!-- Search Form -->
            <form asp-action="DanhSachCanhBao" method="get" class="row g-3 mb-4">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 8px 0 0 8px;"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" value="@ViewBag.Search" placeholder="Tìm theo họ tên, số hộ chiếu, loại vi phạm..." style="border-radius: 0 8px 8px 0;" />
                    </div>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-dark w-100 fw-semibold" style="border-radius: 8px;">Tìm kiếm</button>
                </div>
            </form>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px;">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-shield-check text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">Không tìm thấy cảnh báo vi phạm nào.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 fs-7">
                        <thead>
                            <tr class="table-dark">
                                <th>Ngày gửi</th>
                                <th>Người nước ngoài</th>
                                <th>Số hộ chiếu</th>
                                <th>Loại vi phạm</th>
                                <th>Mức độ</th>
                                <th>Nội dung cảnh báo</th>
                                <th>Cán bộ gửi</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var warn in Model)
                            {
                                <tr>
                                    <td>@warn.NgayCanhBao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="fw-bold">@warn.NguoiNuocNgoai.HoTen</td>
                                    <td>@warn.NguoiNuocNgoai.SoHoChieu</td>
                                    <td><span class="text-dark fw-semibold">@warn.LoaiViPham</span></td>
                                    <td>
                                        @if (warn.MucDoViPham == "Nhẹ")
                                        {
                                            <span class="badge bg-info text-dark px-2.5 py-1.5" style="border-radius: 6px;">Nhẹ</span>
                                        }
                                        else if (warn.MucDoViPham == "Trung bình")
                                        {
                                            <span class="badge bg-warning text-dark px-2.5 py-1.5" style="border-radius: 6px;">Trung bình</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-2.5 py-1.5" style="border-radius: 6px;">Nghiêm trọng</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted style-multiline-ellipsis" style="max-width: 250px; display: inline-block;">
                                            @warn.NoiDungCanhBao
                                        </small>
                                    </td>
                                    <td>@warn.CanBo.HoTen</td>
                                    <td><span class="badge bg-secondary">@warn.TrangThai</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-4">
                    @Html.PagedListPager(Model, page => Url.Action("DanhSachCanhBao", new { page, search = ViewBag.Search }),
                        new X.PagedList.Mvc.Core.PagedListRenderOptions {
                            LiElementClasses = new string[] { "page-item" },
                            PageClasses = new string[] { "page-link" },
                            UlElementClasses = new string[] { "pagination", "pagination-sm" }
                        })
                </div>
            }
        </div>
    </div>
</div>
