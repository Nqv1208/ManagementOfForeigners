@model IEnumerable<ManagementOfForeigners.Models.Entities.TaiKhoan>
@using ManagementOfForeigners.Models.Entities

@{
    ViewData["Title"] = "Quản lý Tài khoản";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white p-4">
            <h5 class="fw-bold mb-0">Quản lý tài khoản người dùng</h5>
            <p class="text-white-50 mb-0 small">Cập nhật vai trò và trạng thái tài khoản theo đúng phân quyền backend.</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="QuanLyTaiKhoan" method="get" class="row g-3 mb-4">
                <div class="col-md-5">
                    <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Tên đăng nhập, email, số điện thoại" />
                </div>
                <div class="col-md-3">
                    <select name="maVaiTro" asp-items="ViewBag.VaiTros" class="form-select">
                        <option value="">Tất cả vai trò</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="trangThai" class="form-select">
                        <option value="">Tất cả trạng thái</option>
                        <option value="@TrangThaiTaiKhoan.HoatDong" selected="@(ViewBag.TrangThai == TrangThaiTaiKhoan.HoatDong)">@TrangThaiTaiKhoan.HoatDong</option>
                        <option value="@TrangThaiTaiKhoan.Khoa" selected="@(ViewBag.TrangThai == TrangThaiTaiKhoan.Khoa)">@TrangThaiTaiKhoan.Khoa</option>
                        <option value="@TrangThaiTaiKhoan.ChoDuyet" selected="@(ViewBag.TrangThai == TrangThaiTaiKhoan.ChoDuyet)">@TrangThaiTaiKhoan.ChoDuyet</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-search me-1"></i>Lọc</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Tên đăng nhập</th>
                            <th>Email</th>
                            <th>Số điện thoại</th>
                            <th>Vai trò</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Cập nhật</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var formId = $"account-{item.MaTaiKhoan}";
                            <tr>
                                <td class="fw-semibold">@item.TenDangNhap</td>
                                <td>@item.Email</td>
                                <td>@item.SoDienThoai</td>
                                <td>
                                    <select name="maVaiTro" class="form-select form-select-sm" form="@formId">
                                        @foreach (var role in (SelectList)ViewBag.VaiTros)
                                        {
                                            <option value="@role.Value" selected="@(role.Value == item.MaVaiTro.ToString())">@role.Text</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <select name="trangThai" class="form-select form-select-sm" form="@formId">
                                        <option value="@TrangThaiTaiKhoan.HoatDong" selected="@(item.TrangThai == TrangThaiTaiKhoan.HoatDong)">@TrangThaiTaiKhoan.HoatDong</option>
                                        <option value="@TrangThaiTaiKhoan.Khoa" selected="@(item.TrangThai == TrangThaiTaiKhoan.Khoa)">@TrangThaiTaiKhoan.Khoa</option>
                                        <option value="@TrangThaiTaiKhoan.ChoDuyet" selected="@(item.TrangThai == TrangThaiTaiKhoan.ChoDuyet)">@TrangThaiTaiKhoan.ChoDuyet</option>
                                    </select>
                                </td>
                                <td class="text-end">
                                    <form id="@formId" asp-action="CapNhatTaiKhoan" method="post" onsubmit="return confirm('Cập nhật tài khoản này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="maTaiKhoan" value="@item.MaTaiKhoan" />
                                        <button class="btn btn-sm btn-dark" type="submit">Lưu</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
