@model IEnumerable<ManagementOfForeigners.Models.ViewModels.Admin.AdminFacilityRowViewModel>
@using ManagementOfForeigners.Models.Entities
@{
    ViewData["Title"] = "Quản lý cơ sở lưu trú";
    string? search = ViewBag.Search as string;
    string? status = ViewBag.Status as string;
}
<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

<section class="admin-page-title">
    <div>
        <span class="admin-eyebrow">Quản trị lưu trú</span>
        <h1>Quản lý cơ sở lưu trú</h1>
        <p>Theo dõi khách đang ở, số hồ sơ khai báo và trạng thái hoạt động của từng cơ sở.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Admin" asp-action="Dashboard">Về dashboard</a>
</section>

<form method="get" class="admin-filter-card">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Tìm kiếm</label>
            <input class="form-control" name="search" value="@search" placeholder="Tên cơ sở, địa chỉ, email, số điện thoại..." />
        </div>
        <div class="col-md-4">
            <label class="form-label">Trạng thái</label>
            <select class="form-select" name="status">
                <option value="">Tất cả trạng thái</option>
                <option value="@TrangThaiCoSo.DangHoatDong" selected="@(status == TrangThaiCoSo.DangHoatDong)">Đang hoạt động</option>
                <option value="@TrangThaiCoSo.DaNgungHoatDong" selected="@(status == TrangThaiCoSo.DaNgungHoatDong)">Đã ngừng hoạt động</option>
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end gap-2">
            <button class="btn btn-primary w-100" type="submit">Lọc</button>
            <a class="btn btn-light" asp-controller="Admin" asp-action="CoSoLuuTru">Xoá</a>
        </div>
    </div>
</form>

<section class="admin-panel">
    <div class="admin-panel-header">
        <div>
            <h2>Danh sách cơ sở</h2>
            <p>Cho phép tạm ngừng hoặc mở lại cơ sở lưu trú khi cần kiểm tra.</p>
        </div>
        <span class="admin-chip">@Model.Count() kết quả</span>
    </div>
    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Cơ sở</th>
                    <th>Chủ cơ sở / tài khoản</th>
                    <th>Liên hệ</th>
                    <th>Khách đang ở</th>
                    <th>Hồ sơ</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.TenCoSo</strong><br /><small>@item.DiaChi</small></td>
                    <td>@item.ChuCoSo<br /><small>@item.TenDangNhap</small></td>
                    <td><small>@item.SoDienThoai<br />@item.Email</small></td>
                    <td><span class="admin-number">@item.SoKhachDangO</span></td>
                    <td><span class="admin-number">@item.TongHoSoKhaiBao</span></td>
                    <td>@await Html.PartialAsync("_StatusBadge", item.TrangThai)</td>
                    <td class="text-end">
                        <form asp-controller="Admin" asp-action="DoiTrangThaiCoSo" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.MaCoSoLuuTru" />
                            <button class="btn btn-sm @(item.TrangThai == TrangThaiCoSo.DangHoatDong ? "btn-outline-danger" : "btn-success")" type="submit">
                                @(item.TrangThai == TrangThaiCoSo.DangHoatDong ? "Tạm ngừng" : "Mở lại")
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
