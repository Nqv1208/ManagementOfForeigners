@model IEnumerable<ManagementOfForeigners.Models.Entities.PhuongXa>

@{
    ViewData["Title"] = "Danh mục Phường/Xã";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white p-4">
            <h5 class="fw-bold mb-0">Cập nhật danh mục Phường/Xã</h5>
            <p class="text-white-50 mb-0 small">Danh mục địa bàn dùng cho cán bộ phụ trách và cơ sở lưu trú.</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="LuuPhuongXa" method="post" class="row g-2 mb-4">
                @Html.AntiForgeryToken()
                <div class="col-md-10"><input name="tenPhuongXa" class="form-control" placeholder="Tên Phường/Xã" /></div>
                <div class="col-md-2 d-grid"><button class="btn btn-primary" type="submit">Thêm mới</button></div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Phường/Xã</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var formId = $"ward-{item.MaPhuongXa}";
                            <tr>
                                <td class="fw-semibold">@item.MaPhuongXa</td>
                                <td><input name="tenPhuongXa" form="@formId" class="form-control form-control-sm" value="@item.TenPhuongXa" /></td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <form id="@formId" asp-action="LuuPhuongXa" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="maPhuongXa" value="@item.MaPhuongXa" />
                                            <button class="btn btn-sm btn-dark" type="submit">Lưu</button>
                                        </form>
                                        <form asp-action="XoaPhuongXa" method="post" onsubmit="return confirm('Xóa Phường/Xã này?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="maPhuongXa" value="@item.MaPhuongXa" />
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
