@model IEnumerable<ManagementOfForeigners.Models.Entities.VaiTro>

@{
    ViewData["Title"] = "Quản lý Phân quyền";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white p-4">
            <h5 class="fw-bold mb-0">Quản lý vai trò và quyền hạn</h5>
            <p class="text-white-50 mb-0 small">Chỉ cấu hình các quyền thuộc phạm vi nghiệp vụ đã xác định.</p>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 16%;">Vai trò</th>
                            <th style="width: 24%;">Mô tả</th>
                            <th style="width: 14%;">Trạng thái</th>
                            <th>Quyền hạn</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var formId = $"role-{item.MaVaiTro}";
                            <tr>
                                <td class="fw-bold">@item.TenVaiTro</td>
                                <td>
                                    <input name="moTaVaiTro" form="@formId" class="form-control form-control-sm" value="@item.MoTaVaiTro" />
                                </td>
                                <td>
                                    <select name="trangThai" form="@formId" class="form-select form-select-sm">
                                        <option value="Hoạt động" selected="@(item.TrangThai == "Hoạt động")">Hoạt động</option>
                                        <option value="Tạm ngưng" selected="@(item.TrangThai == "Tạm ngưng")">Tạm ngưng</option>
                                    </select>
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        @foreach (var q in item.QuyenHans)
                                        {
                                            <form asp-action="XoaQuyen" method="post" onsubmit="return confirm('Xóa quyền @q.TenQuyen?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="maQuyen" value="@q.MaQuyen" />
                                                <button class="badge bg-info text-dark border-0" type="submit">@q.TenQuyen <i class="bi bi-x"></i></button>
                                            </form>
                                        }
                                    </div>
                                    <form asp-action="ThemQuyen" method="post" class="row g-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="maVaiTro" value="@item.MaVaiTro" />
                                        <div class="col-md-5"><input name="tenQuyen" class="form-control form-control-sm" placeholder="Tên quyền" /></div>
                                        <div class="col-md-5"><input name="moTaQuyen" class="form-control form-control-sm" placeholder="Mô tả" /></div>
                                        <div class="col-md-2 d-grid"><button class="btn btn-sm btn-outline-primary" type="submit">Thêm</button></div>
                                    </form>
                                </td>
                                <td class="text-end">
                                    <form id="@formId" asp-action="CapNhatVaiTro" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="maVaiTro" value="@item.MaVaiTro" />
                                        <button class="btn btn-sm btn-dark" type="submit">Lưu vai trò</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
