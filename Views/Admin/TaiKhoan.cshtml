@model IEnumerable<ManagementOfForeigners.Models.ViewModels.Admin.AdminAccountRowViewModel>
@using ManagementOfForeigners.Models.Entities
@{
    ViewData["Title"] = "Quản lý tài khoản";
    var roles = ViewBag.Roles as List<VaiTro> ?? new List<VaiTro>();
    string? search = ViewBag.Search as string;
    string? status = ViewBag.Status as string;
    int? selectedRole = ViewBag.Role == null ? null : Convert.ToInt32(ViewBag.Role);
}
<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

<section class="admin-page-title">
    <div>
        <span class="admin-eyebrow">Quản trị người dùng</span>
        <h1>Quản lý tài khoản hệ thống</h1>
        <p>Tìm kiếm, lọc theo vai trò, khoá/mở khoá và đặt lại mật khẩu tạm thời.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Admin" asp-action="Dashboard">Về dashboard</a>
</section>

<form method="get" class="admin-filter-card">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Tìm kiếm</label>
            <input class="form-control" name="search" value="@search" placeholder="Tên đăng nhập, email, SĐT, họ tên..." />
        </div>
        <div class="col-md-3">
            <label class="form-label">Vai trò</label>
            <select class="form-select" name="role">
                <option value="">Tất cả vai trò</option>
                @foreach (var role in roles)
                {
                    <option value="@role.MaVaiTro" selected="@(selectedRole == role.MaVaiTro)">@role.TenVaiTro</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Trạng thái</label>
            <select class="form-select" name="status">
                <option value="">Tất cả trạng thái</option>
                <option value="@TrangThaiTaiKhoan.HoatDong" selected="@(status == TrangThaiTaiKhoan.HoatDong)">Hoạt động</option>
                <option value="@TrangThaiTaiKhoan.Khoa" selected="@(status == TrangThaiTaiKhoan.Khoa)">Khoá</option>
                <option value="@TrangThaiTaiKhoan.ChoDuyet" selected="@(status == TrangThaiTaiKhoan.ChoDuyet)">Chờ duyệt</option>
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end gap-2">
            <button class="btn btn-primary w-100" type="submit">Lọc</button>
            <a class="btn btn-light" asp-controller="Admin" asp-action="TaiKhoan">Xoá</a>
        </div>
    </div>
</form>

<section class="admin-panel">
    <div class="admin-panel-header">
        <div>
            <h2>Danh sách tài khoản</h2>
            <p>Hiển thị tối đa 200 kết quả gần nhất để tránh tải quá nặng.</p>
        </div>
        <span class="admin-chip">@Model.Count() kết quả</span>
    </div>
    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Tài khoản</th>
                    <th>Chủ thể</th>
                    <th>Vai trò</th>
                    <th>Liên hệ</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.TenDangNhap</strong><br /><small>@item.MaTaiKhoan</small></td>
                    <td>@item.OwnerDisplayName</td>
                    <td><span class="admin-chip">@item.VaiTro</span></td>
                    <td><small>@(item.Email ?? "—")<br />@(item.SoDienThoai ?? "—")</small></td>
                    <td>@await Html.PartialAsync("_StatusBadge", item.TrangThai)</td>
                    <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                    <td class="text-end">
                        <form asp-controller="Admin" asp-action="DoiTrangThaiTaiKhoan" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.MaTaiKhoan" />
                            <button class="btn btn-sm @(item.TrangThai == TrangThaiTaiKhoan.Khoa ? "btn-success" : "btn-outline-danger")" type="submit">
                                @(item.TrangThai == TrangThaiTaiKhoan.Khoa ? "Mở khoá" : "Khoá")
                            </button>
                        </form>
                        <form asp-controller="Admin" asp-action="DatLaiMatKhau" method="post" class="d-inline" onsubmit="return confirm('Đặt lại mật khẩu tạm thời cho tài khoản này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.MaTaiKhoan" />
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Reset mật khẩu</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
