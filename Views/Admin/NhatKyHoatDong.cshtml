@model IEnumerable<ManagementOfForeigners.Models.ViewModels.Admin.AuditEntryViewModel>

@{
    ViewData["Title"] = "Nhật ký hoạt động";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white p-4">
            <h5 class="fw-bold mb-0">Nhật ký hoạt động hệ thống</h5>
            <p class="text-white-50 mb-0 small">Tổng hợp từ lịch sử cập nhật thông tin, cảnh báo và báo cáo vi phạm.</p>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Thời gian</th>
                            <th>Nguồn</th>
                            <th>Loại</th>
                            <th>Nội dung</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.OccurredAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-semibold">@item.ActorOrSource</td>
                                <td>@item.Category</td>
                                <td>@item.Detail</td>
                                <td>@await Html.PartialAsync("_StatusBadge", item.Status)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
